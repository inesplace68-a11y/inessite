{%- comment -%}
  Phase 18 — Page Presse · Hero
  Titre Cormorant italic centré + intro Jost Light centré.
  Align hero home : title_size ~60, intro 16, padding 80/48.
{%- endcomment -%}

{{ 'section-presse-hero.css' | asset_url | stylesheet_tag }}

<section
  class="presse-hero"
  style="
    --presse-hero-title-size: {{ section.settings.title_size }}px;
    --presse-hero-title-color: {{ section.settings.title_color }};
    --presse-hero-intro-size: {{ section.settings.intro_size }}px;
    --presse-hero-intro-max-width: {{ section.settings.intro_max_width }}px;
    --presse-hero-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --presse-hero-intro-color: {{ section.settings.intro_color }};
    --presse-hero-intro-margin-top: {{ section.settings.intro_margin_top }}px;
    --presse-hero-padding-top: {{ section.settings.padding_top }}px;
    --presse-hero-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="presse-hero__inner">
    {%- if section.settings.title_text != blank -%}
      <h1 class="presse-hero__title">{{ section.settings.title_text | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <div class="presse-hero__intro rte">{{ section.settings.intro_text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Presse · Hero",
  "tag": "section",
  "class": "shopify-section--presse-hero",
  "settings": [
    { "type": "header", "content": "Titre" },
    { "type": "text", "id": "title_text", "label": "Titre", "default": "Presse" },
    { "type": "range", "id": "title_size", "min": 40, "max": 140, "step": 2, "unit": "px", "label": "Taille titre", "default": 60 },
    { "type": "color", "id": "title_color", "label": "Couleur titre", "default": "#1A1614" },

    { "type": "header", "content": "Intro" },
    { "type": "richtext", "id": "intro_text", "label": "Texte d'intro", "default": "<p>Maison Coeur est une jeune galerie parisienne fondée en 2019, dédiée au mobilier vintage, au design de collection et à l'art singulier. Pour toute rédaction ou journaliste souhaitant raconter une pièce, retracer sa provenance, ou évoquer notre regard de curatrice, nous mettons à disposition visuels haute définition, contextes éditoriaux, et accès au showroom sur rendez-vous.</p>" },
    { "type": "range", "id": "intro_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Taille intro", "default": 16 },
    { "type": "range", "id": "intro_max_width", "min": 400, "max": 1000, "step": 10, "unit": "px", "label": "Largeur max intro", "default": 720 },
    { "type": "range", "id": "intro_line_height", "min": 120, "max": 250, "step": 5, "unit": "%", "label": "Interligne intro", "default": 170 },
    { "type": "color", "id": "intro_color", "label": "Couleur intro", "default": "#5A5446" },
    { "type": "range", "id": "intro_margin_top", "min": 8, "max": 120, "step": 2, "unit": "px", "label": "Marge titre → intro", "default": 32 },

    { "type": "header", "content": "Espacement section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding haut", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 28, "max": 300, "step": 4, "unit": "px", "label": "Padding bas", "default": 48 }
  ],
  "presets": [
    { "name": "Presse · Hero" }
  ]
}
{% endschema %}
