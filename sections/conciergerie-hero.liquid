{%- comment -%}
  Phase 17.12 — Page Conciergerie · Hero (overlay layout)
  Titre + baseline + intro SUPERPOSÉS au centre de l'image hero
  (mode éditorial luxe). Image + overlay tint sous le texte via z-index.
{%- endcomment -%}

{{ 'section-conciergerie-hero.css' | asset_url | stylesheet_tag }}

<section
  class="conciergerie-hero"
  style="
    --hero-title-size: {{ section.settings.title_size }}px;
    --hero-title-color: {{ section.settings.title_color }};
    --hero-baseline-size: {{ section.settings.baseline_size }}px;
    --hero-baseline-color: {{ section.settings.baseline_color }};
    --hero-baseline-margin-bottom: {{ section.settings.baseline_margin_bottom }}px;
    --hero-intro-size: {{ section.settings.intro_size }}px;
    --hero-intro-max-width: {{ section.settings.intro_max_width }}px;
    --hero-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --hero-intro-color: {{ section.settings.intro_color }};
    --hero-image-height: {{ section.settings.hero_image_height }}px;
    --hero-image-side-padding: {{ section.settings.hero_image_side_padding }}px;
    --hero-overlay-color: {{ section.settings.overlay_color }};
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-padding-top: {{ section.settings.padding_top }}px;
    --hero-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="conciergerie-hero__media">
    {%- if section.settings.hero_image != blank -%}
      <img
        class="conciergerie-hero__image"
        src="{{ section.settings.hero_image | image_url: width: 2320 }}"
        srcset="{{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w, {{ section.settings.hero_image | image_url: width: 1600 }} 1600w, {{ section.settings.hero_image | image_url: width: 2320 }} 2320w"
        sizes="100vw"
        alt="{{ section.settings.hero_image.alt | default: section.settings.title_text | escape }}"
        loading="eager"
        width="2320"
        height="1000"
      >
    {%- else -%}
      <div class="conciergerie-hero__placeholder" role="img" aria-label="Photo à venir">
        <span class="conciergerie-hero__placeholder-label">PHOTO À VENIR</span>
        {%- if section.settings.hero_image_caption != blank -%}
          <span class="conciergerie-hero__placeholder-caption">{{ section.settings.hero_image_caption | escape }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="conciergerie-hero__content">
    {%- if section.settings.title_text != blank -%}
      <h1 class="conciergerie-hero__title">{{ section.settings.title_text | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.baseline_text != blank -%}
      <p class="conciergerie-hero__baseline">{{ section.settings.baseline_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <div class="conciergerie-hero__intro rte">{{ section.settings.intro_text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Conciergerie · Hero",
  "tag": "section",
  "class": "shopify-section--conciergerie-hero",
  "settings": [
    { "type": "header", "content": "Titre" },
    { "type": "text", "id": "title_text", "label": "Titre", "default": "Service de curation sur mesure" },
    { "type": "range", "id": "title_size", "min": 40, "max": 140, "step": 2, "unit": "px", "label": "Taille titre", "default": 56 },
    { "type": "color", "id": "title_color", "label": "Couleur titre", "default": "#1A1614" },

    { "type": "header", "content": "Baseline" },
    { "type": "text", "id": "baseline_text", "label": "Baseline", "default": "Nous vous aidons à créer des espaces qui vous ressemblent." },
    { "type": "range", "id": "baseline_size", "min": 14, "max": 40, "step": 1, "unit": "px", "label": "Taille baseline", "default": 22 },
    { "type": "color", "id": "baseline_color", "label": "Couleur baseline", "default": "#5A5446" },
    { "type": "range", "id": "baseline_margin_bottom", "min": 8, "max": 120, "step": 2, "unit": "px", "label": "Marge bas baseline", "default": 16 },

    { "type": "header", "content": "Intro" },
    { "type": "richtext", "id": "intro_text", "label": "Texte d'intro", "default": "<p>Pour celles et ceux qui recherchent une pièce spécifique — un meuble, un luminaire, un objet, une œuvre — Maison Coeur met son réseau de marchands et son regard curatorial au service de votre projet. Le sourcing s'enracine en France et s'étend à l'international pour les pièces les plus rares.</p>" },
    { "type": "range", "id": "intro_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Taille intro", "default": 16 },
    { "type": "range", "id": "intro_max_width", "min": 400, "max": 1000, "step": 10, "unit": "px", "label": "Largeur max intro", "default": 700 },
    { "type": "range", "id": "intro_line_height", "min": 120, "max": 250, "step": 5, "unit": "%", "label": "Interligne intro", "default": 170 },
    { "type": "color", "id": "intro_color", "label": "Couleur intro", "default": "#5A5446" },

    { "type": "header", "content": "Image hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Image hero (vide = placeholder)" },
    { "type": "text", "id": "hero_image_caption", "label": "Caption placeholder (si pas d'image)", "default": "Showroom Maison Coeur · scène de curation éditoriale" },
    { "type": "range", "id": "hero_image_height", "min": 300, "max": 700, "step": 10, "unit": "px", "label": "Hauteur image", "default": 440 },
    { "type": "range", "id": "hero_image_margin_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Marge haut image (déprécié en 17.12)", "default": 28 },
    { "type": "range", "id": "hero_image_side_padding", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding latéral contenu", "default": 140 },

    { "type": "header", "content": "Overlay (lisibilité texte sur image)" },
    { "type": "color", "id": "overlay_color", "label": "Couleur overlay (sur image)", "default": "#EFE7D5" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 4, "unit": "%", "label": "Opacité overlay", "default": 0 },

    { "type": "header", "content": "Espacement section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding haut", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding bas", "default": 48 }
  ],
  "presets": [
    { "name": "Conciergerie · Hero" }
  ]
}
{% endschema %}
