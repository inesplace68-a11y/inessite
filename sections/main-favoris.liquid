{% comment %}
  Page MA SÉLECTION (wishlist) — Phase 1 MVP localStorage
  Patterns réutilisés (audit Phase 1) :
  - .template-search__eyebrow + .mc-search-eyebrow → eyebrow
  - .template-search__title (Cormorant italic 28px) → H1
  - .template-search__count → compteur "X pieces"
  - .template-search__empty + .title--primary → état vide
  - .mc-search-block--concierge + .mc-search-concierge__cta → bandeau anonyme
  - <ul class="grid product-grid grid--X-col-tablet-down grid--Y-col-desktop"> → grille
{% endcomment %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #shopify-section-{{ section.id }} .template-favoris__header {
    padding-top: {{ section.settings.header_padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.header_padding_bottom | times: 0.75 | round: 0 }}px;
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .template-favoris__header {
      padding-top: {{ section.settings.header_padding_top }}px;
      padding-bottom: {{ section.settings.header_padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="template-favoris section-{{ section.id }}-padding"
  data-template="favoris"
  data-mc-favoris-root
>
  <div class="template-favoris__header page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {%- if section.settings.eyebrow_text != blank -%}
      <span class="template-favoris__eyebrow mc-search-eyebrow">
        {{- section.settings.eyebrow_text -}}
      </span>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="template-favoris__title">{{ section.settings.title }}</h1>
    {%- endif -%}

    <p
      class="template-favoris__count"
      role="status"
      data-mc-favoris-count
      hidden
    ></p>
  </div>

  {%- render 'votre-espace-bar',
    bar_bg: section.settings.bar_bg,
    bar_padding_y: section.settings.bar_padding_y,
    spacing_top: section.settings.spacing_top,
    spacing_bottom: section.settings.spacing_bottom,
    bullet_color: section.settings.bullet_color,
    eyebrow_text: section.settings.eyebrow_bar_text,
    eyebrow_size: section.settings.eyebrow_size,
    eyebrow_ls: section.settings.eyebrow_ls,
    eyebrow_color: section.settings.eyebrow_color,
    body_text: section.settings.body_text,
    body_size: section.settings.body_size,
    body_color: section.settings.body_color,
    cta_label: section.settings.cta_label,
    cta_url: section.settings.cta_url,
    cta_size: section.settings.cta_size,
    cta_ls: section.settings.cta_ls,
    cta_color: section.settings.cta_color
  -%}

  {%- comment -%} État vide {%- endcomment -%}
  <div class="template-favoris__empty page-width center" data-mc-favoris-empty>
    <h2 class="template-favoris__empty-title title title--primary" role="status">
      {{ section.settings.empty_text }}
    </h2>
    {%- if section.settings.empty_cta_text != blank and section.settings.empty_cta_url != blank -%}
      <a class="mc-search-concierge__cta" href="{{ section.settings.empty_cta_url }}">
        {{ section.settings.empty_cta_text }}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} Grille (rendue côté JS depuis localStorage) {%- endcomment -%}
  <div
    class="template-favoris__grid-wrap page-width"
    data-mc-favoris-grid-wrap
    hidden
  >
    <ul
      class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      data-mc-favoris-grid
    ></ul>
  </div>
</div>

{% schema %}
{
  "name": "Page Favoris",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow (suprà-titre)",
      "default": "MA SÉLECTION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre H1",
      "default": "Vos favoris"
    },
    {
      "type": "header",
      "content": "État vide"
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Message état vide",
      "default": "Aucune pièce ajoutée pour le moment. Parcourez la collection et ajoutez vos favoris en cliquant sur le coeur."
    },
    {
      "type": "text",
      "id": "empty_cta_text",
      "label": "CTA état vide — texte",
      "default": "DÉCOUVRIR LA COLLECTION"
    },
    {
      "type": "url",
      "id": "empty_cta_url",
      "label": "CTA état vide — lien"
    },
    {
      "type": "header",
      "content": "Grille produits"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Colonnes desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Espacements de la page"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top section (au-dessus du titre)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom section (sous la grille)",
      "default": 32
    },
    {
      "type": "range",
      "id": "header_padding_top",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Header — padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "header_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Header — padding bottom (sous le compteur)",
      "default": 32
    },
    {
      "type": "header",
      "content": "Bande Votre Espace"
    },
    {
      "type": "color",
      "id": "bar_bg",
      "label": "Couleur de fond",
      "default": "#E8E4DD"
    },
    {
      "type": "range",
      "id": "bar_padding_y",
      "label": "Padding vertical (haut/bas)",
      "min": 8,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Espace au-dessus de la bande",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Espace en-dessous de la bande",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "bullet_color",
      "label": "Couleur des bullets séparateurs",
      "default": "#B8AC9C"
    },
    {
      "type": "text",
      "id": "eyebrow_bar_text",
      "label": "Bande — eyebrow",
      "default": "VOTRE ESPACE"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Bande — taille eyebrow",
      "min": 8,
      "max": 16,
      "step": 0.5,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_ls",
      "label": "Bande — letter-spacing eyebrow",
      "min": 0,
      "max": 0.4,
      "step": 0.1,
      "unit": "em",
      "default": 0.2
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Bande — couleur eyebrow",
      "default": "#6B645C"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Bande — texte central",
      "default": "Connectez-vous pour retrouver votre sélection à tout moment."
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Bande — taille texte",
      "min": 10,
      "max": 18,
      "step": 0.5,
      "unit": "px",
      "default": 13
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Bande — couleur texte",
      "default": "#1A1814"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Bande — libellé CTA",
      "default": "SE CONNECTER"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "Bande — lien CTA",
      "default": "/account/login"
    },
    {
      "type": "range",
      "id": "cta_size",
      "label": "Bande — taille CTA",
      "min": 8,
      "max": 16,
      "step": 0.5,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "cta_ls",
      "label": "Bande — letter-spacing CTA",
      "min": 0,
      "max": 0.4,
      "step": 0.1,
      "unit": "em",
      "default": 0.2
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Bande — couleur CTA",
      "default": "#1A1814"
    }
  ],
  "presets": [
    {
      "name": "Page Favoris"
    }
  ],
  "enabled_on": {
    "templates": ["page"]
  }
}
{% endschema %}
