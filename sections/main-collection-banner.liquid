{% comment %}
  Phase 16.9 — En-tête de collection éditorial Maison Coeur
  Structure : fil d'Ariane (Cormorant Italic petit) + titre (masqué par défaut)
              + intro éditoriale.

  Intro éditoriale priorité :
  1. collection.metafields.maison_coeur.intro_editorial (multi_line_text_field)
  2. settings.intro_default_text (Customizer)
  3. collection.description (fallback Dawn)
{% endcomment %}

{%- liquid
  assign show_collection_title = section.settings.show_collection_title
  assign show_breadcrumb = section.settings.show_breadcrumb
  assign show_eyebrow = section.settings.show_eyebrow
  assign show_count = section.settings.show_product_count_in_eyebrow
  assign eyebrow_text = section.settings.eyebrow_default_text | default: 'COLLECTION'
  assign title_alignment = section.settings.title_alignment | default: 'center'
  assign intro_alignment = section.settings.intro_alignment | default: 'center'
  assign title_style = section.settings.title_style | default: 'italic'
  assign intro_style = section.settings.intro_text_style | default: 'italic'
  assign breadcrumb_font = section.settings.breadcrumb_font_family | default: 'cormorant_italic'
  assign breadcrumb_align = section.settings.breadcrumb_alignment | default: 'left'
  assign breadcrumb_all_label = section.settings.breadcrumb_all_products_label | default: 'Produits'
  assign breadcrumb_home_label = 'general.breadcrumb.home' | t
  if collection.handle == 'all'
    assign breadcrumb_collection_label = breadcrumb_all_label
  else
    assign breadcrumb_collection_label = collection.title
  endif

  assign intro_text = ''
  if collection.metafields.maison_coeur.intro_editorial != blank
    assign intro_text = collection.metafields.maison_coeur.intro_editorial
  elsif section.settings.intro_default_text != blank
    assign intro_text = section.settings.intro_default_text
  elsif section.settings.show_collection_description and collection.description != blank
    assign intro_text = collection.description
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --mcch-pt: {{ section.settings.nav_to_content_gap_desktop | default: 24 }}px;
    --mcch-pt-mobile: {{ section.settings.nav_to_content_gap_mobile | default: 16 }}px;
    --mcch-pb: {{ section.settings.header_padding_bottom | default: 0 }}px;
    --mcch-title-size: {{ section.settings.title_size_desktop | default: 60 }}px;
    --mcch-title-size-mobile: {{ section.settings.title_size_mobile | default: 40 }}px;
    --mcch-intro-size: {{ section.settings.intro_text_size_desktop | default: 18 }}px;
    --mcch-title-align: {{ title_alignment }};
    --mcch-intro-align: {{ intro_alignment }};
    --mcch-bc-size: {{ section.settings.breadcrumb_size_desktop | default: 14 }}px;
    --mcch-bc-align: {{ breadcrumb_align }};
    --mcch-bc-color: {{ section.settings.breadcrumb_color | default: '#8C6D3F' }};
  }
  #shopify-section-{{ section.id }} .mc-collection-header {
    padding-top: var(--mcch-pt);
    padding-bottom: var(--mcch-pb);
  }
{%- endstyle -%}

<header class="mc-collection-header color-{{ section.settings.color_scheme }}">
  <div class="mc-collection-header__inner page-width">

    {%- if show_breadcrumb -%}
      <nav class="mc-collection-header__breadcrumb mc-collection-header__breadcrumb--{{ breadcrumb_font }}" aria-label="Fil d'Ariane">
        <a href="{{ routes.root_url }}">{{ breadcrumb_home_label }}</a>
        <span aria-hidden="true"> — </span>
        <span>{{ breadcrumb_collection_label | escape }}</span>
      </nav>
    {%- endif -%}

    {%- if show_eyebrow -%}
      <p class="mc-collection-header__eyebrow">
        {{- eyebrow_text -}}
        {%- if show_count -%}
          <span aria-hidden="true"> — </span>{{ collection.products_count }} {%- if collection.products_count == 1 -%}pièce{%- else -%}pièces{%- endif -%}
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- if show_collection_title -%}
      <h1 class="mc-collection-header__title mc-collection-header__title--{{ title_style }}">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- collection.title | escape -}}
      </h1>
    {%- else -%}
      {%- comment -%} Titre conservé en visually-hidden pour SEO/a11y {%- endcomment -%}
      <h1 class="visually-hidden">{{ collection.title | escape }}</h1>
    {%- endif -%}

    {%- if intro_text != blank -%}
      <div class="mc-collection-header__intro mc-collection-header__intro--{{ intro_style }} rte">
        {{ intro_text }}
      </div>
    {%- endif -%}

  </div>
</header>

{%- style -%}
  /* Continuité visuelle du fond crème — neutralise le bg de la color-scheme appliquée par Dawn */
  #shopify-section-{{ section.id }} .mc-collection-header,
  #shopify-section-{{ section.id }} .mc-collection-header.color-scheme-1,
  #shopify-section-{{ section.id }} .mc-collection-header[class*='color-'] {
    background: transparent;
    background-color: transparent;
  }
  .mc-collection-header__inner {
    text-align: var(--mcch-title-align, center);
  }
  /* Fil d'Ariane — Cormorant Italic petit aligné gauche par défaut */
  .mc-collection-header__breadcrumb {
    font-size: var(--mcch-bc-size, 14px);
    color: var(--mcch-bc-color, #8C6D3F);
    text-align: var(--mcch-bc-align, left);
    margin: 0 0 12px;
  }
  .mc-collection-header__breadcrumb--cormorant_italic {
    font-family: 'Cormorant Garamond', Cormorant, Georgia, serif;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0;
    text-transform: none;
  }
  .mc-collection-header__breadcrumb--jost_light_caps {
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-style: normal;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: calc(var(--mcch-bc-size, 14px) - 2px);
  }
  .mc-collection-header__breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color 180ms ease;
  }
  .mc-collection-header__breadcrumb a:hover {
    color: #1A1814;
  }
  .mc-collection-header__eyebrow {
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1A1814;
    margin: 0 0 18px;
  }
  .mc-collection-header__title {
    font-family: 'Cormorant Garamond', Cormorant, Georgia, serif;
    font-weight: 400;
    font-size: var(--mcch-title-size, 60px);
    line-height: 1.1;
    letter-spacing: 0;
    color: #1A1814;
    margin: 0;
  }
  .mc-collection-header__title--italic { font-style: italic; }
  .mc-collection-header__title--regular { font-style: normal; }
  .mc-collection-header__intro {
    font-family: 'Cormorant Garamond', Cormorant, Georgia, serif;
    font-weight: 400;
    font-size: var(--mcch-intro-size, 18px);
    line-height: 1.5;
    color: #1A1814;
    margin: 18px auto 0;
    max-width: 60ch;
    text-align: var(--mcch-intro-align, center);
  }
  .mc-collection-header__intro--italic { font-style: italic; }
  .mc-collection-header__intro--regular { font-style: normal; }
  .mc-collection-header__intro > * { margin: 0; }
  .mc-collection-header__intro > * + * { margin-top: 8px; }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-header {
      padding-top: var(--mcch-pt-mobile, 16px);
    }
    .mc-collection-header__title {
      font-size: var(--mcch-title-size-mobile, 40px);
    }
    .mc-collection-header__breadcrumb {
      font-size: calc(var(--mcch-bc-size, 14px) - 2px);
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "En-tête collection",
  "class": "section section--mc-collection-header",
  "settings": [
    { "type": "header", "content": "Affichage titre + fil d'Ariane" },
    { "type": "checkbox", "id": "show_collection_title", "default": false, "label": "Afficher le titre de la catégorie" },
    { "type": "checkbox", "id": "show_breadcrumb", "default": false, "label": "Afficher le fil d'Ariane" },
    { "type": "text", "id": "breadcrumb_all_products_label", "default": "Produits", "label": "Libellé pour la page tous les produits" },
    { "type": "checkbox", "id": "show_eyebrow", "default": false, "label": "Afficher l'eyebrow au-dessus du titre" },
    { "type": "text", "id": "eyebrow_default_text", "default": "COLLECTION", "label": "Texte eyebrow" },
    { "type": "checkbox", "id": "show_product_count_in_eyebrow", "default": true, "label": "Afficher le nombre de pièces dans l'eyebrow" },

    { "type": "header", "content": "Fil d'Ariane — style" },
    {
      "type": "select",
      "id": "breadcrumb_font_family",
      "label": "Police du fil d'Ariane",
      "default": "cormorant_italic",
      "options": [
        { "value": "cormorant_italic", "label": "Cormorant Italic" },
        { "value": "jost_light_caps", "label": "Jost Light Caps" }
      ]
    },
    { "type": "range", "id": "breadcrumb_size_desktop", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 14, "label": "Taille du fil d'Ariane desktop" },
    {
      "type": "select",
      "id": "breadcrumb_alignment",
      "label": "Alignement du fil d'Ariane",
      "default": "left",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ]
    },
    { "type": "color", "id": "breadcrumb_color", "default": "#8C6D3F", "label": "Couleur du fil d'Ariane" },

    { "type": "header", "content": "Titre" },
    { "type": "range", "id": "title_size_desktop", "min": 32, "max": 96, "step": 4, "unit": "px", "default": 60, "label": "Taille titre desktop" },
    { "type": "range", "id": "title_size_mobile", "min": 24, "max": 64, "step": 4, "unit": "px", "default": 40, "label": "Taille titre mobile" },
    {
      "type": "select",
      "id": "title_style",
      "label": "Style titre",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "italic", "label": "Italique" }
      ],
      "default": "italic"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Alignement titre",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "center"
    },

    { "type": "header", "content": "Intro éditoriale" },
    {
      "type": "textarea",
      "id": "intro_default_text",
      "label": "Texte intro par défaut",
      "info": "Surchargé par collection.metafields.maison_coeur.intro_editorial si présent."
    },
    { "type": "range", "id": "intro_text_size_desktop", "min": 14, "max": 28, "step": 2, "unit": "px", "default": 18, "label": "Taille texte intro" },
    {
      "type": "select",
      "id": "intro_text_style",
      "label": "Style intro",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "italic", "label": "Italique" }
      ],
      "default": "italic"
    },
    {
      "type": "select",
      "id": "intro_alignment",
      "label": "Alignement intro",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Fallback : afficher description Shopify si pas d'intro"
    },

    { "type": "header", "content": "Espacements" },
    { "type": "range", "id": "nav_to_content_gap_desktop", "min": 8, "max": 80, "step": 4, "unit": "px", "default": 24, "label": "Espace menu nav → contenu (desktop)" },
    { "type": "range", "id": "nav_to_content_gap_mobile", "min": 4, "max": 48, "step": 4, "unit": "px", "default": 16, "label": "Espace menu nav → contenu (mobile)" },
    { "type": "range", "id": "header_padding_bottom", "min": 0, "max": 96, "step": 8, "unit": "px", "default": 0, "label": "Padding bas en-tête" },

    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Couleur de fond",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
