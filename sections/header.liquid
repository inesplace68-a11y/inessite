{% comment %}
  Phase 16.12 — Cause racine identifiée de l'espace vertical résiduel
  entre la fin du menu nav et le contenu de la page collection :

    L'empilement de paddings/margins distincts (header padding-bottom +
    banner padding-top/bottom + grid padding-top + toolbar margin-top +
    toolbar padding-top) totalisait ~60px alors que la cible est ~24px.

    Solution : deux points de contrôle uniques exposés en customizer
    (un par côté), tous les autres contributeurs collapsent à 0 :
      - header_padding_bottom_desktop / _mobile  (cette section)
      - collection_padding_top_desktop / _mobile (section product-grid)
{% endcomment %}
{%- style -%}
  #shopify-section-{{ section.id }} .mc-hd-monogram-img {
    height: {{ section.settings.monogram_height }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-wordmark-img {
    height: {{ section.settings.wordmark_height }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-wordmark {
    margin-top: {{ section.settings.wordmark_offset_y }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-main {
    padding-top: {{ section.settings.bandeau_padding_top }}px;
    padding-right: 48px;
    padding-bottom: {{ section.settings.bandeau_padding_bottom }}px;
    padding-left: 48px;
    border-top: {{ section.settings.topbar_height }}px solid {{ section.settings.topbar_color }};
  }
  #shopify-section-{{ section.id }} .mc-hd-icons {
    gap: {{ section.settings.icons_gap }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-left {
    gap: {{ section.settings.mono_globe_gap }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-left-stack {
    height: {{ section.settings.monogram_height }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-globe {
    transform: translateX({{ section.settings.globe_offset_x }}px);
  }
  #shopify-section-{{ section.id }} .mc-hd-pro {
    font-size: {{ section.settings.pro_font_size }}px;
    letter-spacing: {{ section.settings.pro_letter_spacing }}em;
    color: {{ section.settings.pro_color }};
    transform: translateX({{ section.settings.pro_offset_x }}px);
  }
  #shopify-section-{{ section.id }} .mc-hd-nav__link {
    font-size: {{ section.settings.nav_font_size }}px;
    letter-spacing: {{ section.settings.nav_letter_spacing }}em;
  }
  #shopify-section-{{ section.id }} .mc-hd-nav__link.is-active {
    color: {{ section.settings.active_nav_color | default: '#8C6D3F' }};
    {%- if section.settings.active_nav_underline -%}
    text-decoration: underline;
    text-underline-offset: {{ section.settings.active_nav_underline_offset | default: 6 }}px;
    text-decoration-thickness: {{ section.settings.active_nav_underline_thickness | default: 1 }}px;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .mc-hd-nav {
    padding-top: {{ section.settings.nav_top_spacing }}px;
    padding-bottom: {{ section.settings.header_padding_bottom_desktop | default: 16 }}px;
    {%- if section.settings.nav_separator_visible %}
    border-top: {{ section.settings.nav_separator_thickness }}px solid {{ section.settings.nav_separator_color }};
    {%- endif %}
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-hd-nav {
      padding-bottom: {{ section.settings.header_padding_bottom_mobile | default: 12 }}px;
    }
    /* Tailles mobile pilotées par customizer — uniquement mobile */
    #shopify-section-{{ section.id }} .mc-hd-burger svg {
      width: {{ section.settings.mobile_burger_size | default: 25 }}px;
      height: {{ section.settings.mobile_burger_size | default: 25 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-wordmark-img {
      max-height: {{ section.settings.mobile_logo_size | default: 17 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-icons {
      gap: {{ section.settings.mobile_icons_gap | default: 15 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-icon svg,
    #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger] svg {
      width: {{ section.settings.mobile_icon_size | default: 21 }}px;
      height: {{ section.settings.mobile_icon_size | default: 21 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-left,
    #shopify-section-{{ section.id }} .mc-hd-icons {
      width: {{ section.settings.mobile_side_width | default: 88 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-mobile-search {
      margin-top: {{ section.settings.mobile_search_margin | default: 16 }}px;
      margin-right: {{ section.settings.mobile_search_margin | default: 16 }}px;
      margin-bottom: 0;
      margin-left: {{ section.settings.mobile_search_margin | default: 16 }}px;
    }
    #shopify-section-{{ section.id }} .mc-hd-mobile-search__btn {
      padding-top: {{ section.settings.mobile_search_height | default: 14 }}px;
      padding-bottom: {{ section.settings.mobile_search_height | default: 14 }}px;
    }
  }
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger] {
    color: {{ section.settings.cart_icon_color }};
  }
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger]:hover,
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger]:focus-visible {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger] svg {
    width: {{ section.settings.cart_icon_size }}px;
    height: {{ section.settings.cart_icon_size }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-cart-badge {
    --mc-cart-badge-bg: {{ section.settings.badge_bg_color }};
    --mc-cart-badge-text: {{ section.settings.badge_text_color }};
    --mc-cart-badge-size: {{ section.settings.badge_size }}px;
    --mc-cart-badge-fs: {{ section.settings.badge_font_size }}px;
    --mc-cart-badge-top: {{ section.settings.badge_offset_top }}px;
    --mc-cart-badge-right: {{ section.settings.badge_offset_right }}px;
  }
  #shopify-section-{{ section.id }} .mc-search-drawer {
    --mc-search-anim: {{ section.settings.search_anim_duration }}ms;
    {%- assign mc_overlay_alpha = section.settings.search_overlay_opacity | divided_by: 100.0 -%}
    --mc-search-overlay: {{ section.settings.search_overlay_color | color_modify: 'alpha', mc_overlay_alpha }};
  }
  #shopify-section-{{ section.id }} .mc-search-panel {
    background: {{ section.settings.search_drawer_bg }};
    color: {{ section.settings.search_drawer_text }};
  }
{%- endstyle -%}

<div class="mc-hd-wrap">

  <!-- ZONE 2 : Bandeau principal -->
  <div class="mc-hd-main">
    <div class="mc-hd-left">
      <button type="button" class="mc-hd-burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mc-hd-drawer" data-mc-drawer-trigger>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" aria-hidden="true" focusable="false">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
      <a href="/" class="mc-hd-logo" aria-label="Maison Coeur — Accueil">
        {% if section.settings.monogram_image != blank %}
          <img src="{{ section.settings.monogram_image | image_url: width: 400 }}" alt="Maison Coeur" class="mc-hd-monogram-img" loading="eager">
        {% else %}
          <img src="{{ 'mc-monogram.png' | asset_url }}" alt="Maison Coeur" class="mc-hd-monogram-img" width="32" height="44" loading="eager">
        {% endif %}
      </a>
      <div class="mc-hd-left-stack">
        <button type="button" class="mc-hd-globe" aria-label="Pays / Devise" data-mc-globe-trigger>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <path d="M3 12h18"/>
            <path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18z"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="mc-hd-wordmark">
      <a href="/">
        {% if section.settings.wordmark_image != blank %}
          <img src="{{ section.settings.wordmark_image | image_url: width: 2400 }}" alt="MAISON COEUR" class="mc-hd-wordmark-img" loading="eager">
        {% else %}
          <img src="{{ 'mc-wordmark.png' | asset_url }}" alt="MAISON COEUR" class="mc-hd-wordmark-img" loading="eager">
        {% endif %}
      </a>
    </div>
    <div class="mc-hd-icons">
      <button type="button" class="mc-hd-icon mc-hd-icon--search" aria-label="Rechercher" data-mc-search-trigger>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </button>
      <a href="/account" class="mc-hd-icon" aria-label="Compte">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4 4-7 8-7s8 3 8 7"/>
        </svg>
      </a>
      <a href="/pages/favoris" class="mc-hd-icon" aria-label="Favoris" data-mc-header-heart>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20.5s-7.5-4.8-9.5-10C1 6 5.5 2.5 9 4.5c1.3.7 2.4 1.8 3 3 .6-1.2 1.7-2.3 3-3 3.5-2 8 1.5 6.5 6-2 5.2-9.5 10-9.5 10z"/>
        </svg>
      </a>
      <button
        type="button"
        class="mc-hd-icon"
        data-mc-cart-trigger
        aria-label="Panier"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M5.5 8h13l-1.2 12.5H6.7L5.5 8z"/>
          <path d="M9 8V6.5a3 3 0 0 1 6 0V8"/>
        </svg>
        {%- if section.settings.badge_visible -%}
          <span
            class="mc-hd-cart-badge"
            data-mc-cart-count
            data-empty="{% if cart.item_count == 0 %}true{% else %}false{% endif %}"
            aria-hidden="true"
          >{%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}</span>
        {%- endif -%}
        <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
      </button>
    </div>
  </div>

  <!-- Barre de recherche mobile : déclenche l'overlay existant -->
  <div class="mc-hd-mobile-search" aria-hidden="false">
    <button type="button" class="mc-hd-mobile-search__btn" data-mc-search-trigger aria-label="Ouvrir la recherche">
      <span class="mc-hd-mobile-search__icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </span>
      <span class="mc-hd-mobile-search__placeholder">Rechercher une pièce, une matière, une époque…</span>
    </button>
  </div>

  <!-- ZONE 3 : Menu navigation -->
  <nav class="mc-hd-nav" aria-label="Navigation principale">
    <ul class="mc-hd-nav__list">
      {%- assign current_path = request.path -%}
      {%- for link in linklists['main-menu'].links -%}
        {%- assign link_active = false -%}
        {%- if link.url == current_path -%}
          {%- assign link_active = true -%}
        {%- elsif link.object.url == current_path -%}
          {%- assign link_active = true -%}
        {%- elsif link.type == 'collection_link' and link.object.url == current_path -%}
          {%- assign link_active = true -%}
        {%- endif -%}
        <li class="mc-hd-nav__item">
          <a
            href="{{ link.url }}"
            class="mc-hd-nav__link{% if link_active %} is-active{% endif %}"
            {% if link_active %}aria-current="page"{% endif %}
          >{{ link.title | upcase }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</div>

<div class="mc-hd-drawer" id="mc-hd-drawer" hidden role="dialog" aria-modal="true" aria-label="Menu principal">
  <div class="mc-hd-drawer__overlay" data-mc-drawer-close></div>
  <aside class="mc-hd-drawer__panel" tabindex="-1">
    <div class="mc-hd-drawer__head">
      <span class="mc-hd-drawer__eyebrow">Menu</span>
      <button type="button" class="mc-hd-drawer__close" aria-label="Fermer le menu" data-mc-drawer-close>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true" focusable="false">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="mc-hd-drawer__nav" aria-label="Navigation mobile">
      <ul class="mc-hd-drawer__list">
        {%- for link in linklists['main-menu'].links -%}
          <li class="mc-hd-drawer__item">
            <a href="{{ link.url }}" class="mc-hd-drawer__link" data-mc-drawer-close>{{ link.title | upcase }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  </aside>
</div>

<div class="mc-globe-modal" id="mc-globe-modal" hidden role="dialog" aria-modal="true" aria-labelledby="mc-globe-title">
  <div class="mc-globe-overlay" data-mc-globe-close></div>
  <div class="mc-globe-content">
    <button type="button" class="mc-globe-close" aria-label="Fermer" data-mc-globe-close>
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.4">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>

    <h2 id="mc-globe-title" class="mc-globe-title">Pays &amp; Langue</h2>

    {% form 'localization', class: 'mc-globe-form' %}
      <div class="mc-globe-field">
        <label for="mc-globe-country">Pays / Devise</label>
        <select id="mc-globe-country" name="country_code">
          {% for country in localization.available_countries %}
            <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
              {{ country.name }} — {{ country.currency.iso_code }} {{ country.currency.symbol }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div class="mc-globe-field">
        <label for="mc-globe-language">Langue</label>
        <select id="mc-globe-language" name="locale_code">
          {% for language in localization.available_languages %}
            <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>
              {{ language.endonym_name }}
            </option>
          {% endfor %}
        </select>
      </div>

      <button type="submit" class="mc-globe-confirm">Confirmer</button>
    {% endform %}
  </div>
</div>

<div class="mc-search-drawer"
     id="mc-search-drawer"
     hidden
     role="dialog"
     aria-modal="true"
     aria-label="Recherche"
     data-predictive-search-url="{{ routes.predictive_search_url }}">
  <div class="mc-search-overlay" data-mc-search-close></div>
  <div class="mc-search-panel">
    <button type="button" class="mc-search-close" aria-label="Fermer" data-mc-search-close>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>

    <form action="{{ routes.search_url }}" method="get" role="search" class="mc-search-form">
      <span class="mc-search-form__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </span>
      <label for="mc-search-input" class="visually-hidden">Rechercher</label>
      <input
        id="mc-search-input"
        type="search"
        name="q"
        class="mc-search-form__input"
        placeholder="{{ section.settings.search_placeholder }}"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      >
      <button
        type="button"
        class="mc-search-form__clear"
        aria-label="Effacer la recherche"
        data-mc-search-clear
        hidden
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
      <input type="hidden" name="options[prefix]" value="last">
    </form>

    <div class="mc-search-results"
         data-mc-search-results
         data-show-concierge="{{ section.settings.search_show_concierge }}"
         hidden>
      <section class="mc-search-block mc-search-block--queries" data-mc-search-block="queries" hidden>
        <span class="mc-search-eyebrow">SUGGESTIONS</span>
        <ul class="mc-search-suggestions" data-mc-search-queries></ul>
      </section>

      <section class="mc-search-block mc-search-block--products" data-mc-search-block="products" hidden>
        <span class="mc-search-eyebrow">RÉSULTATS</span>
        <ul class="mc-search-products" data-mc-search-products></ul>
      </section>

      {%- if section.settings.search_show_concierge -%}
        <section class="mc-search-block mc-search-block--concierge" data-mc-search-block="concierge" hidden>
          {%- if settings.search_concierge_eyebrow != blank -%}
            <span class="mc-search-eyebrow">{{ settings.search_concierge_eyebrow }}</span>
          {%- endif -%}
          {%- if settings.search_concierge_text != blank -%}
            <p class="mc-search-concierge__text">{{ settings.search_concierge_text | newline_to_br }}</p>
          {%- endif -%}
          {%- if settings.search_concierge_cta_text != blank and settings.search_concierge_cta_url != blank -%}
            <a class="mc-search-concierge__cta" href="{{ settings.search_concierge_cta_url }}">
              {{ settings.search_concierge_cta_text }}
            </a>
          {%- endif -%}
        </section>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header Maison Coeur",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "monogram_image",
      "label": "Logo monogramme MC",
      "info": "PNG transparent, format carré 400×400 px minimum, noir sur fond transparent. Si vide, le PNG par défaut s'affiche."
    },
    {
      "type": "image_picker",
      "id": "wordmark_image",
      "label": "Logo wordmark MAISON COEUR",
      "info": "PNG transparent, format horizontal 2400×600 px minimum (ratio ~4:1), noir sur fond transparent. Si vide, le PNG par défaut s'affiche."
    },
    {
      "type": "range",
      "id": "monogram_height",
      "label": "Hauteur du monogramme MC",
      "info": "Logo carré à gauche du bandeau. Cible : hauteur du M de « MAISON COEUR » central.",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "wordmark_height",
      "label": "Hauteur du wordmark MAISON COEUR",
      "info": "Logo texte centré dans le bandeau",
      "min": 12,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "wordmark_offset_y",
      "label": "Décalage vertical wordmark central (px)",
      "info": "Remonte (négatif) ou descend (positif) le wordmark central MAISON COEUR.",
      "min": -16,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": -8
    },
    {
      "type": "range",
      "id": "mono_globe_gap",
      "label": "Espacement monogramme ↔ stack (globe / PRO)",
      "info": "Distance entre le monogramme MC et la colonne globe + PRO (bloc gauche du header)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "globe_offset_x",
      "label": "Décalage horizontal globe (px)",
      "info": "Recalage micro de l'icône globe pour la centrer visuellement sur la lettre R du mot « PRO ».",
      "min": -16,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": -4
    },
    {
      "type": "header",
      "content": "Lien PRO (cluster gauche)"
    },
    {
      "type": "text",
      "id": "pro_text",
      "label": "Texte du lien",
      "default": "PRO"
    },
    {
      "type": "text",
      "id": "pro_url",
      "label": "URL du lien",
      "info": "Page programme professionnel. Ex : /pages/programme-pro",
      "default": "/pages/programme-pro"
    },
    {
      "type": "range",
      "id": "pro_font_size",
      "label": "Taille du texte PRO",
      "min": 9,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "pro_letter_spacing",
      "label": "Espacement des lettres (PRO)",
      "min": 0,
      "max": 0.4,
      "step": 0.1,
      "unit": "em",
      "default": 0.2
    },
    {
      "type": "color",
      "id": "pro_color",
      "label": "Couleur du lien PRO",
      "default": "#1A1814"
    },
    {
      "type": "range",
      "id": "pro_offset_x",
      "label": "Décalage horizontal texte PRO (px)",
      "info": "Recalage micro du texte « PRO » sous le globe (négatif = vers la gauche).",
      "min": -12,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": -4
    },
    {
