{%- style -%}
  #shopify-section-{{ section.id }} .mc-hd-monogram-img {
    height: {{ section.settings.monogram_height }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-wordmark-img {
    height: {{ section.settings.wordmark_height }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-main {
    padding-top: {{ section.settings.bandeau_padding_top }}px;
    padding-right: 48px;
    padding-bottom: {{ section.settings.bandeau_padding_bottom }}px;
    padding-left: 48px;
    border-top: {{ section.settings.topbar_height }}px solid {{ section.settings.topbar_color }};
  }
  #shopify-section-{{ section.id }} .mc-hd-icons {
    gap: {{ section.settings.icons_gap }}px;
  }
  {%- if section.settings.nav_separator_visible -%}
  #shopify-section-{{ section.id }} .mc-hd-nav {
    border-top: {{ section.settings.nav_separator_thickness }}px solid {{ section.settings.nav_separator_color }};
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger] {
    color: {{ section.settings.cart_icon_color }};
  }
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger]:hover,
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger]:focus-visible {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-hd-icon[data-mc-cart-trigger] svg {
    width: {{ section.settings.cart_icon_size }}px;
    height: {{ section.settings.cart_icon_size }}px;
  }
  #shopify-section-{{ section.id }} .mc-hd-cart-badge {
    --mc-cart-badge-bg: {{ section.settings.badge_bg_color }};
    --mc-cart-badge-text: {{ section.settings.badge_text_color }};
    --mc-cart-badge-size: {{ section.settings.badge_size }}px;
    --mc-cart-badge-fs: {{ section.settings.badge_font_size }}px;
    --mc-cart-badge-top: {{ section.settings.badge_offset_top }}px;
    --mc-cart-badge-right: {{ section.settings.badge_offset_right }}px;
  }
  #shopify-section-{{ section.id }} .mc-search-drawer {
    --mc-search-anim: {{ section.settings.search_anim_duration }}ms;
    {%- assign mc_overlay_alpha = section.settings.search_overlay_opacity | divided_by: 100.0 -%}
    --mc-search-overlay: {{ section.settings.search_overlay_color | color_modify: 'alpha', mc_overlay_alpha }};
  }
  #shopify-section-{{ section.id }} .mc-search-panel {
    background: {{ section.settings.search_drawer_bg }};
    color: {{ section.settings.search_drawer_text }};
  }
{%- endstyle -%}

<div class="mc-hd-wrap">

  <!-- ZONE 2 : Bandeau principal -->
  <div class="mc-hd-main">
    <a href="/" class="mc-hd-logo" aria-label="Maison Coeur — Accueil">
      {% if section.settings.monogram_image != blank %}
        <img src="{{ section.settings.monogram_image | image_url: width: 400 }}" alt="Maison Coeur" class="mc-hd-monogram-img" loading="eager">
      {% else %}
        <img src="{{ 'mc-monogram.png' | asset_url }}" alt="Maison Coeur" class="mc-hd-monogram-img" width="32" height="44" loading="eager">
      {% endif %}
    </a>
    <div class="mc-hd-wordmark">
      <a href="/">
        {% if section.settings.wordmark_image != blank %}
          <img src="{{ section.settings.wordmark_image | image_url: width: 2400 }}" alt="MAISON COEUR" class="mc-hd-wordmark-img" loading="eager">
        {% else %}
          <img src="{{ 'mc-wordmark.png' | asset_url }}" alt="MAISON COEUR" class="mc-hd-wordmark-img" loading="eager">
        {% endif %}
      </a>
    </div>
    <div class="mc-hd-icons">
      <button type="button" class="mc-hd-icon" aria-label="Pays / Devise" data-mc-globe-trigger>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <path d="M3 12h18"/>
          <path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18z"/>
        </svg>
      </button>
      <button type="button" class="mc-hd-icon" aria-label="Rechercher" data-mc-search-trigger>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </button>
      <a href="/account" class="mc-hd-icon" aria-label="Compte">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4 4-7 8-7s8 3 8 7"/>
        </svg>
      </a>
      <a href="/pages/favoris" class="mc-hd-icon" aria-label="Favoris">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20.5s-7.5-4.8-9.5-10C1 6 5.5 2.5 9 4.5c1.3.7 2.4 1.8 3 3 .6-1.2 1.7-2.3 3-3 3.5-2 8 1.5 6.5 6-2 5.2-9.5 10-9.5 10z"/>
        </svg>
      </a>
      <button
        type="button"
        class="mc-hd-icon"
        data-mc-cart-trigger
        aria-label="Panier"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M5.5 8h13l-1.2 12.5H6.7L5.5 8z"/>
          <path d="M9 8V6.5a3 3 0 0 1 6 0V8"/>
        </svg>
        {%- if section.settings.badge_visible -%}
          <span
            class="mc-hd-cart-badge"
            data-mc-cart-count
            data-empty="{% if cart.item_count == 0 %}true{% else %}false{% endif %}"
            aria-hidden="true"
          >{%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}</span>
        {%- endif -%}
        <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
      </button>
    </div>
  </div>

  <!-- ZONE 3 : Menu navigation -->
  <nav class="mc-hd-nav" aria-label="Navigation principale">
    <ul class="mc-hd-nav__list">
      {%- for link in linklists['main-menu'].links -%}
        <li class="mc-hd-nav__item">
          <a href="{{ link.url }}" class="mc-hd-nav__link">{{ link.title | upcase }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</div>

<div class="mc-globe-modal" id="mc-globe-modal" hidden role="dialog" aria-modal="true" aria-labelledby="mc-globe-title">
  <div class="mc-globe-overlay" data-mc-globe-close></div>
  <div class="mc-globe-content">
    <button type="button" class="mc-globe-close" aria-label="Fermer" data-mc-globe-close>
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.4">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>

    <h2 id="mc-globe-title" class="mc-globe-title">Pays &amp; Langue</h2>

    {% form 'localization', class: 'mc-globe-form' %}
      <div class="mc-globe-field">
        <label for="mc-globe-country">Pays / Devise</label>
        <select id="mc-globe-country" name="country_code">
          {% for country in localization.available_countries %}
            <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
              {{ country.name }} — {{ country.currency.iso_code }} {{ country.currency.symbol }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div class="mc-globe-field">
        <label for="mc-globe-language">Langue</label>
        <select id="mc-globe-language" name="locale_code">
          {% for language in localization.available_languages %}
            <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>
              {{ language.endonym_name }}
            </option>
          {% endfor %}
        </select>
      </div>

      <button type="submit" class="mc-globe-confirm">Confirmer</button>
    {% endform %}
  </div>
</div>

<div class="mc-search-drawer"
     id="mc-search-drawer"
     hidden
     role="dialog"
     aria-modal="true"
     aria-label="Recherche"
     data-predictive-search-url="{{ routes.predictive_search_url }}">
  <div class="mc-search-overlay" data-mc-search-close></div>
  <div class="mc-search-panel">
    <button type="button" class="mc-search-close" aria-label="Fermer" data-mc-search-close>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>

    <form action="{{ routes.search_url }}" method="get" role="search" class="mc-search-form">
      <span class="mc-search-form__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </span>
      <label for="mc-search-input" class="visually-hidden">Rechercher</label>
      <input
        id="mc-search-input"
        type="search"
        name="q"
        class="mc-search-form__input"
        placeholder="{{ section.settings.search_placeholder }}"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      >
      <button
        type="button"
        class="mc-search-form__clear"
        aria-label="Effacer la recherche"
        data-mc-search-clear
        hidden
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
      <input type="hidden" name="options[prefix]" value="last">
    </form>

    <div class="mc-search-results"
         data-mc-search-results
         data-show-concierge="{{ section.settings.search_show_concierge }}"
         hidden>
      <section class="mc-search-block mc-search-block--queries" data-mc-search-block="queries" hidden>
        <span class="mc-search-eyebrow">SUGGESTIONS</span>
        <ul class="mc-search-suggestions" data-mc-search-queries></ul>
      </section>

      <section class="mc-search-block mc-search-block--products" data-mc-search-block="products" hidden>
        <span class="mc-search-eyebrow">RÉSULTATS</span>
        <ul class="mc-search-products" data-mc-search-products></ul>
      </section>

      {%- if section.settings.search_show_concierge -%}
        <section class="mc-search-block mc-search-block--concierge" data-mc-search-block="concierge" hidden>
          {%- if section.settings.search_concierge_eyebrow != blank -%}
            <span class="mc-search-eyebrow">{{ section.settings.search_concierge_eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.search_concierge_text != blank -%}
            <p class="mc-search-concierge__text">{{ section.settings.search_concierge_text }}</p>
          {%- endif -%}
          {%- if section.settings.search_concierge_cta_text != blank and section.settings.search_concierge_cta_url != blank -%}
            <a class="mc-search-concierge__cta" href="{{ section.settings.search_concierge_cta_url }}">
              {{ section.settings.search_concierge_cta_text }}
            </a>
          {%- endif -%}
        </section>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header Maison Coeur",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "monogram_image",
      "label": "Logo monogramme MC",
      "info": "PNG transparent, format carré 400×400 px minimum, noir sur fond transparent. Si vide, le PNG par défaut s'affiche."
    },
    {
      "type": "image_picker",
      "id": "wordmark_image",
      "label": "Logo wordmark MAISON COEUR",
      "info": "PNG transparent, format horizontal 2400×600 px minimum (ratio ~4:1), noir sur fond transparent. Si vide, le PNG par défaut s'affiche."
    },
    {
      "type": "range",
      "id": "monogram_height",
      "label": "Hauteur du monogramme MC",
      "info": "Logo carré à gauche du bandeau",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "wordmark_height",
      "label": "Hauteur du wordmark MAISON COEUR",
      "info": "Logo texte centré dans le bandeau",
      "min": 12,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Bandeau crème"
    },
    {
      "type": "range",
      "id": "bandeau_padding_top",
      "label": "Marge verticale haut",
      "info": "Espace au-dessus du bandeau crème",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "bandeau_padding_bottom",
      "label": "Marge verticale bas",
      "info": "Espace en dessous du bandeau crème",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "topbar_height",
      "label": "Hauteur de la barre noire (topbar)",
      "info": "Mettre 0 pour masquer complètement",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "topbar_color",
      "label": "Couleur de la barre noire",
      "default": "#1A1814"
    },
    {
      "type": "header",
      "content": "Icônes — espacement"
    },
    {
      "type": "range",
      "id": "icons_gap",
      "label": "Espacement entre icônes",
      "info": "Distance entre les icônes du bandeau (globe, recherche, compte, favoris, panier)",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Trait au-dessus du menu"
    },
    {
      "type": "checkbox",
      "id": "nav_separator_visible",
      "label": "Afficher le trait au-dessus du menu",
      "default": true
    },
    {
      "type": "color",
      "id": "nav_separator_color",
      "label": "Couleur du trait",
      "default": "#C4B8A4"
    },
    {
      "type": "range",
      "id": "nav_separator_thickness",
      "label": "Épaisseur du trait",
      "min": 0.5,
      "max": 2,
      "step": 0.5,
      "unit": "px",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Icône panier"
    },
    {
      "type": "range",
      "id": "cart_icon_size",
      "label": "Taille de l'icône panier",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "cart_icon_color",
      "label": "Couleur de l'icône panier",
      "default": "#1A1814"
    },
    {
      "type": "checkbox",
      "id": "badge_visible",
      "label": "Afficher le compteur (badge)",
      "default": true
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Couleur de fond du badge",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Couleur du texte du badge",
      "default": "#F7F5F1"
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "Taille du badge",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Taille du texte du badge",
      "min": 8,
      "max": 14,
      "step": 0.5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "badge_offset_top",
      "label": "Décalage vertical du badge",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": -4
    },
    {
      "type": "range",
      "id": "badge_offset_right",
      "label": "Décalage horizontal du badge",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": -4
    },
    {
      "type": "header",
      "content": "Drawer recherche"
    },
    {
      "type": "color",
      "id": "search_drawer_bg",
      "label": "Couleur de fond du drawer",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "search_drawer_text",
      "label": "Couleur du texte du drawer",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "search_overlay_color",
      "label": "Couleur de l'overlay derrière le drawer",
      "default": "#1A1814"
    },
    {
      "type": "range",
      "id": "search_overlay_opacity",
      "label": "Opacité de l'overlay",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Texte du placeholder",
      "default": "Rechercher une pièce, une matière, une époque…"
    },
    {
      "type": "link_list",
      "id": "search_categories_menu",
      "label": "Menu des catégories de recherche",
      "info": "Réservé aux résultats live (filtrage). Crée un menu dans Boutique → Navigation et sélectionne-le ici.",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Module conciergerie (aucun résultat)"
    },
    {
      "type": "checkbox",
      "id": "search_show_concierge",
      "label": "Afficher le module conciergerie quand aucun résultat",
      "default": true
    },
    {
      "type": "text",
      "id": "search_concierge_eyebrow",
      "label": "Eyebrow",
      "default": "CONCIERGERIE"
    },
    {
      "type": "textarea",
      "id": "search_concierge_text",
      "label": "Texte central",
      "default": "Une pièce particulière que vous ne trouvez pas ici ? Notre conciergerie la cherche pour vous, partout dans le monde."
    },
    {
      "type": "text",
      "id": "search_concierge_cta_text",
      "label": "Texte du bouton",
      "default": "CONFIER UNE RECHERCHE"
    },
    {
      "type": "text",
      "id": "search_concierge_cta_url",
      "label": "Lien du bouton",
      "info": "Chemin ou URL complète. Default : /pages/conciergerie",
      "default": "/pages/conciergerie"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "search_anim_duration",
      "label": "Durée d'animation",
      "info": "Vitesse d'ouverture / fermeture du drawer recherche",
      "min": 100,
      "max": 500,
      "step": 50,
      "unit": "ms",
      "default": 250
    }
  ]
}
{% endschema %}
