<div class="mc-hd-wrap">

  <!-- ZONE 1 : Bande noire fine vide -->
  <div class="mc-hd-topbar"></div>

  <!-- ZONE 2 : Bandeau principal -->
  <div class="mc-hd-main">
    <a href="/" class="mc-hd-logo" aria-label="Maison Coeur — Accueil">
      <img src="{{ 'mc-monogram.png' | asset_url }}" alt="Maison Coeur" class="mc-hd-monogram-img" width="32" height="44" loading="eager">
    </a>
    <div class="mc-hd-wordmark">
      <a href="/">
        <img src="{{ 'mc-wordmark.png' | asset_url }}" alt="Maison Coeur" class="mc-hd-wordmark-img" loading="eager">
      </a>
    </div>
    <div class="mc-hd-icons">
      <a href="/search" class="mc-hd-icon" aria-label="Rechercher">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
      </a>
      <a href="/account" class="mc-hd-icon" aria-label="Compte">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4 4-7 8-7s8 3 8 7"/>
        </svg>
      </a>
      <a href="/pages/favoris" class="mc-hd-icon" aria-label="Favoris">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20.5s-7.5-4.8-9.5-10C1 6 5.5 2.5 9 4.5c1.3.7 2.4 1.8 3 3 .6-1.2 1.7-2.3 3-3 3.5-2 8 1.5 6.5 6-2 5.2-9.5 10-9.5 10z"/>
        </svg>
      </a>
      <a href="/cart" class="mc-hd-icon" aria-label="Panier">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5.5 8h13l-1.2 12.5H6.7L5.5 8z"/>
          <path d="M9 8V6.5a3 3 0 0 1 6 0V8"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- ZONE 3 : Menu navigation -->
  <nav class="mc-hd-nav" aria-label="Navigation principale">
    <ul class="mc-hd-nav__list">
      {%- for link in linklists['main-menu'].links -%}
        <li class="mc-hd-nav__item">
          <a href="{{ link.url }}" class="mc-hd-nav__link">{{ link.title | upcase }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

</div>

{% schema %}
{
  "name": "Header Maison Coeur",
  "settings": []
}
{% endschema %}
