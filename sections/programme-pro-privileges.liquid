{{ 'section-programme-pro-privileges.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pp-priv-padding-top: {{ section.settings.padding_top }}px;
    --pp-priv-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pp-priv-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --pp-priv-eyebrow-tracking: {{ section.settings.eyebrow_tracking | divided_by: 100.0 }}em;
    --pp-priv-eyebrow-margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
    --pp-priv-numeral-size: {{ section.settings.numeral_size }}px;
    --pp-priv-numeral-color: {{ section.settings.numeral_color }};
    --pp-priv-title-size: {{ section.settings.title_size }}px;
    --pp-priv-body-size: {{ section.settings.body_size }}px;
    --pp-priv-body-line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
    --pp-priv-cell-pad-h: {{ section.settings.grid_gap_horizontal }}px;
    --pp-priv-cell-pad-v: {{ section.settings.grid_gap_vertical }}px;
  }
{%- endstyle -%}

<section class="programme-pro-privileges">
  <div class="programme-pro-privileges__inner">

    {%- if section.settings.eyebrow_text != blank -%}
      <p class="programme-pro-privileges__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
    {%- endif -%}

    <div class="programme-pro-privileges__grid">
      {%- for n in (1..6) -%}
        {%- assign num_key = 'priv' | append: n | append: '_numeral' -%}
        {%- assign title_key = 'priv' | append: n | append: '_title' -%}
        {%- assign body_key = 'priv' | append: n | append: '_body' -%}
        {%- assign num = section.settings[num_key] -%}
        {%- assign title = section.settings[title_key] -%}
        {%- assign body = section.settings[body_key] -%}
        <div class="programme-pro-privileges__cell">
          {%- if num != blank -%}
            <p class="programme-pro-privileges__numeral">{{ num | escape }}</p>
          {%- endif -%}
          {%- if title != blank -%}
            <h2 class="programme-pro-privileges__title">{{ title | escape }}</h2>
          {%- endif -%}
          {%- if body != blank -%}
            <p class="programme-pro-privileges__body">{{ body | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Privilèges",
  "settings": [
    { "type": "header", "content": "Eyebrow" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow", "default": "LES PRIVILÈGES" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 24, "step": 1, "unit": "px", "label": "Taille eyebrow", "default": 13 },
    { "type": "range", "id": "eyebrow_tracking", "min": 0, "max": 50, "step": 1, "unit": "%", "label": "Tracking eyebrow (letter-spacing × 100)", "default": 30 },
    { "type": "range", "id": "eyebrow_margin_bottom", "min": 20, "max": 200, "step": 4, "unit": "px", "label": "Marge sous l'eyebrow", "default": 60 },

    { "type": "header", "content": "Numéral I / II / III…" },
    { "type": "range", "id": "numeral_size", "min": 24, "max": 80, "step": 1, "unit": "px", "label": "Taille du numéral", "default": 30 },
    { "type": "color", "id": "numeral_color", "label": "Couleur du numéral (pierre)", "default": "#8C826E" },

    { "type": "header", "content": "Titre & description" },
    { "type": "range", "id": "title_size", "min": 16, "max": 40, "step": 1, "unit": "px", "label": "Taille du titre", "default": 22 },
    { "type": "range", "id": "body_size", "min": 11, "max": 20, "step": 1, "unit": "px", "label": "Taille de la description", "default": 13 },
    { "type": "range", "id": "body_line_height", "min": 120, "max": 220, "step": 5, "unit": "%", "label": "Interligne description", "default": 165 },

    { "type": "header", "content": "Grille (espacement interne des cellules)" },
    { "type": "range", "id": "grid_gap_horizontal", "min": 16, "max": 80, "step": 2, "unit": "px", "label": "Padding horizontal des cellules", "default": 40 },
    { "type": "range", "id": "grid_gap_vertical", "min": 16, "max": 80, "step": 2, "unit": "px", "label": "Padding vertical des cellules", "default": 40 },

    { "type": "header", "content": "Espacements section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding top", "default": 28 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 },

    { "type": "header", "content": "Privilège I" },
    { "type": "text", "id": "priv1_numeral", "label": "Numéral", "default": "I" },
    { "type": "text", "id": "priv1_title", "label": "Titre", "default": "Sourcing curatorial prioritaire" },
    { "type": "textarea", "id": "priv1_body", "label": "Description", "default": "Identification sous 48h, partout dans le monde." },

    { "type": "header", "content": "Privilège II" },
    { "type": "text", "id": "priv2_numeral", "label": "Numéral", "default": "II" },
    { "type": "text", "id": "priv2_title", "label": "Titre", "default": "Tarification professionnelle" },
    { "type": "textarea", "id": "priv2_body", "label": "Description", "default": "Sur le catalogue et les pièces sourcées." },

    { "type": "header", "content": "Privilège III" },
    { "type": "text", "id": "priv3_numeral", "label": "Numéral", "default": "III" },
    { "type": "text", "id": "priv3_title", "label": "Titre", "default": "Réservation avant publication" },
    { "type": "textarea", "id": "priv3_body", "label": "Description", "default": "Accès prioritaire aux nouvelles acquisitions." },

    { "type": "header", "content": "Privilège IV" },
    { "type": "text", "id": "priv4_numeral", "label": "Numéral", "default": "IV" },
    { "type": "text", "id": "priv4_title", "label": "Titre", "default": "Conseil curatorial en amont" },
    { "type": "textarea", "id": "priv4_body", "label": "Description", "default": "Échange préalable sur chaque projet d'ensemble." },

    { "type": "header", "content": "Privilège V" },
    { "type": "text", "id": "priv5_numeral", "label": "Numéral", "default": "V" },
    { "type": "text", "id": "priv5_title", "label": "Titre", "default": "Documentation enrichie" },
    { "type": "textarea", "id": "priv5_body", "label": "Description", "default": "Justificatifs et note de présentation pour votre client final." },

    { "type": "header", "content": "Privilège VI" },
    { "type": "text", "id": "priv6_numeral", "label": "Numéral", "default": "VI" },
    { "type": "text", "id": "priv6_title", "label": "Titre", "default": "Mise en lumière de vos projets" },
    { "type": "textarea", "id": "priv6_body", "label": "Description", "default": "Relais éditorial sur nos réseaux et supports." }
  ],
  "presets": [
    { "name": "Programme Pro – Privilèges" }
  ]
}
{% endschema %}
