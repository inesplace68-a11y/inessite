{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Phase 16.6 — variables grille + vignette pilotées par Customizer */
  /* Phase 16.7 — variables barre filtres/tri + drawer */
  #shopify-section-{{ section.id }} {
    --mcg-card-gap-desktop: {{ section.settings.card_gap_desktop | default: 20 }}px;
    --mcg-card-gap-mobile: {{ section.settings.card_gap_mobile | default: 12 }}px;
    --mcg-card-title-size: {{ section.settings.card_title_size | default: 16 }}px;
    --mcg-card-title-lines: {{ section.settings.card_title_max_lines | default: 2 }};
    --mcg-card-price-size: {{ section.settings.card_price_size | default: 14 }}px;
    --mcg-image-zoom: {{ section.settings.image_zoom_amount | default: 102 }};
    --mcg-wishlist-color: {{ section.settings.wishlist_color | default: '#1A1814' }};
    --mc-bar-pt: {{ section.settings.bar_padding_top | default: 20 }}px;
    --mc-bar-pb: {{ section.settings.bar_padding_bottom | default: 20 }}px;
    --mc-title-gap: {{ section.settings.collection_padding_top_desktop | default: 8 }}px;
    --mc-title-gap-mobile: {{ section.settings.collection_padding_top_mobile | default: 8 }}px;
    --mc-grid-gap: {{ section.settings.bar_to_grid_gap | default: 24 }}px;
    --mc-drawer-w: {{ section.settings.drawer_width_desktop | default: 400 }}px;
    --mc-drawer-dur: {{ section.settings.drawer_animation_duration | default: 350 }}ms;
    --mc-drawer-bg: {{ section.settings.drawer_bg_color | default: '#F5F0E8' }};
    --mc-overlay-op: {{ section.settings.overlay_opacity | default: 0.4 }};
    --mc-sort-gap: {{ section.settings.sort_chevron_gap | default: 8 }}px;
    --mc-sort-bg: {{ section.settings.sort_dropdown_bg | default: '#F5F0E8' }};
    --mc-drawer-top: {{ section.settings.drawer_top_offset | default: 80 }}px;
    --mc-drawer-maxh: {{ section.settings.drawer_max_height_vh | default: 85 }}vh;
    --mc-drawer-divider: {{ section.settings.drawer_divider_color | default: '#E8E4DD' }};
    --mc-filter-title-size: {{ section.settings.filter_title_size_desktop | default: 18 }}px;
    --mc-filter-title-size-m: {{ section.settings.filter_title_size_mobile | default: 16 }}px;
    --mc-filter-label-size: {{ section.settings.filter_section_label_size_desktop | default: 14 }}px;
    --mc-filter-label-size-m: {{ section.settings.filter_section_label_size_mobile | default: 12 }}px;
    --mc-label-size: {{ section.settings.filter_sort_label_size | default: 12 }}px;
    --mc-label-color: {{ section.settings.filter_sort_label_color | default: '#6B6660' }};
  }
  /* Grille — gap configurable */
  #shopify-section-{{ section.id }} .grid--quarter-max,
  #shopify-section-{{ section.id }} .product-grid {
    gap: var(--mcg-card-gap-desktop, 20px);
  }
  /* Format image 4:5 portrait (override Dawn ratio) */
  #shopify-section-{{ section.id }} .card .card__inner.ratio,
  #shopify-section-{{ section.id }} .card-wrapper .card__inner.ratio {
    --ratio-percent: 125%;
  }
  /* Typo vignette */
  #shopify-section-{{ section.id }} .card__heading {
    font-family: 'Cormorant Garamond', Cormorant, Georgia, serif;
    font-weight: 400;
    font-style: normal;
    font-size: var(--mcg-card-title-size, 16px);
    line-height: 1.25;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    display: -webkit-box;
    -webkit-line-clamp: var(--mcg-card-title-lines, 2);
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  #shopify-section-{{ section.id }} .card__heading a {
    font-family: inherit;
    font-weight: inherit;
    font-style: inherit;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  /* Phase 16.20 — Hover titre carte produit : transition couleur + no underline */
  #shopify-section-{{ section.id }} .card__heading,
  #shopify-section-{{ section.id }} .card__heading a {
    transition: color {{ section.settings.card_title_hover_transition | default: 0.5 }}s ease;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .card-wrapper:hover .card__heading,
  #shopify-section-{{ section.id }} .card-wrapper:hover .card__heading a,
  #shopify-section-{{ section.id }} .card-wrapper:focus-within .card__heading,
  #shopify-section-{{ section.id }} .card-wrapper:focus-within .card__heading a {
    color: {{ section.settings.card_title_hover_color | default: '#8C6D3F' }};
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .card__information,
  #shopify-section-{{ section.id }} .card-information {
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .price,
  #shopify-section-{{ section.id }} .price__regular .price-item,
  #shopify-section-{{ section.id }} .price-item--regular {
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: var(--mcg-card-price-size, 14px);
  }
  /* Coeur wishlist sur la vignette — masqué au repos, visible au hover */
  #shopify-section-{{ section.id }} .card-wrapper {
    position: relative;
  }
  #shopify-section-{{ section.id }} .card-wrapper .mc-product-heart--card {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    color: var(--mcg-wishlist-color, #1A1814);
    {%- if section.settings.wishlist_hover_only -%}
    opacity: 0;
    transition: opacity 200ms ease-out;
    {%- endif -%}
  }
  {%- if section.settings.wishlist_hover_only -%}
  #shopify-section-{{ section.id }} .card-wrapper:hover .mc-product-heart--card,
  #shopify-section-{{ section.id }} .card-wrapper:focus-within .mc-product-heart--card,
  #shopify-section-{{ section.id }} .card-wrapper .mc-product-heart--card[aria-pressed='true'],
  #shopify-section-{{ section.id }} .card-wrapper .mc-product-heart--card[data-active='true'] {
    opacity: 1;
  }
  {%- endif -%}
  {%- unless section.settings.show_wishlist_heart -%}
  #shopify-section-{{ section.id }} .card-wrapper .mc-product-heart--card {
    display: none !important;
  }
  {%- endunless -%}
  /* Zoom image au hover (optionnel) */
  {%- if section.settings.enable_image_zoom_on_hover -%}
  #shopify-section-{{ section.id }} .card-wrapper .card__media img {
    transition: transform 400ms ease;
  }
  #shopify-section-{{ section.id }} .card-wrapper:hover .card__media img {
    transform: scale(calc(var(--mcg-image-zoom, 102) / 100));
  }
  {%- endif -%}

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .grid--quarter-max,
    #shopify-section-{{ section.id }} .product-grid {
      gap: var(--mcg-card-gap-mobile, 12px);
    }
  }

  /* === Phase 16.7 — Barre filtres/tri + drawer === */

  /* Toolbar */
  #shopify-section-{{ section.id }} .mc-collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: var(--mc-title-gap, 32px);
    margin-bottom: var(--mc-grid-gap, 24px);
    padding-top: var(--mc-bar-pt, 20px);
    padding-bottom: var(--mc-bar-pb, 20px);
    {%- if section.settings.show_bar_top_border -%}
    border-top: 1px solid rgba(26, 24, 20, 0.10);
    {%- endif -%}
    {%- if section.settings.show_bar_bottom_border -%}
    border-bottom: 1px solid rgba(26, 24, 20, 0.10);
    {%- endif -%}
    position: relative;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__filter-trigger {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 6px 0;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: var(--mc-label-size, 12px);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mc-label-color, #6B6660);
    transition: color 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__filter-trigger:hover,
  #shopify-section-{{ section.id }} .mc-toolbar__filter-trigger:focus-visible {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
    color: currentColor;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__icon svg {
    width: 100%;
    height: 100%;
    color: currentColor;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__right {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__count {
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.10em;
    color: rgba(26, 24, 20, 0.70);
  }
  #shopify-section-{{ section.id }} .mc-toolbar__sep {
    color: rgba(26, 24, 20, 0.35);
    font-size: 12px;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__sort {
    display: inline-flex;
    align-items: center;
    margin-left: auto;
    margin-right: 0;
  }
  #shopify-section-{{ section.id }} .mc-toolbar__sort form {
    display: inline-flex;
    align-items: center;
    margin: 0;
  }
  /* Native select hidden — facets.js submission compat */
  #shopify-section-{{ section.id }} .mc-toolbar__select-native {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    pointer-events: none;
  }
  /* Custom sort dropdown */
  #shopify-section-{{ section.id }} .mc-sort {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .mc-sort__trigger {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 6px 0;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--mc-sort-gap, 8px);
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: var(--mc-label-size, 12px);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mc-label-color, #6B6660);
    transition: color 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-sort__trigger:hover,
  #shopify-section-{{ section.id }} .mc-sort__trigger:focus-visible {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-sort__caret {
    display: inline-flex;
    width: 10px;
    height: 10px;
    color: currentColor;
    transition: transform 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-sort__caret svg {
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .mc-sort__trigger[aria-expanded='true'] .mc-sort__caret {
    transform: rotate(180deg);
  }
  #shopify-section-{{ section.id }} .mc-sort__menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 220px;
    max-width: 320px;
    background: var(--mc-sort-bg, #F5F0E8);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    list-style: none;
    margin: 0;
    padding: 8px 0;
    z-index: 50;
  }
  #shopify-section-{{ section.id }} .mc-sort__menu[hidden] {
    display: none;
  }
  #shopify-section-{{ section.id }} .mc-sort__option {
    appearance: none;
    background: transparent;
    border: 0;
    width: 100%;
    text-align: left;
    padding: 10px 22px;
    cursor: pointer;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: var(--mc-label-size, 12px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mc-label-color, #6B6660);
    transition: background-color 180ms ease, color 180ms ease;
    display: block;
    position: relative;
  }
  #shopify-section-{{ section.id }} .mc-sort__option:hover,
  #shopify-section-{{ section.id }} .mc-sort__option:focus-visible {
    background: rgba(26, 24, 20, 0.04);
    color: #8C6D3F;
    outline: none;
  }
  /* Active option — bronze color */
  #shopify-section-{{ section.id }} .mc-sort__option.is-active--bronze {
    color: #8C6D3F;
  }
  /* Active option — underline */
  #shopify-section-{{ section.id }} .mc-sort__option.is-active--underline {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    text-decoration-color: #8C6D3F;
  }
  /* Active option — left dot */
  #shopify-section-{{ section.id }} .mc-sort__option.is-active--dot {
    padding-left: 30px;
  }
  #shopify-section-{{ section.id }} .mc-sort__option.is-active--dot::before {
    content: '';
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #8C6D3F;
  }

  /* Overlay */
  #shopify-section-{{ section.id }} .mc-filter-overlay {
    position: fixed;
    inset: 0;
    background: rgba(26, 24, 20, var(--mc-overlay-op, 0.4));
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--mc-drawer-dur, 350ms) ease-out, visibility var(--mc-drawer-dur, 350ms) ease-out;
    z-index: 90;
  }
  #shopify-section-{{ section.id }} .mc-filter-overlay[data-open='true'] {
    opacity: 1;
    visibility: visible;
  }

  /* Drawer */
  #shopify-section-{{ section.id }} .mc-filter-drawer {
    position: fixed;
    top: var(--mc-drawer-top, 80px);
    {%- if section.settings.drawer_height_mode == 'fullscreen' -%}
    height: 100vh;
    height: 100dvh;
    {%- else -%}
    height: auto;
    max-height: min(var(--mc-drawer-maxh, 85vh), calc(100vh - var(--mc-drawer-top, 80px) - 16px));
    {%- endif -%}
    width: var(--mc-drawer-w, 400px);
    max-width: 100vw;
    background: var(--mc-drawer-bg, #F5F0E8);
    box-shadow: 2px 0 24px rgba(0, 0, 0, 0.08);
    z-index: 100;
    transition: transform var(--mc-drawer-dur, 350ms) ease-out;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer--left {
    left: 0;
    transform: translateX(-100%);
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer--right {
    right: 0;
    transform: translateX(100%);
    box-shadow: -2px 0 24px rgba(0, 0, 0, 0.08);
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer[data-open='true'] {
    transform: translateX(0);
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px 20px;
    border-bottom: 1px solid var(--mc-drawer-divider, #E8E4DD);
    flex: 0 0 auto;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__title {
    margin: 0;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: var(--mc-filter-title-size, 18px);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #1A1814;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__close {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 6px;
    margin: -6px;
    cursor: pointer;
    color: #1A1814;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__close:hover {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__close svg {
    width: 16px;
    height: 16px;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__body {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 8px 28px 16px;
    -webkit-overflow-scrolling: touch;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__footer {
    flex: 0 0 auto;
    padding: 16px 28px 24px;
    border-top: 1px solid var(--mc-drawer-divider, #E8E4DD);
    background: var(--mc-drawer-bg, #F5F0E8);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__clear {
    align-self: center;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1A1814;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__clear:hover {
    color: #8C6D3F;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__apply {
    appearance: none;
    width: 100%;
    padding: 14px 20px;
    background: transparent;
    border: 1px solid #1A1814;
    color: #1A1814;
    cursor: pointer;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: background-color 200ms ease, color 200ms ease;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__apply:hover,
  #shopify-section-{{ section.id }} .mc-filter-drawer__apply:focus-visible {
    background: #1A1814;
    color: #F5F0E8;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer__apply[data-empty='true'] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Override facets snippet styles when inside the drawer (force full width / single column) */
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets {
    width: 100%;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets.small-hide {
    display: block !important;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__form-vertical {
    width: 100%;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets-wrapper {
    padding-right: 0 !important;
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets-vertical {
    display: block;
  }
  /* Hide the heading of the facets snippet — we have our own drawer title */
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__heading--vertical {
    display: none;
  }
  /* Hide the legacy mobile menu-drawer (we now own the drawer UX) */
  #shopify-section-{{ section.id }} .mc-filter-drawer .mobile-facets__wrapper {
    display: none !important;
  }
  /* Hide the duplicate mobile product count rendered by the facets snippet */
  #shopify-section-{{ section.id }} .mc-filter-drawer .product-count.light {
    display: none !important;
  }
  /* Make sure facet summaries adopt our typography */
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__summary,
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__summary-label {
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: var(--mc-filter-label-size, 14px);
    color: #1A1814;
  }
  /* Drawer accordion dividers — pierre */
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__disclosure,
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__disclosure-vertical,
  #shopify-section-{{ section.id }} .mc-filter-drawer details.facets__disclosure-vertical {
    border-bottom: 1px solid var(--mc-drawer-divider, #E8E4DD);
  }
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__disclosure:last-of-type,
  #shopify-section-{{ section.id }} .mc-filter-drawer .facets__disclosure-vertical:last-of-type,
  #shopify-section-{{ section.id }} .mc-filter-drawer details.facets__disclosure-vertical:last-of-type {
    border-bottom: 0;
  }
  /* Hide top clear-all (active-facets) — keep only the bottom footer link */
  {%- unless section.settings.show_clear_all_top -%}
  #shopify-section-{{ section.id }} .mc-filter-drawer .active-facets,
  #shopify-section-{{ section.id }} .mc-filter-drawer .active-facets-vertical-filter,
  #shopify-section-{{ section.id }} .mc-filter-drawer .active-facets__button-remove {
    display: none !important;
  }
  {%- endunless -%}

  /* Body/html scroll lock when drawer open */
  html.mc-filters-open,
  body.mc-filters-open {
    overflow: hidden;
  }

  /* Tighten vertical spacing between banner and grid */
  #shopify-section-{{ section.id }} .product-grid-container {
    margin-top: 0;
  }

  /* Mobile: full-width drawer + mobile typo */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-filter-drawer {
      width: 100vw;
      max-width: 100vw;
    }
    #shopify-section-{{ section.id }} .mc-filter-drawer__title {
      font-size: var(--mc-filter-title-size-m, 16px);
    }
    #shopify-section-{{ section.id }} .mc-filter-drawer .facets__summary,
    #shopify-section-{{ section.id }} .mc-filter-drawer .facets__summary-label {
      font-size: var(--mc-filter-label-size-m, 12px);
    }
    #shopify-section-{{ section.id }} .mc-collection-toolbar {
      flex-wrap: wrap;
      gap: 8px;
      margin-top: var(--mc-title-gap-mobile, 8px);
    }
    #shopify-section-{{ section.id }} .mc-sort__menu {
      right: 0;
      min-width: 200px;
    }
  }

  /* === Phase 16.21 — Sidebar inline (desktop >= 990px) ============
     Le drawer devient une sidebar dans le flow du document, ancrée
     à gauche d'un layout flex contenant la grille. Au repos, la
     sidebar a une largeur de 0 (invisible, pas de place réservée).
     À l'ouverture, elle s'étend à 400px et la grille se compresse
     en passant de 4 à 3 colonnes. Pas d'overlay desktop, pas de
     scroll lock, la grille reste cliquable.
     Mobile (< 990px) : comportement drawer overlay inchangé. */
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .mc-collection-layout {
      display: flex;
      align-items: flex-start;
      gap: 0;
    }
    #shopify-section-{{ section.id }} .mc-collection-layout .product-grid-container {
      flex: 1 1 auto;
      min-width: 0;
      transition: padding-left var(--mc-drawer-dur, 350ms) ease-out;
    }
    /* Drawer en mode sidebar : passe dans le flow normal */
    #shopify-section-{{ section.id }} .mc-collection-layout .mc-filter-drawer {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      height: auto;
      max-height: none;
      flex: 0 0 0;
      width: 0;
      transform: none;
      box-shadow: none;
      overflow: hidden;
      opacity: 0;
      transition:
        flex-basis var(--mc-drawer-dur, 350ms) ease-out,
        width var(--mc-drawer-dur, 350ms) ease-out,
        opacity var(--mc-drawer-dur, 350ms) ease-out,
        margin var(--mc-drawer-dur, 350ms) ease-out;
      margin-right: 0;
    }
    #shopify-section-{{ section.id }} .mc-collection-layout .mc-filter-drawer[data-open='true'] {
      flex: 0 0 var(--mc-drawer-w, 400px);
      width: var(--mc-drawer-w, 400px);
      opacity: 1;
      margin-right: 32px;
    }
    /* Pas d'overlay desktop */
    #shopify-section-{{ section.id }} .mc-collection-layout .mc-filter-overlay {
      display: none;
    }
    /* Pas de scroll lock du body sur desktop quand sidebar ouverte
       (override la règle html.mc-filters-open / body.mc-filters-open
       qui sert au drawer overlay mobile) */
    html.mc-filters-open,
    body.mc-filters-open {
      overflow: auto;
    }
    /* Grille en 3 colonnes quand sidebar ouverte (override .grid--4-col-desktop) */
    #shopify-section-{{ section.id }} .mc-collection-layout:has(.mc-filter-drawer[data-open='true']) .grid--4-col-desktop .grid__item {
      width: calc(33.333% - var(--grid-desktop-horizontal-spacing) * 2 / 3);
      max-width: calc(33.333% - var(--grid-desktop-horizontal-spacing) * 2 / 3);
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {{ 'component-facets.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

    {%- liquid
      assign filter_btn_label = section.settings.filter_button_label | default: 'FILTRES'
      assign show_filter_icon = section.settings.show_filter_icon
      assign icon_style = section.settings.filter_icon_style | default: 'curseurs'
      assign show_count = section.settings.show_product_count
      assign drawer_side = section.settings.drawer_side | default: 'left'
      assign apply_text = section.settings.apply_button_text | default: 'VOIR LES X PIÈCES'
      assign clear_all_text = section.settings.clear_all_text | default: 'Tout effacer'
      assign close_on_apply = section.settings.close_on_apply
      assign close_on_escape = section.settings.close_on_escape
      assign close_on_overlay = section.settings.close_on_overlay_click
      assign sort_by = collection.sort_by | default: collection.default_sort_by
      assign sort_show_current = section.settings.sort_show_current_value
      assign sort_active_indicator = section.settings.sort_active_indicator | default: 'bronze'
      assign sort_label_text = section.settings.sort_label_text | default: 'TRIER PAR'
      assign sort_current_label = ''
      for option in collection.sort_options
        if option.value == sort_by
          assign sort_current_label = option.name
        endif
      endfor
      assign apply_prefix = apply_text | split: 'X' | first | strip
      assign apply_suffix = apply_text | split: 'X' | last
      if apply_suffix == apply_text
        assign apply_suffix = ''
      else
        assign apply_suffix = apply_suffix | strip
      endif
    -%}

    {% comment %} === Toolbar (filtres + tri) — Phase 16.7 === {% endcomment %}
    <div class="mc-collection-toolbar page-width" data-mc-toolbar>
      {%- if section.settings.enable_filtering -%}
        <button
          type="button"
          class="mc-toolbar__filter-trigger"
          data-mc-filter-open
          aria-controls="MCFilterDrawer-{{ section.id }}"
          aria-expanded="false"
        >
          {%- if show_filter_icon -%}
            <span class="mc-toolbar__icon" aria-hidden="true">
              {%- case icon_style -%}
                {%- when 'lignes' -%}
                  <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <line x1="2" y1="6" x2="18" y2="6" stroke="currentColor" stroke-width="1"/>
                    <line x1="2" y1="14" x2="18" y2="14" stroke="currentColor" stroke-width="1"/>
                  </svg>
                {%- when 'plus' -%}
                  <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <line x1="10" y1="3" x2="10" y2="17" stroke="currentColor" stroke-width="1"/>
                    <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1"/>
                  </svg>
                {%- else -%}
                  {{- 'icon-filter.svg' | inline_asset_content -}}
              {%- endcase -%}
            </span>
          {%- endif -%}
          <span class="mc-toolbar__filter-label">{{ filter_btn_label }}</span>
        </button>
      {%- endif -%}

      <div class="mc-toolbar__right">
        {%- if show_count -%}
          <span class="mc-toolbar__count" data-mc-toolbar-count>
            <span data-mc-count-number>{{ collection.products_count }}</span>&nbsp;pièces
          </span>
          {%- if section.settings.enable_sorting -%}<span class="mc-toolbar__sep" aria-hidden="true">·</span>{%- endif -%}
        {%- endif -%}

        {%- if section.settings.enable_sorting -%}
          <facet-filters-form class="mc-toolbar__sort">
            <form id="FacetSortForm">
              <label class="visually-hidden" for="SortBy">{{ sort_label_text }}</label>
              <select
                name="sort_by"
                id="SortBy"
                class="mc-toolbar__select-native"
                data-mc-sort-select
                aria-describedby="a11y-refresh-page-message"
                tabindex="-1"
              >
                {%- for option in collection.sort_options -%}
                  <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected="selected"{% endif %}>
                    {{- option.name | escape -}}
                  </option>
                {%- endfor -%}
              </select>
              <div class="mc-sort" data-mc-sort>
                <button
                  type="button"
                  class="mc-sort__trigger"
                  data-mc-sort-trigger
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-controls="MCSortMenu-{{ section.id }}"
                >
                  <span class="mc-sort__label">
                    {{- sort_label_text -}}
                    {%- if sort_show_current and sort_current_label != blank -%}
                      &nbsp;: <span data-mc-sort-current>{{ sort_current_label }}</span>
                    {%- endif -%}
                  </span>
                  <span class="mc-sort__caret" aria-hidden="true">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </button>
                <ul
                  id="MCSortMenu-{{ section.id }}"
                  class="mc-sort__menu"
                  data-mc-sort-menu
                  role="listbox"
                  aria-label="{{ sort_label_text }}"
                  hidden
                >
                  {%- for option in collection.sort_options -%}
                    <li>
                      <button
                        type="button"
                        role="option"
                        class="mc-sort__option{% if option.value == sort_by %} is-active is-active--{{ sort_active_indicator }}{% endif %}"
                        data-value="{{ option.value | escape }}"
                        aria-selected="{% if option.value == sort_by %}true{% else %}false{% endif %}"
                      >
                        {{- option.name | escape -}}
                      </button>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </form>
          </facet-filters-form>
        {%- endif -%}
      </div>

      {% comment %} Hidden mirror for facets.js compatibility (renderProductCount writes here) {% endcomment %}
      <span id="ProductCountDesktop" class="visually-hidden" data-mc-count-mirror role="status">
        {%- if collection.results_count -%}
          {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
        {%- elsif collection.products_count == collection.all_products_count -%}
          {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
        {%- else -%}
          {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
        {%- endif -%}
      </span>
    </div>

    {% comment %} === Layout wrapper (Phase 16.21) : flex container desktop
                     pour transformer le drawer en sidebar inline ;
                     mobile < 990px conserve un comportement drawer overlay
                     classique (le drawer s'extrait visuellement via fixed). === {% endcomment %}
    <div class="mc-collection-layout">
    {% comment %} === Overlay + Drawer === {% endcomment %}
    {%- if section.settings.enable_filtering -%}
      <div class="mc-filter-overlay" data-mc-filter-overlay aria-hidden="true"></div>
      <aside
        id="MCFilterDrawer-{{ section.id }}"
        class="mc-filter-drawer mc-filter-drawer--{{ drawer_side }}"
        data-mc-filter-drawer
        data-close-escape="{{ close_on_escape }}"
        data-close-overlay="{{ close_on_overlay }}"
        data-close-apply="{{ close_on_apply }}"
        role="dialog"
        aria-modal="true"
        aria-labelledby="MCFilterDrawerTitle-{{ section.id }}"
        aria-hidden="true"
        tabindex="-1"
      >
        <div class="mc-filter-drawer__inner">
          <header class="mc-filter-drawer__header">
            <h2 id="MCFilterDrawerTitle-{{ section.id }}" class="mc-filter-drawer__title">FILTRES</h2>
            <button
              type="button"
              class="mc-filter-drawer__close"
              data-mc-filter-close
              aria-label="Fermer les filtres"
            >
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </header>
          <div class="mc-filter-drawer__body">
            {% render 'facets',
              results: collection,
              enable_filtering: section.settings.enable_filtering,
              enable_sorting: false,
              filter_type: 'vertical',
              paginate: paginate
            %}
          </div>
          <footer class="mc-filter-drawer__footer">
            <a href="{{ collection.url }}" class="mc-filter-drawer__clear">{{ clear_all_text }}</a>
            <button
              type="button"
              class="mc-filter-drawer__apply"
              data-mc-filter-apply
              data-empty="{% if collection.products_count == 0 %}true{% else %}false{% endif %}"
            >
              <span data-mc-apply-text>{{ 'collection.see_pieces' | t: count: collection.products_count }}</span>
            </button>
          </footer>
        </div>
      </aside>
    {%- endif -%}

    {% comment %} === Product grid === {% endcomment %}
    <div
      class="product-grid-container page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      id="ProductGridContainer"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
      {% endif %}
    >
      {%- if collection.products.size == 0 -%}
        <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
          <div class="loading-overlay gradient"></div>
          <div class="title-wrapper center">
            <h2 class="title title--primary">
              {{ 'sections.collection_template.empty' | t -}}
              <br>
              {{
                'sections.collection_template.use_fewer_filters_html'
                | t: link: collection.url, class: 'underlined-link link'
              }}
            </h2>
          </div>
        </div>
      {%- else -%}
        <div class="collection">
          <div class="loading-overlay gradient"></div>
          <ul
            id="product-grid"
            data-id="{{ section.id }}"
            class="
              grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
              grid--{{ section.settings.columns_desktop }}-col-desktop
              {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
            "
          >
            {% assign skip_card_product_styles = false %}
            {%- for product in collection.products -%}
              {% assign lazy_load = false %}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              <li
                class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load,
                  skip_styles: skip_card_product_styles,
                  quick_add: section.settings.quick_add,
                  section_id: section.id
                %}
              </li>
              {%- assign skip_card_product_styles = true -%}
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    </div>{% comment %} /.mc-collection-layout (Phase 16.21) {% endcomment %}

    {% comment %} === Drawer interactions (Phase 16.7) === {% endcomment %}
    <script>
      (function () {
        var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
        if (!sectionEl) return;
        var drawer = sectionEl.querySelector('[data-mc-filter-drawer]');
        var overlay = sectionEl.querySelector('[data-mc-filter-overlay]');
        var openers = sectionEl.querySelectorAll('[data-mc-filter-open]');
        var closers = sectionEl.querySelectorAll('[data-mc-filter-close]');
        var apply = sectionEl.querySelector('[data-mc-filter-apply]');
        var applyText = sectionEl.querySelector('[data-mc-apply-text]');
        var countMirror = sectionEl.querySelector('[data-mc-count-mirror]');
        var countNumber = sectionEl.querySelector('[data-mc-count-number]');
        if (!drawer) return;

        var pieceLabels = {
          zero: {{ 'collection.see_pieces.zero' | t | json }},
          one: {{ 'collection.see_pieces.one' | t: count: 1 | json }},
          other: {{ 'collection.see_pieces.other' | t: count: 0 | json }}
        };

        var closeEscape = drawer.dataset.closeEscape === 'true';
        var closeOverlay = drawer.dataset.closeOverlay === 'true';
        var closeApply = drawer.dataset.closeApply === 'true';

        function openDrawer() {
          drawer.setAttribute('data-open', 'true');
          drawer.setAttribute('aria-hidden', 'false');
          if (overlay) {
            overlay.setAttribute('data-open', 'true');
            overlay.setAttribute('aria-hidden', 'false');
          }
          openers.forEach(function (b) { b.setAttribute('aria-expanded', 'true'); });
          document.body.classList.add('mc-filters-open');
          document.documentElement.classList.add('mc-filters-open');
        }
        function closeDrawer() {
          drawer.removeAttribute('data-open');
          drawer.setAttribute('aria-hidden', 'true');
          if (overlay) {
            overlay.removeAttribute('data-open');
            overlay.setAttribute('aria-hidden', 'true');
          }
          openers.forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
          document.body.classList.remove('mc-filters-open');
          document.documentElement.classList.remove('mc-filters-open');
        }

        openers.forEach(function (b) { b.addEventListener('click', openDrawer); });
        closers.forEach(function (b) { b.addEventListener('click', closeDrawer); });
        if (overlay && closeOverlay) {
          overlay.addEventListener('click', closeDrawer);
        }
        if (closeEscape) {
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && drawer.getAttribute('data-open') === 'true') {
              closeDrawer();
            }
          });
        }
        if (apply && closeApply) {
          apply.addEventListener('click', closeDrawer);
        }

        function extractCount(text) {
          if (!text) return null;
          var m = String(text).match(/\d[\d\s  ]*/);
          if (!m) return null;
          return m[0].replace(/[\s  ]/g, '');
        }

        function formatApply(count) {
          if (count === 0) return pieceLabels.zero;
          if (count === 1) return pieceLabels.one.replace('1', String(count));
          return pieceLabels.other.replace('0', String(count));
        }
        function syncCounts() {
          if (!countMirror) return;
          var nStr = extractCount(countMirror.textContent);
          if (nStr === null) return;
          var n = parseInt(nStr, 10);
          if (isNaN(n)) return;
          if (countNumber) countNumber.textContent = String(n);
          if (applyText) applyText.textContent = formatApply(n);
          if (apply) apply.setAttribute('data-empty', n === 0 ? 'true' : 'false');
        }
        if (countMirror) {
          var mo = new MutationObserver(syncCounts);
          mo.observe(countMirror, { childList: true, characterData: true, subtree: true });
        }
      })();

      /* === Sort dropdown — Phase 16.9 === */
      (function () {
        var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
        if (!sectionEl) return;

        function getRoot(target) {
          return target && target.closest ? target.closest('[data-mc-sort]') : null;
        }
        function openMenu(root) {
          var trigger = root.querySelector('[data-mc-sort-trigger]');
          var menu = root.querySelector('[data-mc-sort-menu]');
          if (menu) menu.hidden = false;
          if (trigger) trigger.setAttribute('aria-expanded', 'true');
        }
        function closeMenu(root) {
          var trigger = root.querySelector('[data-mc-sort-trigger]');
          var menu = root.querySelector('[data-mc-sort-menu]');
          if (menu) menu.hidden = true;
          if (trigger) trigger.setAttribute('aria-expanded', 'false');
        }
        function closeAll() {
          sectionEl.querySelectorAll('[data-mc-sort]').forEach(closeMenu);
        }

        sectionEl.addEventListener('click', function (e) {
          var trigger = e.target.closest && e.target.closest('[data-mc-sort-trigger]');
          if (trigger) {
            var root = getRoot(trigger);
            if (!root) return;
            var menu = root.querySelector('[data-mc-sort-menu]');
            var isOpen = menu && !menu.hidden;
            closeAll();
            if (!isOpen) openMenu(root);
            return;
          }
          var option = e.target.closest && e.target.closest('[data-mc-sort-menu] [data-value]');
          if (option) {
            var optRoot = getRoot(option);
            if (!optRoot) return;
            var form = optRoot.closest('form');
            var nativeSelect = form && form.querySelector('[data-mc-sort-select]');
            if (nativeSelect) {
              nativeSelect.value = option.dataset.value;
              nativeSelect.dispatchEvent(new Event('input', { bubbles: true }));
              nativeSelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
            closeMenu(optRoot);
          }
        });

        document.addEventListener('click', function (e) {
          if (!sectionEl.contains(e.target)) {
            closeAll();
            return;
          }
          if (!e.target.closest('[data-mc-sort]')) closeAll();
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeAll();
        });
      })();
    </script>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },    
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
        },
        {
          "value": "blob",
          "label": "t:sections.all.image_shape.options__3.label"
        },
        {
          "value": "chevronleft",
          "label": "t:sections.all.image_shape.options__4.label"
        },
