{%- comment -%}
  Phase 18 — Page Presse · Contact presse
  Eyebrow + intro Jost Light + email mailto Cormorant italic underlined
  + sub délai. Tout centré.
{%- endcomment -%}

{{ 'section-presse-contact.css' | asset_url | stylesheet_tag }}

<section
  class="presse-contact"
  style="
    --presse-contact-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --presse-contact-eyebrow-tracking: {{ section.settings.eyebrow_tracking | divided_by: 100.0 }}em;
    --presse-contact-eyebrow-margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
    --presse-contact-eyebrow-color: {{ section.settings.eyebrow_color }};
    --presse-contact-intro-size: {{ section.settings.intro_size }}px;
    --presse-contact-intro-max-width: {{ section.settings.intro_max_width }}px;
    --presse-contact-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --presse-contact-intro-color: {{ section.settings.intro_color }};
    --presse-contact-intro-margin-bottom: {{ section.settings.intro_margin_bottom }}px;
    --presse-contact-email-size: {{ section.settings.email_size }}px;
    --presse-contact-email-color: {{ section.settings.email_color }};
    --presse-contact-email-margin-bottom: {{ section.settings.email_margin_bottom }}px;
    --presse-contact-delai-size: {{ section.settings.delai_size }}px;
    --presse-contact-delai-color: {{ section.settings.delai_color }};
    --presse-contact-padding-top: {{ section.settings.padding_top }}px;
    --presse-contact-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="presse-contact__inner">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="presse-contact__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <div class="presse-contact__intro rte">{{ section.settings.intro_text }}</div>
    {%- endif -%}

    {%- if section.settings.email_text != blank -%}
      <a class="presse-contact__email" href="mailto:{{ section.settings.email_text }}">
        {{ section.settings.email_text }}
      </a>
    {%- endif -%}

    {%- if section.settings.delai_note_text != blank -%}
      <p class="presse-contact__delai">{{ section.settings.delai_note_text | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Presse · Contact",
  "tag": "section",
  "class": "shopify-section--presse-contact",
  "settings": [
    { "type": "header", "content": "Eyebrow" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow", "default": "CONTACT PRESSE" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 18, "step": 1, "unit": "px", "label": "Taille eyebrow", "default": 12 },
    { "type": "range", "id": "eyebrow_tracking", "min": 0, "max": 50, "step": 1, "unit": "%", "label": "Letter-spacing eyebrow", "default": 22 },
    { "type": "range", "id": "eyebrow_margin_bottom", "min": 16, "max": 80, "step": 2, "unit": "px", "label": "Marge bas eyebrow", "default": 28 },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur eyebrow", "default": "#8C8882" },

    { "type": "header", "content": "Intro" },
    { "type": "richtext", "id": "intro_text", "label": "Texte d'intro", "default": "<p>Pour une interview, une visite du showroom, l'emprunt d'une pièce ou l'obtention de visuels, écrivez à</p>" },
    { "type": "range", "id": "intro_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Taille intro", "default": 16 },
    { "type": "range", "id": "intro_max_width", "min": 400, "max": 1000, "step": 10, "unit": "px", "label": "Largeur max intro", "default": 720 },
    { "type": "range", "id": "intro_line_height", "min": 120, "max": 220, "step": 5, "unit": "%", "label": "Interligne intro", "default": 170 },
    { "type": "color", "id": "intro_color", "label": "Couleur intro", "default": "#5A5446" },
    { "type": "range", "id": "intro_margin_bottom", "min": 12, "max": 60, "step": 2, "unit": "px", "label": "Marge intro → email", "default": 24 },

    { "type": "header", "content": "Email (mailto)" },
    { "type": "text", "id": "email_text", "label": "Adresse email", "default": "hello@maisoncoeur.fr" },
    { "type": "range", "id": "email_size", "min": 14, "max": 32, "step": 1, "unit": "px", "label": "Taille email", "default": 18 },
    { "type": "color", "id": "email_color", "label": "Couleur email", "default": "#1A1614" },
    { "type": "range", "id": "email_margin_bottom", "min": 8, "max": 40, "step": 2, "unit": "px", "label": "Marge email → délai", "default": 16 },

    { "type": "header", "content": "Note délai de réponse" },
    { "type": "text", "id": "delai_note_text", "label": "Texte délai", "default": "Réponse sous 48 heures ouvrées." },
    { "type": "range", "id": "delai_size", "min": 10, "max": 18, "step": 1, "unit": "px", "label": "Taille délai", "default": 13 },
    { "type": "color", "id": "delai_color", "label": "Couleur délai", "default": "#8C8882" },

    { "type": "header", "content": "Espacement section" },
    { "type": "range", "id": "padding_top", "min": 28, "max": 200, "step": 4, "unit": "px", "label": "Padding haut", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 28, "max": 200, "step": 4, "unit": "px", "label": "Padding bas", "default": 64 }
  ],
  "presets": [
    { "name": "Presse · Contact" }
  ]
}
{% endschema %}
