{{ 'home-vus-dans.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --hvd-padding-top: {{ section.settings.padding_top_desktop | default: 40 }}px;
    --hvd-padding-bottom: {{ section.settings.padding_bottom_desktop | default: 40 }}px;
    --hvd-padding-top-mobile: {{ section.settings.padding_top_mobile | default: 28 }}px;
    --hvd-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: 28 }}px;
    --hvd-logo-height: {{ section.settings.logo_max_height_desktop | default: 32 }}px;
    --hvd-logo-height-mobile: {{ section.settings.logo_max_height_mobile | default: 24 }}px;
    --hvd-logo-gap: {{ section.settings.logos_gap_desktop | default: 48 }}px;
    --hvd-logo-gap-mobile: {{ section.settings.logos_gap_mobile | default: 24 }}px;
    --hvd-eyebrow-gap: {{ section.settings.title_to_logos_gap_desktop | default: 24 }}px;
    --hvd-eyebrow-gap-mobile: {{ section.settings.title_to_logos_gap_mobile | default: 18 }}px;
  }
{%- endstyle -%}

{%- assign logo_indices = '1,2,3,4,5,6' | split: ',' -%}
{%- assign filled_count = 0 -%}
{%- for i in logo_indices -%}
  {%- assign img_key = 'logo_' | append: i | append: '_image' -%}
  {%- assign img = section.settings[img_key] -%}
  {%- if img != blank -%}
    {%- assign filled_count = filled_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<section class="home-vus-dans">
  <div class="home-vus-dans__inner">
    {%- if section.settings.title_eyebrow != blank -%}
      <p class="home-vus-dans__eyebrow">{{ section.settings.title_eyebrow | escape }}</p>
    {%- endif -%}

    {%- if filled_count > 0 -%}
      <ul class="home-vus-dans__logos" role="list">
        {%- for i in logo_indices -%}
          {%- assign img_key = 'logo_' | append: i | append: '_image' -%}
          {%- assign alt_key = 'logo_' | append: i | append: '_alt' -%}
          {%- assign url_key = 'logo_' | append: i | append: '_url' -%}
          {%- assign img = section.settings[img_key] -%}
          {%- assign alt = section.settings[alt_key] -%}
          {%- assign url = section.settings[url_key] -%}

          {%- if img != blank -%}
            <li class="home-vus-dans__logo-item">
              {%- if url != blank -%}
                <a href="{{ url }}" class="home-vus-dans__logo-link" target="_blank" rel="noopener noreferrer">
              {%- endif -%}
                <img
                  class="home-vus-dans__logo"
                  src="{{ img | image_url: width: 400 }}"
                  srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 400 }} 400w, {{ img | image_url: width: 600 }} 600w"
                  sizes="200px"
                  alt="{{ alt | default: img.alt | default: 'Presse' | escape }}"
                  loading="lazy"
                  width="{{ img.width }}"
                  height="{{ img.height }}"
                >
              {%- if url != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home — Vus dans",
  "tag": "section",
  "class": "section section--home-vus-dans",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Titre" },
    {
      "type": "text",
      "id": "title_eyebrow",
      "label": "Eyebrow (CAPS)",
      "default": "VUS DANS"
    },

    { "type": "header", "content": "Logo 1" },
    { "type": "image_picker", "id": "logo_1_image", "label": "Image" },
    { "type": "text", "id": "logo_1_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_1_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Logo 2" },
    { "type": "image_picker", "id": "logo_2_image", "label": "Image" },
    { "type": "text", "id": "logo_2_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_2_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Logo 3" },
    { "type": "image_picker", "id": "logo_3_image", "label": "Image" },
    { "type": "text", "id": "logo_3_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_3_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Logo 4" },
    { "type": "image_picker", "id": "logo_4_image", "label": "Image" },
    { "type": "text", "id": "logo_4_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_4_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Logo 5" },
    { "type": "image_picker", "id": "logo_5_image", "label": "Image" },
    { "type": "text", "id": "logo_5_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_5_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Logo 6" },
    { "type": "image_picker", "id": "logo_6_image", "label": "Image" },
    { "type": "text", "id": "logo_6_alt", "label": "Texte alternatif" },
    { "type": "url", "id": "logo_6_url", "label": "Lien (optionnel)" },

    { "type": "header", "content": "Apparence — logos (Phase 16.1)" },
    { "type": "range", "id": "logo_max_height_desktop", "min": 16, "max": 80, "step": 2, "unit": "px", "default": 32, "label": "Hauteur max logos (desktop)" },
    { "type": "range", "id": "logo_max_height_mobile", "min": 12, "max": 60, "step": 2, "unit": "px", "default": 24, "label": "Hauteur max logos (mobile)" },
    { "type": "range", "id": "logos_gap_desktop", "min": 16, "max": 160, "step": 8, "unit": "px", "default": 48, "label": "Gap entre logos (desktop)" },
    { "type": "range", "id": "logos_gap_mobile", "min": 12, "max": 80, "step": 4, "unit": "px", "default": 24, "label": "Gap entre logos (mobile)" },

    { "type": "header", "content": "Rythme interne (Phase 16.1)" },
    { "type": "range", "id": "title_to_logos_gap_desktop", "min": 12, "max": 80, "step": 4, "unit": "px", "default": 24, "label": "Gap titre → logos (desktop)" },
    { "type": "range", "id": "title_to_logos_gap_mobile", "min": 8, "max": 60, "step": 2, "unit": "px", "default": 18, "label": "Gap titre → logos (mobile)" },

    { "type": "header", "content": "Espacements section (Phase 16.1)" },
    { "type": "range", "id": "padding_top_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 40, "label": "Marge haute desktop" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 40, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_top_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 28, "label": "Marge haute mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 28, "label": "Marge basse mobile" }
  ],
  "presets": [
    { "name": "Home — Vus dans" }
  ]
}
{% endschema %}
