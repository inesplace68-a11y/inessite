{%- comment -%}
  Phase 21 — Page Protection acheteur · Hero
  Clone structurel de livraisons-hero (mêmes defaults, mêmes settings,
  même CSS pattern). Seule la copie change.
{%- endcomment -%}

{{ 'section-protection-hero.css' | asset_url | stylesheet_tag }}

<section
  class="protection-hero"
  style="
    --protection-hero-title-size: {{ section.settings.title_size }}px;
    --protection-hero-title-color: {{ section.settings.title_color }};
    --protection-hero-intro-size: {{ section.settings.intro_size }}px;
    --protection-hero-intro-max-width: {{ section.settings.intro_max_width }}px;
    --protection-hero-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --protection-hero-intro-color: {{ section.settings.intro_color }};
    --protection-hero-intro-margin-top: {{ section.settings.intro_margin_top }}px;
    --protection-hero-padding-top: {{ section.settings.padding_top }}px;
    --protection-hero-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="protection-hero__inner">
    {%- if section.settings.title_text != blank -%}
      <h1 class="protection-hero__title">{{ section.settings.title_text | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <div class="protection-hero__intro rte">{{ section.settings.intro_text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Protection · Hero",
  "tag": "section",
  "class": "shopify-section--protection-hero",
  "settings": [
    { "type": "header", "content": "Titre" },
    { "type": "text", "id": "title_text", "label": "Titre", "default": "Protection acheteur" },
    { "type": "range", "id": "title_size", "min": 40, "max": 140, "step": 2, "unit": "px", "label": "Taille titre", "default": 60 },
    { "type": "color", "id": "title_color", "label": "Couleur titre", "default": "#1A1614" },

    { "type": "header", "content": "Intro" },
    { "type": "richtext", "id": "intro_text", "label": "Texte d'intro", "default": "<p>Chaque acquisition auprès de Maison Coeur est protégée par plusieurs garanties — d'authenticité, de paiement, d'expédition, et de conformité.</p>" },
    { "type": "range", "id": "intro_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Taille intro", "default": 16 },
    { "type": "range", "id": "intro_max_width", "min": 400, "max": 1000, "step": 10, "unit": "px", "label": "Largeur max intro", "default": 720 },
    { "type": "range", "id": "intro_line_height", "min": 120, "max": 250, "step": 5, "unit": "%", "label": "Interligne intro", "default": 170 },
    { "type": "color", "id": "intro_color", "label": "Couleur intro", "default": "#5A5446" },
    { "type": "range", "id": "intro_margin_top", "min": 8, "max": 120, "step": 2, "unit": "px", "label": "Marge titre → intro", "default": 32 },

    { "type": "header", "content": "Espacement section" },
    { "type": "range", "id": "padding_top", "min": 28, "max": 300, "step": 4, "unit": "px", "label": "Padding haut", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 28, "max": 300, "step": 4, "unit": "px", "label": "Padding bas", "default": 48 }
  ],
  "presets": [
    { "name": "Protection · Hero" }
  ]
}
{% endschema %}
