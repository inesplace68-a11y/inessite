{{ 'section-programme-pro-manifeste.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pp-manifeste-padding-top: {{ section.settings.padding_top }}px;
    --pp-manifeste-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pp-manifeste-size: {{ section.settings.manifeste_size }}px;
    --pp-manifeste-max-width: {{ section.settings.manifeste_max_width }}px;
    --pp-manifeste-line-height: {{ section.settings.manifeste_line_height | divided_by: 100.0 }};
    --pp-manifeste-color: {{ section.settings.manifeste_color }};
  }
{%- endstyle -%}

<section class="programme-pro-manifeste">
  <div class="programme-pro-manifeste__inner">
    <div class="programme-pro-manifeste__text">
      {{ section.settings.manifeste_text }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Programme Pro – Manifeste",
  "settings": [
    { "type": "header", "content": "Manifeste" },
    { "type": "richtext", "id": "manifeste_text", "label": "Texte du manifeste", "default": "<p>Travailler avec celles et ceux qui composent les lieux.</p>" },
    { "type": "range", "id": "manifeste_size", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Taille du manifeste", "default": 28 },
    { "type": "range", "id": "manifeste_max_width", "min": 600, "max": 1300, "step": 20, "unit": "px", "label": "Largeur max", "default": 1100 },
    { "type": "range", "id": "manifeste_line_height", "min": 110, "max": 180, "step": 5, "unit": "%", "label": "Interligne", "default": 130 },
    { "type": "color", "id": "manifeste_color", "label": "Couleur du texte", "default": "#1A1A1A" },

    { "type": "header", "content": "Espacements section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding bottom", "default": 60 }
  ],
  "presets": [
    { "name": "Programme Pro – Manifeste" }
  ]
}
{% endschema %}
