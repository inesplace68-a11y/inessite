{%- style -%}
  #shopify-section-{{ section.id }} .mc-reassurance {
    --mcr-pt: {{ section.settings.padding_top_desktop | default: 36 }}px;
    --mcr-pb: {{ section.settings.padding_bottom_desktop | default: 36 }}px;
    --mcr-pt-mobile: {{ section.settings.padding_top_mobile | default: 28 }}px;
    --mcr-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 28 }}px;
    --mcr-cell-pv: {{ section.settings.cell_padding_vertical | default: 24 }}px;
    --mcr-cell-ph: {{ section.settings.cell_padding_horizontal | default: 16 }}px;
    --mcr-icon-to-label: {{ section.settings.icon_to_label_gap | default: 14 }}px;
    padding-top: var(--mcr-pt);
    padding-bottom: var(--mcr-pb);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-reassurance {
      padding-top: var(--mcr-pt-mobile);
      padding-bottom: var(--mcr-pb-mobile);
    }
  }
  #shopify-section-{{ section.id }} .mc-reassurance__item {
    padding: var(--mcr-cell-pv) var(--mcr-cell-ph);
  }
  #shopify-section-{{ section.id }} .mc-reassurance__icon {
    margin-bottom: var(--mcr-icon-to-label);
  }
{%- endstyle -%}

<section class="mc-reassurance">
  <div class="mc-container">
    <div class="mc-reassurance__grid">
      {%- for block in section.blocks -%}
        <div class="mc-reassurance__item" {{ block.shopify_attributes }}>
          <div class="mc-reassurance__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="3" width="15" height="13" rx="0.5"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              {%- when 'package' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/>
                </svg>
              {%- when 'award' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="0.5" fill="currentColor"/>
                </svg>
            {%- endcase -%}
          </div>

          {%- if block.settings.title != blank -%}
            <p class="mc-reassurance__title">{{ block.settings.title }}</p>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="mc-reassurance__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Réassurance",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Espacements section (Phase 16.1)" },
    { "type": "range", "id": "padding_top_desktop", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Marge haute desktop" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_top_mobile", "min": 12, "max": 80, "step": 4, "unit": "px", "default": 28, "label": "Marge haute mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 12, "max": 80, "step": 4, "unit": "px", "default": 28, "label": "Marge basse mobile" },

    { "type": "header", "content": "Rythme interne (Phase 16.1)" },
    { "type": "range", "id": "cell_padding_vertical", "min": 8, "max": 60, "step": 4, "unit": "px", "default": 24, "label": "Padding vertical cellule" },
    { "type": "range", "id": "cell_padding_horizontal", "min": 8, "max": 40, "step": 4, "unit": "px", "default": 16, "label": "Padding horizontal cellule" },
    { "type": "range", "id": "icon_to_label_gap", "min": 6, "max": 40, "step": 2, "unit": "px", "default": 14, "label": "Gap icône → label" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "truck",   "label": "Camion / Livraison" },
            { "value": "package", "label": "Colis / Emballage" },
            { "value": "shield",  "label": "Bouclier / Sécurité" },
            { "value": "heart",   "label": "Cœur / Passion" },
            { "value": "star",    "label": "Étoile / Qualité" },
            { "value": "clock",   "label": "Horloge / Délais" },
            { "value": "refresh", "label": "Retour / Échange" },
            { "value": "award",   "label": "Trophée / Excellence" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Livraison sécurisée"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Emballage soigné, livraison assurée en France et en Europe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Réassurance",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "title": "Livraison offerte",
            "text": "Dès 150 € d'achat en France métropolitaine"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "title": "Paiement sécurisé",
            "text": "Transactions chiffrées SSL — Visa, Mastercard, PayPal"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "refresh",
            "title": "Retours faciles",
            "text": "14 jours pour changer d'avis, sans justification"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "award",
            "title": "Pièces authentifiées",
            "text": "Chaque objet est sélectionné et expertisé par notre équipe"
          }
        }
      ]
    }
  ]
}
{% endschema %}
