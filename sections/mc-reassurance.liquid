{%- style -%}
  #shopify-section-{{ section.id }} .mc-reassurance {
    --mcr-pt: {{ section.settings.padding_top_desktop | default: 24 }}px;
    --mcr-pb: {{ section.settings.padding_bottom_desktop | default: 24 }}px;
    --mcr-pt-mobile: {{ section.settings.padding_top_mobile | default: 16 }}px;
    --mcr-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 16 }}px;
    --mcr-icon-to-label: {{ section.settings.icon_to_label_gap | default: 10 }}px;
    --mc-trust-sep-inset: {{ section.settings.separator_vertical_inset | default: 0 }}px;
    /* Phase 16.6 — cases carrées mobile (utilisés uniquement dans la media query ≤749px) */
    --mcr-text-inset-mobile: {{ section.settings.text_inset_mobile | default: 12 }}px;
    --mcr-cell-vpad-mobile: {{ section.settings.cell_vpad_mobile | default: 10 }}px;
    padding-top: var(--mcr-pt);
    padding-bottom: var(--mcr-pb);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-reassurance {
      padding-top: var(--mcr-pt-mobile);
      padding-bottom: var(--mcr-pb-mobile);
    }
  }
  /* Phase 16.2 — neutralise le hardcoded vertical `padding: 44px 28px` de
     .mc-reassurance__item dans maison-coeur.css. Seul le padding horizontal
     28px est préservé. La respiration verticale est désormais contrôlée
     uniquement par les sliders Section padding + icon-to-label. */
  #shopify-section-{{ section.id }} .mc-reassurance__item {
    padding-top: 0;
    padding-bottom: 0;
    position: relative;
    border-right: none !important;
  }
  #shopify-section-{{ section.id }} .mc-reassurance__icon {
    margin-bottom: var(--mcr-icon-to-label);
  }
  /* Phase 16.4 — séparateurs verticaux en ligne pleine : ::before en absolute
     positionné sur le bord droit de chaque cellule, avec top/bottom étendus
     dans le padding de la section via offsets négatifs. inset 0 par défaut
     → la ligne touche les bords haut et bas de la bande beige. inset > 0
     → retrait progressif de chaque extrémité. */
  #shopify-section-{{ section.id }} .mc-reassurance__item:not(:last-child)::before {
    content: '';
    position: absolute;
    right: 0;
    top: calc(-1 * var(--mcr-pt) + var(--mc-trust-sep-inset));
    bottom: calc(-1 * var(--mcr-pb) + var(--mc-trust-sep-inset));
    width: 1px;
    background-color: var(--mc-border);
    pointer-events: none;
  }
  @media (max-width: 749px) {
    /* Phase 16.6 — grille 2×2 : 4 cases CARRÉES (aspect-ratio 1:1), contenu
       aligné PAR LE HAUT, zone de texte élargie (retrait latéral réglable),
       croix de filets continue collée aux bords. Override mobile uniquement ;
       desktop strictement inchangé. */

    /* Cases carrées : la hauteur suit la largeur de colonne. Quand la
       description la plus longue dépasse le carré (petits écrans ≤~375px), la
       rangée s'étire légèrement — align-self:stretch (défaut) égalise la paire —
       au lieu de tronquer le texte ou de réduire la police. */
    #shopify-section-{{ section.id }} .mc-reassurance__item {
      aspect-ratio: 1 / 1;
      justify-content: flex-start;                 /* contenu calé en haut */
      padding-left: var(--mcr-text-inset-mobile);  /* zone de texte élargie */
      padding-right: var(--mcr-text-inset-mobile);
      padding-top: var(--mcr-cell-vpad-mobile);    /* respiration interne haut/bas */
      padding-bottom: var(--mcr-cell-vpad-mobile);
    }

    /* Filet vertical central, continu du haut au bas de la bande beige :
       case 1 (rangée haute) monte jusqu'au bord haut ; case 3 (rangée basse)
       descend jusqu'au bord bas ; les deux se rejoignent à la frontière des
       rangées. (left/right des pseudos = bord visuel de la case, non affecté
       par le retrait de texte.) */
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(1)::before {
      top: calc(-1 * var(--mcr-pt-mobile));
      bottom: 0;
    }
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(3)::before {
      top: 0;
      bottom: calc(-1 * var(--mcr-pb-mobile));
    }
    /* Case 2 = dernière de la rangée haute : pas de filet vertical à droite. */
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(2)::before {
      display: none;
    }

    /* Filet horizontal central, pleine largeur jusqu'aux bords de la bande :
       posé sur le bord bas des 2 cases de la rangée haute → il suit toujours la
       frontière des rangées (même si une rangée s'étire), exactement là où se
       rejoignent les deux moitiés du filet vertical. Remplace les border-bottom
       des cases. Marges négatives = miroir du padding .mc-container mobile (20px). */
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(1),
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(2) {
      border-bottom: none;
    }
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(1)::after,
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(2)::after {
      content: '';
      position: absolute;
      bottom: 0;
      height: 1px;
      background-color: var(--mc-border);
      pointer-events: none;
    }
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(1)::after {
      left: -20px;   /* du bord gauche de la bande jusqu'au filet vertical central */
      right: 0;
    }
    #shopify-section-{{ section.id }} .mc-reassurance__item:nth-child(2)::after {
      left: 0;       /* du filet vertical central jusqu'au bord droit de la bande */
      right: -20px;
    }
  }
{%- endstyle -%}

<section class="mc-reassurance">
  <div class="mc-container">
    <div class="mc-reassurance__grid">
      {%- for block in section.blocks -%}
        <div class="mc-reassurance__item" {{ block.shopify_attributes }}>
          <div class="mc-reassurance__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="3" width="15" height="13" rx="0.5"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              {%- when 'package' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/>
                </svg>
              {%- when 'award' -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="0.5" fill="currentColor"/>
                </svg>
            {%- endcase -%}
          </div>

          {%- if block.settings.title != blank -%}
            <p class="mc-reassurance__title">{{ block.settings.title }}</p>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="mc-reassurance__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Réassurance",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Espacements section (Phase 16.2)" },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24, "label": "Marge haute desktop" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 16, "label": "Marge haute mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 16, "label": "Marge basse mobile" },

    { "type": "header", "content": "Rythme vertical interne (Phase 16.2)" },
    { "type": "range", "id": "icon_to_label_gap", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 10, "label": "Gap vertical icône → label" },

    { "type": "header", "content": "Séparateurs verticaux (Phase 16.4)" },
    { "type": "range", "id": "separator_vertical_inset", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 0, "label": "Retrait vertical des séparateurs", "info": "0 = ligne pleine touchant les bords haut/bas de la bande beige. Augmenter pour rétracter symétriquement de chaque extrémité." },

    { "type": "header", "content": "Cases carrées (Phase 16.6, mobile)" },
    { "type": "range", "id": "text_inset_mobile", "min": 0, "max": 28, "step": 1, "unit": "px", "default": 12, "label": "Retrait latéral texte", "info": "Mobile uniquement. Plus petit = zone de texte plus large (descriptions sur moins de lignes). Garder une marge avec le filet central." },
    { "type": "range", "id": "cell_vpad_mobile", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 10, "label": "Marge interne haut/bas", "info": "Mobile uniquement. Respiration verticale interne des cases ; évite que le contenu touche les filets." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "truck",   "label": "Camion / Livraison" },
            { "value": "package", "label": "Colis / Emballage" },
            { "value": "shield",  "label": "Bouclier / Sécurité" },
            { "value": "heart",   "label": "Cœur / Passion" },
            { "value": "star",    "label": "Étoile / Qualité" },
            { "value": "clock",   "label": "Horloge / Délais" },
            { "value": "refresh", "label": "Retour / Échange" },
            { "value": "award",   "label": "Trophée / Excellence" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Livraison sécurisée"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Emballage soigné, livraison assurée en France et en Europe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Réassurance",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "title": "Livraison offerte",
            "text": "Dès 150 € d'achat en France métropolitaine"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "title": "Paiement sécurisé",
            "text": "Transactions chiffrées SSL — Visa, Mastercard, PayPal"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "refresh",
            "title": "Retours faciles",
            "text": "14 jours pour changer d'avis, sans justification"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "award",
            "title": "Pièces authentifiées",
            "text": "Chaque objet est sélectionné et expertisé par notre équipe"
          }
        }
      ]
    }
  ]
}
{% endschema %}
