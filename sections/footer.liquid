{% comment %}theme-check-disable UndefinedObject{% endcomment %}

<footer class="mc-footer">
  <div class="mc-footer-inner">

    <!-- ZONE 1 : Logo -->
    <div class="mc-fz mc-fz--logo">
      <a href="{{ routes.root_url }}" class="mc-fz-logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.footer_logo != blank -%}
          <img
            src="{{ section.settings.footer_logo | image_url: width: section.settings.footer_logo_width }}"
            alt="{{ section.settings.footer_logo.alt | default: shop.name }}"
            width="{{ section.settings.footer_logo_width }}"
            loading="lazy"
            class="mc-fz-logo-img"
          >
        {%- else -%}
          <span class="mc-fz-brand">
            <span class="mc-fz-brand__name">MAISON COEUR</span>
            <span class="mc-fz-brand__tagline">GALERIE D'ART — PARIS</span>
          </span>
        {%- endif -%}
      </a>
    </div>

    <!-- ZONES 2-4 : Colonnes de liens -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="mc-fz mc-fz--col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="mc-fz-col__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="mc-fz-col__links">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="mc-fz-col__link{% if link.active %} is-active{% endif %}">
                    {{- link.title | escape -}}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    <!-- ZONE 5 : Newsletter + réseaux sociaux -->
    <div class="mc-fz mc-fz--nl">

      {%- if section.settings.newsletter_heading != blank -%}
        <p class="mc-fz-nl__heading">{{ section.settings.newsletter_heading }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'ContactFooter', class: 'mc-fz-nl__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="mc-fz-nl__field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="mc-fz-nl__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="ContactFooter-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="ContactFooter-success"
            {% endif %}
            placeholder="Votre adresse email"
            required
          >
          {%- if form.errors -%}
            <small class="mc-fz-nl__error" id="ContactFooter-error">
              {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        </div>
        <button type="submit" class="mc-fz-nl__btn" name="commit">S'ABONNER</button>
        {%- if form.posted_successfully? -%}
          <p class="mc-fz-nl__success" id="ContactFooter-success" tabindex="-1" autofocus>
            {{- 'newsletter.success' | t }}
          </p>
        {%- endif -%}
      {%- endform -%}

      <!-- Réseaux sociaux -->
      {%- liquid
        assign has_ig = false
        assign has_pi = false
        if settings.social_instagram_link != blank
          assign has_ig = true
        endif
        if settings.social_pinterest_link != blank
          assign has_pi = true
        endif
      -%}
      {%- if has_ig or has_pi -%}
        <div class="mc-fz-nl__social">
          {%- if has_ig -%}
            <a href="{{ settings.social_instagram_link }}" class="mc-fz-nl__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <span class="mc-fz-nl__social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                  <circle cx="12" cy="12" r="11.5" stroke="currentColor" stroke-width="0.8"/>
                  <rect x="7" y="7" width="10" height="10" rx="3" stroke="currentColor" stroke-width="0.9" fill="none"/>
                  <circle cx="12" cy="12" r="2.8" stroke="currentColor" stroke-width="0.9" fill="none"/>
                  <circle cx="15.5" cy="8.5" r="0.7" fill="currentColor"/>
                </svg>
              </span>
              <span>INSTAGRAM</span>
            </a>
          {%- endif -%}
          {%- if has_pi -%}
            <a href="{{ settings.social_pinterest_link }}" class="mc-fz-nl__social-link" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
              <span class="mc-fz-nl__social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                  <circle cx="12" cy="12" r="11.5" stroke="currentColor" stroke-width="0.8"/>
                  <path d="M12 6.5c-3.03 0-5.5 2.47-5.5 5.5 0 2.33 1.42 4.33 3.45 5.18-.05-.43-.09-1.08.02-1.55.1-.42.68-2.9.68-2.9s-.17-.35-.17-.87c0-.81.47-1.42 1.06-1.42.5 0 .74.37.74.82 0 .5-.32 1.25-.48 1.94-.14.58.29 1.05.86 1.05 1.03 0 1.72-1.32 1.72-2.88 0-1.18-.8-2.01-1.93-2.01-1.32 0-2.09.99-2.09 2.01 0 .4.15.82.34 1.05.04.04.04.08.03.13-.03.13-.11.43-.12.5-.02.08-.07.1-.15.06-.68-.31-1.1-1.3-1.1-2.09 0-1.71 1.24-3.27 3.58-3.27 1.88 0 3.34 1.34 3.34 3.12 0 1.86-1.17 3.36-2.8 3.36-.55 0-1.06-.28-1.24-.62l-.33 1.27c-.12.47-.45 1.06-.68 1.41.51.16 1.04.24 1.6.24 3.04 0 5.5-2.47 5.5-5.5s-2.46-5.5-5.5-5.5z" fill="currentColor"/>
                </svg>
              </span>
              <span>PINTEREST</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  <!-- BARRE DU BAS -->
  <div class="mc-footer-bar">
    <div class="mc-footer-bar-inner">
      <p class="mc-footer-bar-copy">&copy; {{ 'now' | date: '%Y' }} MAISON COEUR — PARIS</p>
      {%- if section.settings.payment_enable -%}
        <ul class="list list-payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="list-payment__item">
              {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Colonne de liens",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre de la colonne",
          "default": "Liens"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo du footer"
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 140
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "default": "ENTOUREZ-VOUS D'OBJETS QUI VOUS INSPIRENT.",
      "label": "Titre newsletter"
    },
    {
      "type": "header",
      "content": "Bas de page"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Afficher les moyens de paiement"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "À PROPOS",
          "menu": "footer-a-propos"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "CATÉGORIES",
          "menu": "footer-categories"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "SERVICE CLIENT",
          "menu": "footer-service-client"
        }
      }
    ]
  }
}
{% endschema %}
