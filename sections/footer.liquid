{% comment %}theme-check-disable UndefinedObject{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} .mc-footer-inner {
    padding-top: {{ section.settings.footer_top_padding | default: 48 }}px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-footer-inner {
      padding-top: {{ section.settings.footer_top_padding_mobile | default: 32 }}px;
    }
  }
  /* Phase 16.43 — épaisseur de la bande copyright : padding-top/bottom
     du conteneur interne .mc-footer-bar-inner, piloté par
     footer_last_row_inner_padding (anciennement footer_bottom_padding_y,
     renommé pour clarifier qu'il s'agit du rembourrage interne et non
     d'une marge externe). Va à 0 pour compresser la bande au maximum. */
  #shopify-section-{{ section.id }} .mc-footer-bar-inner {
    padding-top: {{ section.settings.footer_last_row_inner_padding | default: 0 }}px !important;
    padding-bottom: {{ section.settings.footer_last_row_inner_padding | default: 0 }}px !important;
  }
  /* Phase 16.3 — UN setting consolidé `footer_localization_color` pilote la
     couleur du sélecteur pays/devise (texte + chevron SVG) ET du copyright +
     mentions légales. Les icônes social (Instagram, Pinterest) sont
     volontairement HORS scope (elles restent rendues via .mc-footer color: #fff
     du registre maison-coeur.css). */
  #shopify-section-{{ section.id }} .mc-footer-bar-copy,
  #shopify-section-{{ section.id }} .mc-footer-bar-legal a,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button > span,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select > span {
    font-size: {{ section.settings.footer_bottom_font_size | default: 12 }}px !important;
    color: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
  }
  #shopify-section-{{ section.id }} .mc-footer-bar svg,
  #shopify-section-{{ section.id }} .mc-footer-bar svg path {
    color: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
  }
  #shopify-section-{{ section.id }} .mc-footer-bar svg [fill]:not([fill="none"]) {
    fill: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
  }
  #shopify-section-{{ section.id }} .mc-footer-bar svg [stroke]:not([stroke="none"]) {
    stroke: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
  }
  /* Hover : on garde la couleur consolidée pleine opacité (au lieu du rgba 0.7
     hardcoded de maison-coeur.css) pour ne pas avoir d'effet de "passe en noir". */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button:hover,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select:hover,
  #shopify-section-{{ section.id }} .mc-footer-bar-legal a:hover {
    color: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
    opacity: 0.75;
  }
  /* Phase 16.3.3 — catch-all border/outline/box-shadow sur tout le sélecteur
     pays/devise pour neutraliser tout reliquat de noir hérité (focus-visible
     box-shadow Dawn, outline UA `<button>`, border-color de pseudo-éléments,
     etc.). currentColor suit automatiquement footer_localization_color. */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization *,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization *::before,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization *::after {
    border-color: currentColor !important;
    outline-color: currentColor !important;
  }
  /* Phase 16.35 — Zéro bordure visible : le sélecteur "FRANCE · EUR €"
     se fond complètement dans le fond brun du footer. Neutralise border,
     outline, box-shadow et background (Dawn pose un bg blanc sur le
     bouton via .disclosure__button.localization-form__select). */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button:hover,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button:focus,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button[aria-expanded='true'],
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select:hover,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select:focus {
    text-decoration: none !important;
    border: 0 !important;
    outline: none !important;
    box-shadow: none !important;
    background: transparent !important;
  }
  /* Focus clavier uniquement (Tab) — marqueur d'accessibilité discret,
     pas visible au clic souris. */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button:focus-visible,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select:focus-visible {
    text-decoration: none !important;
    border: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    outline: 1px dotted currentColor !important;
    outline-offset: 2px !important;
  }
  /* Dropdown popup quand le sélecteur est ouvert — border noir Dawn par défaut */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__list-wrapper {
    border-color: {{ section.settings.footer_localization_color | default: '#F5F0E8' }} !important;
  }
  /* Phase 16.39 — câblage padding vertical du sélecteur pays/devise.
     Phase 16.40 — padding horizontal forcé à 0 en dur (texte collé aux
     bords du sélecteur, plus de setting customizer). */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select {
    padding-top: {{ section.settings.footer_bottom_selector_padding_y | default: 6 }}px !important;
    padding-bottom: {{ section.settings.footer_bottom_selector_padding_y | default: 6 }}px !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
  #shopify-section-{{ section.id }} .mc-fz-nl__btn {
    height: {{ section.settings.newsletter_btn_height | default: 40 }}px;
    line-height: 1;
    padding-top: 0;
    padding-bottom: 0;
    padding-left: {{ section.settings.newsletter_btn_padding | default: 12 }}px;
    padding-right: {{ section.settings.newsletter_btn_padding | default: 12 }}px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  /* Phase 16.42 — BRUTE-FORCE suppression définitive du rectangle visible
     autour de "FRANCE · EUR €". Root cause identifiée : Dawn dessine la
     bordure via un box-shadow ring sur le pseudo-élément
     .localization-form__select:after (base.css l.1611-1624) — NEUTRALISÉ
     par les phases 16.34/35/37 sur le bouton mais PAS sur son ::after.
     De plus .disclosure__button.localization-form__select pose un
     background opaque (color-background) qui crée un rectangle clair.
     On exclut explicitement .disclosure__list-wrapper (dropdown popup
     ouvert) qui doit conserver sa bordure. */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-selector,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure::before,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure::after,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button::before,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button::after,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select::before,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select::after,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-selector::before,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-selector::after {
    border: 0 !important;
    border-color: transparent !important;
    border-style: none !important;
    border-width: 0 !important;
    outline: 0 !important;
    outline-color: transparent !important;
    outline-style: none !important;
    outline-width: 0 !important;
    box-shadow: none !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }
  /* Phase 16.43 — chevron sélecteur pays/devise repositionné en flux
     flex normal (annule position: absolute de Dawn dans
     component-localization-form.css l.79-85). Cause initiale du
     chevauchement : Phase 16.40 a retiré le padding-right du bouton
     qui réservait l'espace où le chevron en position absolute venait
     se loger. Solution : laisser le SVG s'inscrire dans le
     display: inline-flex; gap: 6px déjà appliqué par
     maison-coeur.css:873-875 → écart de 6px exact entre "EUR €" et
     le chevron, sans réintroduction de padding (qui raviverait la
     box visible neutralisée Phase 16.42). */
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button .icon-caret,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select .icon-caret,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .disclosure__button svg,
  #shopify-section-{{ section.id }} .mc-footer-bar-localization .localization-form__select svg {
    position: static !important;
    right: auto !important;
    top: auto !important;
    margin: 0 !important;
  }
{%- endstyle -%}

<footer class="mc-footer">
  <div class="mc-footer-inner">

    {%- comment -%} ZONE 1 : Logo {%- endcomment -%}
    <div class="mc-fz mc-fz--logo">
      <a href="{{ routes.root_url }}" class="mc-fz-logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.footer_logo != blank -%}
          <img
            src="{{ section.settings.footer_logo | image_url: width: section.settings.footer_logo_width }}"
            alt="{{ section.settings.footer_logo.alt | default: shop.name }}"
            width="{{ section.settings.footer_logo_width }}"
            loading="lazy"
            class="mc-fz-logo-img"
          >
        {%- else -%}
          <span class="mc-fz-brand">
            <span class="mc-fz-brand__name">MAISON COEUR</span>
            {%- if section.settings.brand_tagline != blank -%}
              <span class="mc-fz-brand__tagline">{{ section.settings.brand_tagline }}</span>
            {%- endif -%}
          </span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} ZONE 2 : À PROPOS — repliable en accordéon mobile uniquement {%- endcomment -%}
    <div class="mc-fz mc-fz--col mc-fz--col-first">
      <h2 class="mc-fz-col__heading">
        <button type="button" class="mc-fz-col__toggle" aria-expanded="false" aria-controls="mc-fz-panel-{{ section.id }}-apropos">
          <span class="mc-fz-col__toggle-label">À PROPOS</span>
          <span class="mc-fz-col__chevron" aria-hidden="true"></span>
        </button>
      </h2>
      <ul class="mc-fz-col__links" id="mc-fz-panel-{{ section.id }}-apropos">
        {%- for link in linklists['footer-a-propos'].links -%}
          <li><a href="{{ link.url }}" class="mc-fz-col__link">{{ link.title | upcase }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ZONE 3 : CATÉGORIES — repliable en accordéon mobile uniquement {%- endcomment -%}
    <div class="mc-fz mc-fz--col">
      <h2 class="mc-fz-col__heading">
        <button type="button" class="mc-fz-col__toggle" aria-expanded="false" aria-controls="mc-fz-panel-{{ section.id }}-categories">
          <span class="mc-fz-col__toggle-label">CATÉGORIES</span>
          <span class="mc-fz-col__chevron" aria-hidden="true"></span>
        </button>
      </h2>
      <ul class="mc-fz-col__links" id="mc-fz-panel-{{ section.id }}-categories">
        {%- for link in linklists['footer-categories'].links -%}
          <li><a href="{{ link.url }}" class="mc-fz-col__link">{{ link.title | upcase }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ZONE 4 : SERVICE CLIENT — repliable en accordéon mobile uniquement {%- endcomment -%}
    <div class="mc-fz mc-fz--col">
      <h2 class="mc-fz-col__heading">
        <button type="button" class="mc-fz-col__toggle" aria-expanded="false" aria-controls="mc-fz-panel-{{ section.id }}-service">
          <span class="mc-fz-col__toggle-label">SERVICE CLIENT</span>
          <span class="mc-fz-col__chevron" aria-hidden="true"></span>
        </button>
      </h2>
      <ul class="mc-fz-col__links" id="mc-fz-panel-{{ section.id }}-service">
        {%- for link in linklists['footer-service-client'].links -%}
          <li><a href="{{ link.url }}" class="mc-fz-col__link">{{ link.title | upcase }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ZONE 5 : Newsletter + réseaux sociaux {%- endcomment -%}
    <div class="mc-fz mc-fz--nl">

      {%- if section.settings.newsletter_heading != blank -%}
        <p class="mc-fz-nl__heading">{{ section.settings.newsletter_heading }}</p>
      {%- endif -%}

      {%- if section.settings.newsletter_subtext != blank -%}
        <p class="mc-fz-nl__sub">{{ section.settings.newsletter_subtext }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'ContactFooter', class: 'mc-fz-nl__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="mc-fz-nl__field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="mc-fz-nl__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="ContactFooter-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="ContactFooter-success"
            {% endif %}
            placeholder="Votre adresse email"
            required
          >
          {%- if form.errors -%}
            <small class="mc-fz-nl__error" id="ContactFooter-error">
              {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        </div>
        <button type="submit" class="mc-fz-nl__btn" name="commit">S'ABONNER</button>
        {%- if form.posted_successfully? -%}
          <p class="mc-fz-nl__success" id="ContactFooter-success" tabindex="-1" autofocus>
            {{- 'newsletter.success' | t }}
          </p>
        {%- endif -%}
      {%- endform -%}

      {%- liquid
        assign has_ig = false
        assign has_pi = false
        if settings.social_instagram_link != blank
          assign has_ig = true
        endif
        if settings.social_pinterest_link != blank
          assign has_pi = true
        endif
      -%}
      {%- if has_ig or has_pi -%}
        <div class="mc-fz-nl__social">
          {%- if has_ig -%}
            <a href="{{ settings.social_instagram_link }}" class="mc-fz-nl__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <span class="mc-fz-nl__social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                  <circle cx="12" cy="12" r="11.5" stroke="currentColor" stroke-width="0.8"/>
                  <rect x="7" y="7" width="10" height="10" rx="3" stroke="currentColor" stroke-width="0.9" fill="none"/>
                  <circle cx="12" cy="12" r="2.8" stroke="currentColor" stroke-width="0.9" fill="none"/>
                  <circle cx="15.5" cy="8.5" r="0.7" fill="currentColor"/>
                </svg>
              </span>
              <span>INSTAGRAM</span>
            </a>
          {%- endif -%}
          {%- if has_pi -%}
            <a href="{{ settings.social_pinterest_link }}" class="mc-fz-nl__social-link" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
              <span class="mc-fz-nl__social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                  <circle cx="12" cy="12" r="11.5" stroke="currentColor" stroke-width="0.8"/>
                  <path d="M12 6.5c-3.03 0-5.5 2.47-5.5 5.5 0 2.33 1.42 4.33 3.45 5.18-.05-.43-.09-1.08.02-1.55.1-.42.68-2.9.68-2.9s-.17-.35-.17-.87c0-.81.47-1.42 1.06-1.42.5 0 .74.37.74.82 0 .5-.32 1.25-.48 1.94-.14.58.29 1.05.86 1.05 1.03 0 1.72-1.32 1.72-2.88 0-1.18-.8-2.01-1.93-2.01-1.32 0-2.09.99-2.09 2.01 0 .4.15.82.34 1.05.04.04.04.08.03.13-.03.13-.11.43-.12.5-.02.08-.07.1-.15.06-.68-.31-1.1-1.3-1.1-2.09 0-1.71 1.24-3.27 3.58-3.27 1.88 0 3.34 1.34 3.34 3.12 0 1.86-1.17 3.36-2.8 3.36-.55 0-1.06-.28-1.24-.62l-.33 1.27c-.12.47-.45 1.06-.68 1.41.51.16 1.04.24 1.6.24 3.04 0 5.5-2.47 5.5-5.5s-2.46-5.5-5.5-5.5z" fill="currentColor"/>
                </svg>
              </span>
              <span>PINTEREST</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} BARRE DU BAS — 3 blocs sur une seule ligne {%- endcomment -%}
  <div class="mc-footer-bar">
    <div class="mc-footer-bar-inner">

      {%- comment -%} Sélecteurs pays/devise + langue (natif Shopify) — gauche.
           Phase 16.38 : conditionné par le toggle `hide_localization_selector`
           pour permettre un masquage total sans laisser de trace dans le DOM. {%- endcomment -%}
      {%- unless section.settings.hide_localization_selector -%}
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          <div class="mc-footer-bar-localization">
            {%- if localization.available_countries.size > 1 -%}
              <localization-form class="mc-footer-bar-localization__form" data-prevent-hide>
                {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                    {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
            {%- if localization.available_languages.size > 1 -%}
              <localization-form class="mc-footer-bar-localization__form" data-prevent-hide>
                {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                    {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endunless -%}

      <p class="mc-footer-bar-copy">&copy; {{ 'now' | date: '%Y' }} Maison Coeur — Tous droits réservés.</p>

      <ul class="mc-footer-bar-legal" role="list">
        <li><a href="/policies/privacy-policy">POLITIQUE DE CONFIDENTIALITÉ</a></li>
        <li><a href="/policies/terms-of-service">CGU</a></li>
        <li><a href="/pages/mentions-legales">MENTIONS LÉGALES</a></li>
      </ul>
    </div>
  </div>

</footer>

{%- comment -%}
  Accordéon footer — MOBILE uniquement (le CSS de repli ne s'active que
  sous .mc-fz-acc--on + @media max-width:767px ; desktop strictement intouché).
  Le JS ne fait qu'ajouter la classe d'amélioration et brancher le tap.
  Sans JS (ou réglage désactivé) → footer rendu comme aujourd'hui (listes ouvertes).
{%- endcomment -%}
{%- if section.settings.footer_mobile_accordion -%}
  <script>
    (function () {
      var root = document.getElementById('shopify-section-{{ section.id }}');
      if (!root) return;
      var footer = root.querySelector('.mc-footer');
      if (!footer) return;
      footer.classList.add('mc-fz-acc--on');
      var toggles = root.querySelectorAll('.mc-fz-col__toggle');
      Array.prototype.forEach.call(toggles, function (btn) {
        btn.addEventListener('click', function () {
          var col = btn.closest('.mc-fz--col');
          if (!col) return;
          var open = col.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo du footer"
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "min": 60,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 380
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Tagline (fallback sans logo)",
      "info": "Affichée sous MAISON COEUR uniquement si aucun logo n'est uploadé. Modifiable ou supprimable dans le Customizer.",
      "default": "COLLECTIBLE INTERIORS · PARIS"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "default": "ICI, LES COUPS DE COEUR DURENT POUR TOUJOURS.",
      "label": "Titre newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "default": "Une sélection rare, livrée une fois par mois.",
      "label": "Sous-texte newsletter"
    },
    {
      "type": "header",
      "content": "Espacements footer"
    },
    {
      "type": "range",
      "id": "footer_top_padding",
      "label": "Marge supérieure footer (desktop)",
      "info": "Phase 13/16.2 — espace au-dessus du logo footer. Default 48px compact.",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "footer_top_padding_mobile",
      "label": "Marge supérieure footer (mobile)",
      "info": "Phase 16.2 — espace au-dessus du logo footer en mobile.",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
