{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- if section.settings.image_height == 'adapt' and section.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before,
      #Banner-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before {
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- style -%}
  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }

  @media screen and (min-width: 750px) {
    #Banner-{{ section.id }}:not(.banner--adapt) {
      min-height: {{ section.settings.image_height_desktop_custom }}rem;
    }
  }

  {%- if section.settings.nav_hero_gap != blank -%}
  #Banner-{{ section.id }} {
    margin-top: calc({{ section.settings.nav_hero_gap }}px - 18px);
  }
  {%- endif -%}

  #Banner-{{ section.id }} .banner__media > img,
  #Banner-{{ section.id }} .banner__media > video,
  #Banner-{{ section.id }} .banner__media .hero-video {
    object-position: {{ section.settings.hero_image_position_x }}% {{ section.settings.hero_image_position_y }}%;
  }

  {%- liquid
    assign hero_title_size = section.settings.hero_title_size | default: 64
    assign hero_title_min = hero_title_size | times: 60 | divided_by: 100
    if hero_title_min < 32
      assign hero_title_min = 32
    endif
    assign hero_title_mobile = hero_title_size | times: 70 | divided_by: 100
    if hero_title_mobile < 32
      assign hero_title_mobile = 32
    endif
  -%}
  #Banner-{{ section.id }} .banner__heading,
  #Banner-{{ section.id }} .banner__heading.inline-richtext {
    font-size: clamp({{ hero_title_min }}px, 5vw, {{ hero_title_size }}px) !important;
  }
  @media screen and (max-width: 749px) {
    #Banner-{{ section.id }} .banner__heading,
    #Banner-{{ section.id }} .banner__heading.inline-richtext {
      font-size: clamp(32px, 7vw, {{ hero_title_mobile }}px) !important;
    }
  }

  {%- liquid
    assign btn_rest_r = section.settings.hero_button_color_rest | color_extract: 'red'
    assign btn_rest_g = section.settings.hero_button_color_rest | color_extract: 'green'
    assign btn_rest_b = section.settings.hero_button_color_rest | color_extract: 'blue'
    assign btn_rest_a = section.settings.hero_button_opacity_rest | default: 1

    assign btn_bg_h_r = section.settings.hero_button_bg_hover | color_extract: 'red'
    assign btn_bg_h_g = section.settings.hero_button_bg_hover | color_extract: 'green'
    assign btn_bg_h_b = section.settings.hero_button_bg_hover | color_extract: 'blue'

    assign btn_tx_h_r = section.settings.hero_button_color_hover | color_extract: 'red'
    assign btn_tx_h_g = section.settings.hero_button_color_hover | color_extract: 'green'
    assign btn_tx_h_b = section.settings.hero_button_color_hover | color_extract: 'blue'
    assign btn_hover_a = section.settings.hero_button_opacity_hover | default: 1
  -%}
  #Banner-{{ section.id }} {
    --mc-hero-btn-rest-rgb: {{ btn_rest_r }}, {{ btn_rest_g }}, {{ btn_rest_b }};
    --mc-hero-btn-rest-alpha: {{ btn_rest_a }};
    --mc-hero-btn-hover-bg-rgb: {{ btn_bg_h_r }}, {{ btn_bg_h_g }}, {{ btn_bg_h_b }};
    --mc-hero-btn-hover-color-rgb: {{ btn_tx_h_r }}, {{ btn_tx_h_g }}, {{ btn_tx_h_b }};
    --mc-hero-btn-hover-alpha: {{ btn_hover_a }};
  }

  #Banner-{{ section.id }} .banner__buttons .button {
    background: transparent !important;
    background-color: transparent !important;
    color: rgba(var(--mc-hero-btn-rest-rgb), var(--mc-hero-btn-rest-alpha)) !important;
    border: 1px solid rgba(var(--mc-hero-btn-rest-rgb), var(--mc-hero-btn-rest-alpha)) !important;
    border-radius: 0 !important;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-weight: 300;
    transition: background-color 250ms ease, color 250ms ease, border-color 250ms ease !important;
    box-shadow: none !important;
  }

  #Banner-{{ section.id }} .banner__buttons .button::before,
  #Banner-{{ section.id }} .banner__buttons .button::after {
    display: none !important;
    content: none !important;
    box-shadow: none !important;
  }

  #Banner-{{ section.id }} .banner__buttons .button:hover,
  #Banner-{{ section.id }} .banner__buttons .button:active,
  #Banner-{{ section.id }} .banner__buttons .button:focus,
  #Banner-{{ section.id }} .banner__buttons .button.focused {
    background-color: rgba(var(--mc-hero-btn-hover-bg-rgb), var(--mc-hero-btn-hover-alpha)) !important;
    border-color: rgba(var(--mc-hero-btn-hover-bg-rgb), var(--mc-hero-btn-hover-alpha)) !important;
    color: rgba(var(--mc-hero-btn-hover-color-rgb), var(--mc-hero-btn-hover-alpha)) !important;
    box-shadow: none !important;
  }

  #Banner-{{ section.id }} .banner__buttons .button:focus:not(:focus-visible):not(.focused) {
    outline: 0;
    box-shadow: none !important;
  }

  #Banner-{{ section.id }} .banner__buttons .button:focus-visible {
    outline: 2px solid rgba(var(--mc-hero-btn-rest-rgb), 0.5);
    outline-offset: 3px;
    box-shadow: none !important;
  }

  {%- liquid
    assign overlay_color = section.settings.hero_overlay_color | default: '#000000'
    assign overlay_r = overlay_color | color_extract: 'red'
    assign overlay_g = overlay_color | color_extract: 'green'
    assign overlay_b = overlay_color | color_extract: 'blue'
    assign overlay_pct = section.settings.hero_overlay_opacity_pct | default: 8
    assign overlay_alpha = overlay_pct | divided_by: 100.0

    assign scroll_color = section.settings.hero_scroll_indicator_color | default: '#FFFFFF'
    assign scroll_r = scroll_color | color_extract: 'red'
    assign scroll_g = scroll_color | color_extract: 'green'
    assign scroll_b = scroll_color | color_extract: 'blue'
    assign scroll_opacity = section.settings.hero_scroll_indicator_opacity | default: 1
    assign scroll_height = section.settings.hero_scroll_indicator_height | default: 50

    assign kb_amp = section.settings.hero_kenburns_amplitude_pct | divided_by: 100.0 | plus: 1
    assign aspect_ratio = section.settings.hero_aspect_ratio | default: '16/9'
    assign max_height_vh = section.settings.hero_max_height_vh | default: 90
  -%}

  @media screen and (min-width: 750px) {
    #Banner-{{ section.id }}:not(.banner--adapt) {
      width: 100% !important;
      aspect-ratio: {{ aspect_ratio }} !important;
      max-height: {{ max_height_vh }}vh !important;
      min-height: 0 !important;
      height: auto !important;
    }
  }

  #Banner-{{ section.id }}::after {
    background-color: rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_alpha }}) !important;
    background-color: color-mix(in srgb, {{ overlay_color }} {{ overlay_pct }}%, transparent) !important;
    background-image: none !important;
    opacity: 1 !important;
  }

  #Banner-{{ section.id }} .banner__box .banner__heading + .banner__text,
  #Banner-{{ section.id }} .banner__box > .banner__heading + .banner__text {
    margin-top: {{ section.settings.hero_spacing_title_to_subtitle }}px !important;
  }

  @media screen and (min-width: 750px) {
    #Banner-{{ section.id }} .banner__box > * + .banner__text {
      margin-top: {{ section.settings.hero_spacing_title_to_subtitle }}px !important;
    }
  }

  #Banner-{{ section.id }} .banner__box > * + .banner__buttons,
  #Banner-{{ section.id }} .banner__box .banner__text + .banner__buttons {
    margin-top: {{ section.settings.hero_spacing_subtitle_to_cta }}px !important;
  }

  {%- if section.settings.hero_kenburns_enabled -%}
    @keyframes mc-hero-kenburns-{{ section.id }} {
      0%   { transform: scale(1); }
      50%  { transform: scale({{ kb_amp }}); }
      100% { transform: scale(1); }
    }
    #Banner-{{ section.id }} .banner__media > img,
    #Banner-{{ section.id }} .banner__media > svg {
      animation: mc-hero-kenburns-{{ section.id }} {{ section.settings.hero_kenburns_duration }}s ease-in-out infinite;
      transform-origin: center center;
      will-change: transform;
    }
    @media (prefers-reduced-motion: reduce) {
      #Banner-{{ section.id }} .banner__media > img,
      #Banner-{{ section.id }} .banner__media > svg {
        animation: none !important;
        transform: none !important;
      }
    }
  {%- endif -%}

  .mc-hero-scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 2.4rem;
    transform: translateX(-50%);
    width: 1.5px;
    height: {{ scroll_height }}px;
    padding: 0;
    margin: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    z-index: 3;
    -webkit-appearance: none;
    appearance: none;
  }
  .mc-hero-scroll-indicator::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 1.5px;
    height: 100%;
    background: rgb({{ scroll_r }}, {{ scroll_g }}, {{ scroll_b }});
    opacity: {{ scroll_opacity }};
    animation: mc-hero-scroll-pulse-{{ section.id }} 2s ease-in-out infinite;
  }
  .mc-hero-scroll-indicator:focus { outline: 0; }
  .mc-hero-scroll-indicator:focus-visible {
    outline: 2px solid rgba({{ scroll_r }}, {{ scroll_g }}, {{ scroll_b }}, 0.5);
    outline-offset: 4px;
  }
  @keyframes mc-hero-scroll-pulse-{{ section.id }} {
    0%   { opacity: {{ scroll_opacity | times: 0.6 }}; transform: translateY(0); }
    50%  { opacity: {{ scroll_opacity }}; transform: translateY(9px); }
    100% { opacity: {{ scroll_opacity | times: 0.6 }}; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mc-hero-scroll-indicator::before {
      animation: none !important;
      opacity: {{ scroll_opacity }};
    }
  }
{%- endstyle -%}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign half_width = '60vw'
    assign full_width = '120vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  elsif section.settings.image_behavior == 'fixed' or section.settings.image_behavior == 'zoom-in'
    assign half_width = '100vw'
    assign stacked_sizes = '100vw'
  else
    assign half_width = '50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 100vw'
  endif
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="Banner-{{ section.id }}"
  class="banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--{{ section.settings.image_height }}{% if section.settings.stack_images_on_mobile and section.settings.image != blank and section.settings.image_2 != blank %} banner--stacked{% endif %}{% if section.settings.image_height == 'adapt' and section.settings.image != blank %} banner--adapt{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{%- endif -%}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  {%- if section.settings.image != blank -%}
    <div class="banner__media media{% if section.settings.image == blank and section.settings.image_2 == blank %} placeholder{% endif %}{% if section.settings.image_2 != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
        if section.settings.image_2 != blank
          assign image_class = 'banner__media-image-half'
        endif
        if section.settings.image_2 != blank and section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        elsif section.settings.image_2 != blank
          assign sizes = half_width
        else
          assign sizes = full_width
        endif
      -%}
      {% if section.settings.hero_video != blank %}
        {{
          section.settings.hero_video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            playsinline: true,
            controls: false,
            class: 'hero-video'
        }}
      {% else %}
        {{
          section.settings.image
          | image_url: width: 3840
          | image_tag:
            width: section.settings.image.width,
            height: image_height,
            class: image_class,
            sizes: sizes,
            widths: widths,
            fetchpriority: fetch_priority
        }}
      {% endif %}
    </div>
  {%- elsif section.settings.image_2 == blank -%}
    <div class="banner__media media{% if section.settings.image == blank and section.settings.image_2 == blank %} placeholder{% endif %}{% if section.settings.image_2 != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}
  {%- if section.settings.image_2 != blank -%}
    <div class="banner__media media{% if section.settings.image != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height_2 = section.settings.image_2.width | divided_by: section.settings.image_2.aspect_ratio
        if section.settings.image != blank
          assign image_class_2 = 'banner__media-image-half'
        endif
        if section.settings.image != blank and section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        elsif section.settings.image_2 != blank
          assign sizes = half_width
        else
          assign sizes = full_width
        endif
      -%}
      {{
        section.settings.image_2
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_2.width,
          height: image_height_2,
          class: image_class_2,
          sizes: sizes,
          widths: widths,
          fetchpriority: fetch_priority
      }}
    </div>
  {%- endif -%}
  {%- if section.settings.hero_scroll_indicator_enabled -%}
    <button
      type="button"
      class="mc-hero-scroll-indicator"
      data-mc-hero-scroll
      data-banner-id="Banner-{{ section.id }}"
      aria-label="Faire défiler vers la section suivante"
    ></button>
  {%- endif -%}
  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="banner__heading inline-richtext {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'text' -%}
            <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'buttons' -%}
            <div
              class="banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if section.settings.hero_scroll_indicator_enabled -%}
  <script>
    (function () {
      var btn = document.querySelector('[data-mc-hero-scroll][data-banner-id="Banner-{{ section.id }}"]');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var banner = document.getElementById('Banner-{{ section.id }}');
        if (!banner) return;
        var holder = banner.closest('.shopify-section') || banner;
        var next = holder.nextElementSibling;
        while (next && next.offsetHeight === 0) next = next.nextElementSibling;
        if (next && typeof next.scrollIntoView === 'function') {
          next.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Vidéo (optionnelle, remplace l'image)",
      "info": "MP4 H.264, ratio 2.4:1, 8-12s, max 5 Mo, sans son. Lecture auto, muet, boucle."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:sections.image-banner.settings.image_2.label"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "nav_hero_gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espace entre menu et hero (px)",
      "info": "Distance verticale entre la fin de la nav éditoriale et le haut du hero.",
      "default": 8
    },
    {
      "type": "range",
      "id": "hero_image_position_x",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Position horizontale image (%)",
      "info": "0 = bord gauche cadré, 50 = centre, 100 = bord droit cadré.",
      "default": 50
    },
    {
      "type": "range",
      "id": "hero_image_position_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Position verticale image (%)",
      "info": "0 = haut cadré, 50 = centre, 100 = bas cadré.",
      "default": 50
    },
    {
      "type": "range",
      "id": "hero_title_size",
      "min": 32,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre hero (px)",
      "info": "Taille du titre Cormorant italique. Clamp adaptatif appliqué entre mobile et desktop.",
      "default": 64
    },
    {
      "type": "header",
      "content": "Bouton CTA du hero"
    },
    {
      "type": "color",
      "id": "hero_button_color_rest",
      "label": "Couleur du bouton au repos (contour et texte)",
      "info": "Couleur du contour et du texte avant survol. À aligner sur la couleur du sous-titre du hero pour cohérence visuelle.",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "hero_button_opacity_rest",
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "label": "Opacité du bouton au repos",
      "info": "Présence du contour et du texte avant survol. 1 = pleine présence, valeurs plus basses = bouton plus discret.",
      "default": 1
    },
    {
      "type": "color",
      "id": "hero_button_bg_hover",
      "label": "Couleur de fond au survol",
      "info": "Couleur qui remplit le bouton quand la souris passe dessus. Default crème pour une inversion douce.",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "hero_button_color_hover",
      "label": "Couleur du texte au survol",
      "info": "Couleur du texte quand le bouton est rempli. Default marron pour cohérence avec la palette.",
      "default": "#332821"
    },
    {
      "type": "range",
      "id": "hero_button_opacity_hover",
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "label": "Opacité du bouton au survol",
      "info": "Présence du bouton rempli. 1 = pleine présence, valeurs plus basses = effet voilé.",
      "default": 1
    },
    {
      "type": "header",
      "content": "Format du hero (aspect-ratio)"
    },
    {
      "type": "select",
      "id": "hero_aspect_ratio",
      "label": "Format du hero",
      "info": "Ratio largeur/hauteur de l'image hero. 16:9 = standard cinéma (recommandé, équivalent Invisible Collection). 21:9 = panoramique large. 2:1 = large. 3:1 = bande très panoramique.",
      "options": [
        { "value": "16/9", "label": "16:9 (cinéma — recommandé)" },
        { "value": "21/9", "label": "21:9 (panoramique)" },
        { "value": "2/1", "label": "2:1 (large)" },
        { "value": "3/1", "label": "3:1 (très panoramique, ne montre qu'une bande)" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "hero_max_height_vh",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hauteur maximale du hero (% écran)",
      "info": "Limite haute pour éviter un hero trop grand sur écrans très larges. 90 par défaut.",
      "default": 90
    },
    {
      "type": "header",
      "content": "Voile sur l'image"
    },
    {
      "type": "color",
      "id": "hero_overlay_color",
      "label": "Couleur du voile sur l'image",
      "info": "Voile très discret qui assombrit légèrement l'image pour faire ressortir le texte. Default noir.",
      "default": "#000000"
    },
    {
