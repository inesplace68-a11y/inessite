{% comment %}
  Bande VOTRE ESPACE — pleine largeur en pierre, visiteur anonyme uniquement.
  Affichée entre le titre éditorial et la grille sur la page Mes Favoris.
{% endcomment %}

{%- unless customer -%}
  {%- style -%}
    .votre-espace-bar-{{ section.id }} {
      width: 100%;
      background-color: {{ section.settings.bar_bg }};
      padding-top: {{ section.settings.bar_padding_y }}px;
      padding-bottom: {{ section.settings.bar_padding_y }}px;
      margin-top: {{ section.settings.spacing_top }}px;
      margin-bottom: {{ section.settings.spacing_bottom }}px;
    }

    .votre-espace-bar-{{ section.id }}__inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .votre-espace-bar-{{ section.id }}__eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      text-transform: uppercase;
      font-size: {{ section.settings.eyebrow_size }}px;
      letter-spacing: {{ section.settings.eyebrow_ls }}em;
      color: {{ section.settings.eyebrow_color }};
      line-height: 1;
    }

    .votre-espace-bar-{{ section.id }}__bullet {
      color: {{ section.settings.bullet_color }};
      font-size: {{ section.settings.body_size }}px;
      line-height: 1;
      user-select: none;
    }

    .votre-espace-bar-{{ section.id }}__body {
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: {{ section.settings.body_size }}px;
      color: {{ section.settings.body_color }};
      line-height: 1.4;
      margin: 0;
    }

    .votre-espace-bar-{{ section.id }}__cta {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      text-transform: uppercase;
      font-size: {{ section.settings.cta_size }}px;
      letter-spacing: {{ section.settings.cta_ls }}em;
      color: {{ section.settings.cta_color }};
      text-decoration: underline;
      text-decoration-thickness: 0.5px;
      text-decoration-color: {{ section.settings.cta_color }};
      text-underline-offset: 3px;
      padding-top: 4px;
      padding-bottom: 4px;
      line-height: 1;
      transition: opacity 200ms ease;
      display: inline-flex;
      align-items: baseline;
      gap: 0.4em;
    }

    .votre-espace-bar-{{ section.id }}__cta:hover,
    .votre-espace-bar-{{ section.id }}__cta:focus-visible {
      opacity: 0.7;
    }

    .votre-espace-bar-{{ section.id }}__cta-arrow {
      text-decoration: none;
      display: inline-block;
    }
  {%- endstyle -%}

  <div class="votre-espace-bar-{{ section.id }}">
    <div class="votre-espace-bar-{{ section.id }}__inner">
      {%- if section.settings.eyebrow_text != blank -%}
        <span class="votre-espace-bar-{{ section.id }}__eyebrow">
          {{- section.settings.eyebrow_text -}}
        </span>
        <span class="votre-espace-bar-{{ section.id }}__bullet" aria-hidden="true">&bull;</span>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <p class="votre-espace-bar-{{ section.id }}__body">
          {{- section.settings.body_text -}}
        </p>
        <span class="votre-espace-bar-{{ section.id }}__bullet" aria-hidden="true">&bull;</span>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a
          class="votre-espace-bar-{{ section.id }}__cta"
          href="{{ section.settings.cta_url }}"
        >
          <span>{{ section.settings.cta_label }}</span>
          <span class="votre-espace-bar-{{ section.id }}__cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endunless -%}

{% schema %}
{
  "name": "Bande Votre Espace",
  "tag": "section",
  "class": "section section--votre-espace-bar",
  "settings": [
    {
      "type": "header",
      "content": "Apparence de la bande"
    },
    {
      "type": "color",
      "id": "bar_bg",
      "label": "Couleur de fond",
      "default": "#E8E4DD"
    },
    {
      "type": "range",
      "id": "bar_padding_y",
      "label": "Padding vertical (haut/bas)",
      "min": 8,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Espace au-dessus de la bande",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Espace en-dessous de la bande",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "bullet_color",
      "label": "Couleur des bullets séparateurs",
      "default": "#B8AC9C"
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Texte eyebrow",
      "default": "VOTRE ESPACE"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Taille eyebrow",
      "min": 8,
      "max": 16,
      "step": 0.5,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_ls",
      "label": "Letter-spacing eyebrow",
      "min": 0,
      "max": 0.4,
      "step": 0.1,
      "unit": "em",
      "default": 0.2
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Couleur eyebrow",
      "default": "#6B645C"
    },
    {
      "type": "header",
      "content": "Texte central"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Texte body",
      "default": "Connectez-vous pour retrouver votre sélection à tout moment."
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Taille body",
      "min": 10,
      "max": 18,
      "step": 0.5,
      "unit": "px",
      "default": 13
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Couleur body",
      "default": "#1A1814"
    },
    {
      "type": "header",
      "content": "Bouton SE CONNECTER"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Libellé CTA",
      "default": "SE CONNECTER"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien CTA",
      "default": "/account/login"
    },
    {
      "type": "range",
      "id": "cta_size",
      "label": "Taille CTA",
      "min": 8,
      "max": 16,
      "step": 0.5,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "cta_ls",
      "label": "Letter-spacing CTA",
      "min": 0,
      "max": 0.4,
      "step": 0.1,
      "unit": "em",
      "default": 0.2
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Couleur CTA",
      "default": "#1A1814"
    }
  ],
  "presets": [
    {
      "name": "Bande Votre Espace"
    }
  ],
  "enabled_on": {
    "templates": ["page"]
  }
}
{% endschema %}
