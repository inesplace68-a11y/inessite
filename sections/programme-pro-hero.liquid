{{ 'section-programme-pro-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pp-hero-padding-top: {{ section.settings.padding_top }}px;
    --pp-hero-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pp-hero-title-size: {{ section.settings.title_size }}px;
    --pp-hero-title-color: {{ section.settings.title_color }};
    --pp-hero-intro-size: {{ section.settings.intro_size }}px;
    --pp-hero-intro-max-width: {{ section.settings.intro_max_width }}px;
    --pp-hero-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --pp-hero-intro-color: {{ section.settings.intro_color }};
    --pp-hero-image-height: {{ section.settings.hero_image_height }}px;
    --pp-hero-image-margin-top: {{ section.settings.hero_image_margin_top }}px;
    --pp-hero-image-side-padding: {{ section.settings.hero_image_side_padding }}px;
  }
{%- endstyle -%}

<section class="programme-pro-hero">
  <div class="programme-pro-hero__inner">
    <h1 class="programme-pro-hero__title">{{ section.settings.title_text | escape }}</h1>

    {%- if section.settings.intro_text != blank -%}
      <div class="programme-pro-hero__intro">{{ section.settings.intro_text }}</div>
    {%- endif -%}

    <div class="programme-pro-hero__image-wrap">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 2400 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w, {{ section.settings.hero_image | image_url: width: 1600 }} 1600w, {{ section.settings.hero_image | image_url: width: 2400 }} 2400w"
          sizes="(max-width: 767px) 100vw, calc(100vw - {{ section.settings.hero_image_side_padding | times: 2 }}px)"
          alt="{{ section.settings.hero_image.alt | default: section.settings.title_text | escape }}"
          loading="lazy"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          class="programme-pro-hero__image"
        >
      {%- else -%}
        <div class="programme-pro-hero__placeholder" role="img" aria-label="Photo à venir">
          <span class="programme-pro-hero__placeholder-label">PHOTO À VENIR</span>
          {%- if section.settings.hero_image_placeholder_caption != blank -%}
            <span class="programme-pro-hero__placeholder-caption">{{ section.settings.hero_image_placeholder_caption | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Programme Pro – Hero",
  "settings": [
    { "type": "header", "content": "Titre" },
    { "type": "text", "id": "title_text", "label": "Titre", "default": "Programme Pro" },
    { "type": "range", "id": "title_size", "min": 40, "max": 160, "step": 2, "unit": "px", "label": "Taille du titre", "default": 96 },
    { "type": "color", "id": "title_color", "label": "Couleur du titre", "default": "#1A1A1A" },

    { "type": "header", "content": "Intro" },
    { "type": "richtext", "id": "intro_text", "label": "Texte d'intro", "default": "<p>Maison Coeur accompagne architectes d'intérieur, décorateurs, hôteliers et restaurateurs dans la recherche et l'acquisition de pièces vintage, de design de collection et d'art singulier. Le Programme Pro offre un accès privilégié à la sélection, à la Conciergerie, et au conseil curatorial en amont des projets.</p>" },
    { "type": "range", "id": "intro_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Taille du texte d'intro", "default": 19 },
    { "type": "range", "id": "intro_max_width", "min": 400, "max": 1000, "step": 10, "unit": "px", "label": "Largeur max de l'intro", "default": 820 },
    { "type": "range", "id": "intro_line_height", "min": 120, "max": 250, "step": 5, "unit": "%", "label": "Interligne de l'intro", "default": 175 },
    { "type": "color", "id": "intro_color", "label": "Couleur de l'intro", "default": "#5A5446" },

    { "type": "header", "content": "Image hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Image hero (vide = placeholder)" },
    { "type": "text", "id": "hero_image_placeholder_caption", "label": "Caption du placeholder (optionnelle)", "info": "Ligne descriptive Cormorant italic affichée sous « PHOTO À VENIR » si l'image hero est vide." },
    { "type": "range", "id": "hero_image_height", "min": 300, "max": 700, "step": 10, "unit": "px", "label": "Hauteur de l'image", "default": 500 },
    { "type": "range", "id": "hero_image_margin_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Marge au-dessus de l'image", "default": 90 },
    { "type": "range", "id": "hero_image_side_padding", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding latéral de l'image", "default": 140 },

    { "type": "header", "content": "Espacements section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding bottom", "default": 160 }
  ],
  "presets": [
    { "name": "Programme Pro – Hero" }
  ]
}
{% endschema %}
