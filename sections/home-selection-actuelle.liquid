{{ 'home-selection-actuelle.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign coll = collections[section.settings.featured_collection]
  assign pieces_total = section.settings.pieces_total
  assign pieces_visible = section.settings.pieces_visible_desktop
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --hs-padding-top: {{ section.settings.padding_top }}px;
    --hs-padding-bottom: {{ section.settings.padding_bottom }}px;
    --hs-pieces-visible: {{ pieces_visible }};
    --hs-card-gap: {{ section.settings.card_gap }}px;
    --hs-eyebrow-margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
  }
{%- endstyle -%}

<section class="home-selection">
  <div class="home-selection__inner">
    {%- if section.settings.show_eyebrow and section.settings.title_eyebrow != blank -%}
      <p class="home-selection__eyebrow">{{ section.settings.title_eyebrow | escape }}</p>
    {%- endif -%}

    {%- if coll != blank and coll.products.size > 0 -%}
      <div class="home-selection__carousel">
        <div
          class="home-selection__track"
          role="region"
          aria-label="{{ section.settings.title_eyebrow | default: 'Sélection actuelle' | escape }}"
          tabindex="0"
          data-home-selection-track
        >
          {%- assign limit = pieces_total -%}
          {%- if coll.products_count < limit -%}
            {%- assign limit = coll.products_count -%}
          {%- endif -%}

          {%- for product in coll.products limit: limit -%}
            <a class="home-selection__card" href="{{ product.url }}">
              <div class="home-selection__media">
                {%- if product.featured_image != blank -%}
                  <img
                    class="home-selection__image"
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
                    sizes="(max-width: 749px) 88vw, (max-width: 989px) 44vw, 23vw"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {%- else -%}
                  <div class="home-selection__image home-selection__image--placeholder"></div>
                {%- endif -%}
              </div>

              <h3 class="home-selection__name">{{ product.title }}</h3>

              <p class="home-selection__price">
                {%- liquid
                  if product.price_varies
                    assign hs_price_str = 'products.product.from_price_html' | t: price: product.price_min
                  else
                    assign hs_price_str = product.price | money
                  endif
                  assign hs_price_str = hs_price_str | replace: '&nbsp;€', '€' | replace: ' €', '€' | replace: ' €', '€' | replace: '€', ' €'
                -%}
                {{ hs_price_str }}
              </p>
            </a>
          {%- endfor -%}
        </div>

        <button
          type="button"
          class="home-selection__nav home-selection__nav--prev"
          data-home-selection-prev
          aria-label="Voir les pièces précédentes"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          type="button"
          class="home-selection__nav home-selection__nav--next"
          data-home-selection-next
          aria-label="Voir les pièces suivantes"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {%- else -%}
      <p class="home-selection__empty">
        Sélectionnez une collection dans les réglages pour afficher la sélection actuelle.
      </p>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-home-selection-track]');
    if (!track) return;
    var prev = root.querySelector('[data-home-selection-prev]');
    var next = root.querySelector('[data-home-selection-next]');

    function cardStep() {
      var card = track.querySelector('.home-selection__card');
      if (!card) return track.clientWidth;
      var styles = window.getComputedStyle(track);
      var gap = parseFloat(styles.columnGap || styles.gap || '0');
      return card.getBoundingClientRect().width + gap;
    }

    function updateNav() {
      var maxScroll = track.scrollWidth - track.clientWidth;
      var hasOverflow = maxScroll > 1;
      if (prev) {
        prev.hidden = !hasOverflow;
        prev.disabled = track.scrollLeft <= 1;
      }
      if (next) {
        next.hidden = !hasOverflow;
        next.disabled = track.scrollLeft >= maxScroll - 1;
      }

      var media = track.querySelector('.home-selection__media');
      if (media) {
        root.style.setProperty('--hs-photo-mid', (media.getBoundingClientRect().height / 2) + 'px');
      }
    }

    if (prev) {
      prev.addEventListener('click', function () {
        track.scrollBy({ left: -cardStep(), behavior: 'smooth' });
      });
    }
    if (next) {
      next.addEventListener('click', function () {
        track.scrollBy({ left: cardStep(), behavior: 'smooth' });
      });
    }
    track.addEventListener('scroll', updateNav, { passive: true });
    window.addEventListener('resize', updateNav);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateNav);
    } else {
      updateNav();
    }
  })();
</script>

{% schema %}
{
  "name": "Home — Sélection actuelle",
  "tag": "section",
  "class": "section section--home-selection",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Eyebrow" },
    {
      "type": "checkbox",
      "id": "show_eyebrow",
      "label": "Afficher l'eyebrow",
      "default": true
    },
    {
      "type": "text",
      "id": "title_eyebrow",
      "label": "Eyebrow (CAPS)",
      "default": "NOUVEAUTÉS"
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Marge sous l'eyebrow",
      "default": 36
    },

    { "type": "header", "content": "Contenu" },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "pieces_visible_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "unit": "pcs",
      "label": "Pièces visibles (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "pieces_total",
      "min": 6,
      "max": 12,
      "step": 1,
      "unit": "pcs",
      "label": "Pool total de pièces",
      "default": 9
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Espace entre cartes",
      "default": 28
    },

    { "type": "header", "content": "Espacements" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "info": "Phase 13 — 3 niveaux harmonisés : 64 compact / 96 standard / 140 immersif.",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 96
    }
  ],
  "presets": [
    { "name": "Home — Sélection actuelle" }
  ]
}
{% endschema %}
