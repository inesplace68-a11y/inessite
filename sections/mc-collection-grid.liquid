{%- style -%}
  #shopify-section-{{ section.id }} .mc-collection-grid {
    --mcg-bg: {{ section.settings.background_color | default: '#F7F5F1' }};
    --mcg-pt: {{ section.settings.padding_top_desktop | default: 56 }}px;
    --mcg-pb: {{ section.settings.padding_bottom_desktop | default: 80 }}px;
    --mcg-pt-mobile: {{ section.settings.padding_top_mobile | default: 40 }}px;
    --mcg-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 48 }}px;
    --mcg-title-gap: {{ section.settings.title_to_grid_gap_desktop | default: 40 }}px;
    --mcg-title-gap-mobile: {{ section.settings.title_to_grid_gap_mobile | default: 28 }}px;
    --mcg-cards-gap: {{ section.settings.cards_gap_desktop | default: 12 }}px;
    --mcg-cards-gap-mobile: {{ section.settings.cards_gap_mobile | default: 10 }}px;
    --mcg-image-to-label: {{ section.settings.image_to_label_gap | default: 18 }}px;
    --mcg-label-to-link: {{ section.settings.label_to_link_gap | default: 8 }}px;
    padding-top: var(--mcg-pt);
    padding-bottom: var(--mcg-pb);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-grid {
      padding-top: var(--mcg-pt-mobile);
      padding-bottom: var(--mcg-pb-mobile);
    }
  }
  #shopify-section-{{ section.id }} .mc-collection-grid .mc-section-heading {
    margin: 0 0 var(--mcg-title-gap);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-grid .mc-section-heading {
      margin: 0 0 var(--mcg-title-gap-mobile);
    }
  }
  #shopify-section-{{ section.id }} .mc-collection-grid__grid {
    gap: var(--mcg-cards-gap);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-grid__grid {
      gap: var(--mcg-cards-gap-mobile);
    }
  }
  #shopify-section-{{ section.id }} .mc-collection-grid__image-wrap {
    margin-bottom: var(--mcg-image-to-label);
  }
  #shopify-section-{{ section.id }} .mc-collection-grid__label {
    margin: 0 0 var(--mcg-label-to-link);
  }
{%- endstyle -%}

<section class="mc-section mc-collection-grid">
  <div class="mc-container">
    {%- if section.settings.title != blank -%}
      <h2 class="mc-section-heading">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mc-collection-grid__grid">
        {%- for block in section.blocks -%}
          <div class="mc-collection-grid__item" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.collection_link | default: '#' }}"
              class="mc-collection-grid__link"
              {% if block.settings.collection_link == blank %}aria-disabled="true"{% endif %}
            >
              <div class="mc-collection-grid__image-wrap">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      class: 'mc-collection-grid__image',
                      widths: '400, 600, 800',
                      sizes: '(min-width: 990px) 25vw, 50vw'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'mc-collection-grid__image placeholder-svg' }}
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank -%}
                <p class="mc-collection-grid__label">{{ block.settings.title }}</p>
              {%- endif -%}

              <p class="mc-collection-grid__discover">
                {{- block.settings.discover_label | default: 'Découvrir' | upcase -}}<span class="mc-collection-grid__discover-arrow" aria-hidden="true">&nbsp;→</span>
              </p>
            </a>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille collections",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de section",
      "default": "NOTRE SÉLECTION"
    },
    { "type": "header", "content": "Apparence" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond de la section Notre Sélection",
      "default": "#F7F5F1"
    },

    { "type": "header", "content": "Espacements section (Phase 16.1)" },
    { "type": "range", "id": "padding_top_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 56, "label": "Marge haute desktop" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 80, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_top_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 40, "label": "Marge haute mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 48, "label": "Marge basse mobile" },

    { "type": "header", "content": "Rythme interne (Phase 16.1)" },
    { "type": "range", "id": "title_to_grid_gap_desktop", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 40, "label": "Gap titre → grille (desktop)" },
    { "type": "range", "id": "title_to_grid_gap_mobile", "min": 12, "max": 60, "step": 4, "unit": "px", "default": 28, "label": "Gap titre → grille (mobile)" },
    { "type": "range", "id": "cards_gap_desktop", "min": 4, "max": 40, "step": 2, "unit": "px", "default": 12, "label": "Gap entre cartes (desktop)" },
    { "type": "range", "id": "cards_gap_mobile", "min": 4, "max": 30, "step": 2, "unit": "px", "default": 10, "label": "Gap entre cartes (mobile)" },
    { "type": "range", "id": "image_to_label_gap", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 18, "label": "Gap image → label" },
    { "type": "range", "id": "label_to_link_gap", "min": 4, "max": 20, "step": 2, "unit": "px", "default": 8, "label": "Gap label → lien Découvrir" }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre catégorie",
          "default": "Catégorie"
        },
        {
          "type": "text",
          "id": "discover_label",
          "label": "Libellé lien",
          "default": "Découvrir"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Lien vers la collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grille collections",
      "blocks": [
        {
          "type": "collection_item",
          "settings": { "title": "OBJETS", "discover_label": "Découvrir", "collection_link": "/collections/objets" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "MIROIRS", "discover_label": "Découvrir", "collection_link": "/collections/miroirs" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "LUMINAIRES", "discover_label": "Découvrir", "collection_link": "/collections/luminaires" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "MOBILIER", "discover_label": "Découvrir", "collection_link": "/collections/mobilier" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "ART", "discover_label": "Découvrir", "collection_link": "/collections/art" }
        }
      ]
    }
  ]
}
{% endschema %}
