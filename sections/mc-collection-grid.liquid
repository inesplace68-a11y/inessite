{%- liquid
  assign cat_text_color = section.settings.selection_cat_text_color | default: '#F7F5F1'
  assign cat_veil_color = section.settings.selection_cat_veil_color | default: '#1A1814'
  assign cat_veil_intensity = section.settings.selection_cat_veil_intensity | default: 55
  assign cat_veil_height = section.settings.selection_cat_veil_height | default: 60
  assign cat_caption_bottom = section.settings.selection_cat_caption_bottom | default: 18
  assign cat_hover_class = ''
  if section.settings.selection_cat_hover_enabled
    assign cat_hover_class = ' mc-collection-grid--hover'
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .mc-collection-grid {
    --mcg-bg: {{ section.settings.background_color | default: '#F7F5F1' }};
    --mcg-pt: {{ section.settings.padding_top_desktop | default: 56 }}px;
    --mcg-pb: {{ section.settings.padding_bottom_desktop | default: 80 }}px;
    --mcg-pt-mobile: {{ section.settings.padding_top_mobile | default: 40 }}px;
    --mcg-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 48 }}px;
    --mcg-title-gap: {{ section.settings.title_to_grid_gap_desktop | default: 40 }}px;
    --mcg-title-gap-mobile: {{ section.settings.title_to_grid_gap_mobile | default: 28 }}px;
    --mcg-cols-mobile: {{ section.settings.mobile_columns | default: 2 }};
    --mcg-gap-mobile: {{ section.settings.grid_gap_mobile | default: 16 }}px;
    --mcg-image-to-label: {{ section.settings.image_to_label_gap | default: 18 }}px;
    --mcg-label-to-link: {{ section.settings.label_to_link_gap | default: 8 }}px;
    --mc-cat-text-color: {{ cat_text_color }};
    --mc-cat-veil-color: {{ cat_veil_color }};
    --mc-cat-veil-intensity: {{ cat_veil_intensity }}%;
    --mc-cat-veil-height: {{ cat_veil_height }}%;
    --mc-cat-caption-bottom: {{ cat_caption_bottom }}px;
    padding-top: var(--mcg-pt);
    padding-bottom: var(--mcg-pb);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-grid {
      padding-top: var(--mcg-pt-mobile);
      padding-bottom: var(--mcg-pb-mobile);
    }
  }
  #shopify-section-{{ section.id }} .mc-collection-grid .mc-section-heading {
    margin-bottom: var(--mcg-title-gap);
    text-align: {{ section.settings.selection_title_alignment | default: 'left' }};
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-collection-grid .mc-section-heading {
      margin-bottom: var(--mcg-title-gap-mobile);
      text-align: center;
    }
  }
{%- endstyle -%}

<section class="mc-section mc-collection-grid{{ cat_hover_class }}">
  <div class="mc-container">
    {%- if section.settings.title != blank -%}
      <h2 class="mc-section-heading">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mc-collection-grid__grid">
        {%- for block in section.blocks -%}
          <div class="mc-collection-grid__item" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.collection_link | default: '#' }}"
              class="mc-cat-card"
              {% if block.settings.collection_link == blank %}aria-disabled="true"{% endif %}
              aria-label="{{ block.settings.title | default: 'Catégorie' | escape }}"
            >
              <div class="mc-cat-card__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      class: 'mc-cat-card__image',
                      widths: '400, 600, 800',
                      sizes: '(min-width: 990px) 25vw, 50vw'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'mc-cat-card__image placeholder-svg' }}
                {%- endif -%}

                <span class="mc-cat-card__veil" aria-hidden="true"></span>

                {%- if block.settings.title != blank -%}
                  <div class="mc-cat-card__caption">
                    <span class="mc-cat-card__title">{{ block.settings.title }}</span>
                    <span class="mc-cat-card__arrow" aria-hidden="true">
                      <svg width="20" height="8" viewBox="0 0 20 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 4H19M12 1L19 4L12 7" stroke="currentColor" stroke-width="1" stroke-linecap="square" stroke-linejoin="miter" />
                      </svg>
                    </span>
                  </div>
                {%- endif -%}
              </div>
            </a>
          </div>
        {%- endfor -%}

        {%- comment -%}
          6e tuile « TOUTE LA COLLECTION » — MOBILE UNIQUEMENT (masquée ≥768px via
          .mc-collection-grid__item--all { display:none } de base → desktop intouché,
          reste 5 tuiles). Fond crème uni #F5F0E8, pas une image-catégorie.
        {%- endcomment -%}
        {%- if section.settings.all_tile_enabled -%}
          {%- assign all_tile_url = section.settings.all_collection_link | default: routes.all_products_collection_url -%}
          <div class="mc-collection-grid__item mc-collection-grid__item--all">
            <a href="{{ all_tile_url }}" class="mc-cat-card mc-cat-card--all" aria-label="{{ section.settings.all_tile_label | default: 'Toute la collection' | escape }}">
              <div class="mc-cat-card__media mc-cat-card__media--all">
                <span class="mc-cat-card__all-label">
                  <span class="mc-cat-card__all-text">{{ section.settings.all_tile_label | default: 'TOUTE LA COLLECTION' | escape }}</span>
                  <span class="mc-cat-card__all-arrow" aria-hidden="true">
                    <svg width="20" height="8" viewBox="0 0 20 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M0 4H19M12 1L19 4L12 7" stroke="currentColor" stroke-width="1" stroke-linecap="square" stroke-linejoin="miter" />
                    </svg>
                  </span>
                </span>
              </div>
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille collections",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de section",
      "default": "NOTRE SÉLECTION"
    },
    {
      "type": "select",
      "id": "selection_title_alignment",
      "label": "Position du titre de section",
      "info": "Place le titre à gauche (cohérence avec NOS NOUVEAUTÉS, signature gallery éditoriale) ou au centre. Sur mobile, le titre reste toujours centré pour lisibilité.",
      "options": [
        { "value": "left", "label": "À gauche (recommandé)" },
        { "value": "center", "label": "Au centre" }
      ],
      "default": "left"
    },
    { "type": "header", "content": "Apparence" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond de la section Notre Sélection",
      "default": "#F7F5F1"
    },

    { "type": "header", "content": "Cartes catégories — titre superposé (Phase 16.56)" },
    {
      "type": "color",
      "id": "selection_cat_text_color",
      "label": "Couleur du texte superposé sur les cartes",
      "info": "Couleur du titre de catégorie et de la flèche, superposés sur l'image. Default crème claire pour lisibilité sur image moyennement contrastée.",
      "default": "#F7F5F1"
    },
    {
      "type": "color",
      "id": "selection_cat_veil_color",
      "label": "Couleur du voile sur les cartes",
      "info": "Voile dégradé qui assombrit le bas de l'image pour faire ressortir le titre. Default noir.",
      "default": "#1A1814"
    },
    {
      "type": "range",
      "id": "selection_cat_veil_intensity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Intensité du voile sur les cartes",
      "info": "0 = aucun voile (image brute, titre peut être illisible). 100 = voile très opaque. Recommandé entre 40 et 70 selon vos images.",
      "default": 55
    },
    {
      "type": "range",
      "id": "selection_cat_veil_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Hauteur du voile (% de la carte)",
      "info": "Proportion de la carte couverte par le voile degrade. Plus haute = plus de l'image est assombrie.",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "selection_cat_hover_enabled",
      "label": "Activer l'effet de survol editorial",
      "info": "Au survol d'une carte : leger zoom de l'image, titre passe en italique, fleche apparait a droite du titre via fade-in. Decocher pour rendu statique.",
      "default": true
    },
    {
      "type": "range",
      "id": "selection_cat_caption_bottom",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Distance du titre par rapport au bas de la carte",
      "info": "Espace vertical entre le bas de l'image et le titre centre. Permet d'ajuster selon vos visuels.",
      "default": 18
    },

    { "type": "header", "content": "Disposition mobile (≤767px)" },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Nombre de colonnes (mobile)",
      "info": "Nombre de colonnes de la grille sous 767px. 2 colonnes = grille 2×3 (recommandé, lisibilité). 3 colonnes = grille 3×2 (tuiles plus compactes). Desktop inchangé.",
      "options": [
        { "value": "2", "label": "2 colonnes (recommandé)" },
        { "value": "3", "label": "3 colonnes" }
      ],
      "default": "2"
    },
    { "type": "range", "id": "grid_gap_mobile", "min": 8, "max": 32, "step": 2, "unit": "px", "default": 16, "label": "Espace entre tuiles (mobile)", "info": "Gap horizontal et vertical entre les tuiles sous 767px." },

    { "type": "header", "content": "6e tuile « Toute la collection » (mobile)" },
    {
      "type": "checkbox",
      "id": "all_tile_enabled",
      "label": "Afficher la tuile « Toute la collection »",
      "info": "Ajoute une 6e tuile (fond crème) en fin de grille, MOBILE uniquement. Désactivée = 5 tuiles.",
      "default": true
    },
    {
      "type": "text",
      "id": "all_tile_label",
      "label": "Texte de la tuile",
      "default": "TOUTE LA COLLECTION"
    },
    {
      "type": "url",
      "id": "all_collection_link",
      "label": "Lien de la tuile",
      "info": "Laisser vide = lien vers tous les produits (/collections/all)."
    },

    { "type": "header", "content": "Espacements section (Phase 16.1 V2)" },
    { "type": "range", "id": "padding_top_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 56, "label": "Marge haute desktop" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 16, "max": 200, "step": 4, "unit": "px", "default": 80, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_top_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 40, "label": "Marge haute mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 48, "label": "Marge basse mobile" },

    { "type": "header", "content": "Rythme vertical interne (Phase 16.1 V2)" },
    { "type": "range", "id": "title_to_grid_gap_desktop", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 40, "label": "Gap vertical titre → grille (desktop)" },
    { "type": "range", "id": "title_to_grid_gap_mobile", "min": 12, "max": 60, "step": 4, "unit": "px", "default": 28, "label": "Gap vertical titre → grille (mobile)" },
    { "type": "range", "id": "image_to_label_gap", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 18, "label": "Gap vertical image → label (carte)" },
    { "type": "range", "id": "label_to_link_gap", "min": 4, "max": 20, "step": 2, "unit": "px", "default": 8, "label": "Gap vertical label → lien Découvrir" }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre catégorie",
          "default": "Catégorie"
        },
        {
          "type": "text",
          "id": "discover_label",
          "label": "Libellé lien (réservé — non affiché en Phase 16.56)",
          "default": "Découvrir"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Lien vers la collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grille collections",
      "blocks": [
        {
          "type": "collection_item",
          "settings": { "title": "OBJETS", "discover_label": "Découvrir", "collection_link": "/collections/objets" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "MIROIRS", "discover_label": "Découvrir", "collection_link": "/collections/miroirs" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "LUMINAIRES", "discover_label": "Découvrir", "collection_link": "/collections/luminaires" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "MOBILIER", "discover_label": "Découvrir", "collection_link": "/collections/mobilier" }
        },
        {
          "type": "collection_item",
          "settings": { "title": "ART", "discover_label": "Découvrir", "collection_link": "/collections/art" }
        }
      ]
    }
  ]
}
{% endschema %}
