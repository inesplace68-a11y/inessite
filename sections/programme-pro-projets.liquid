{{ 'section-programme-pro-projets.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pp-proj-padding-top: {{ section.settings.padding_top }}px;
    --pp-proj-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pp-proj-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --pp-proj-eyebrow-tracking: {{ section.settings.eyebrow_tracking | divided_by: 100.0 }}em;
    --pp-proj-eyebrow-margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
    --pp-proj-content-max-width: {{ section.settings.content_max_width }}px;
    --pp-proj-column-gap: {{ section.settings.column_gap }}px;
    --pp-proj-cta-margin-top: {{ section.settings.cta_margin_top }}px;
  }
{%- endstyle -%}

{%- assign vignettes = 'v1,v2,v3' | split: ',' -%}

<section class="programme-pro-projets">
  <div class="programme-pro-projets__inner">

    {%- if section.settings.eyebrow_text != blank -%}
      <p class="programme-pro-projets__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
    {%- endif -%}

    <ul class="programme-pro-projets__grid" role="list">
      {%- for slot in vignettes -%}
        {%- assign image_key = slot | append: '_image' -%}
        {%- assign secteur_key = slot | append: '_secteur' -%}
        {%- assign titre_key = slot | append: '_titre' -%}
        {%- assign lieu_key = slot | append: '_lieu' -%}
        {%- assign image = section.settings[image_key] -%}
        {%- assign secteur = section.settings[secteur_key] -%}
        {%- assign titre = section.settings[titre_key] -%}
        {%- assign lieu = section.settings[lieu_key] -%}

        <li class="programme-pro-projets__card">
          <div class="programme-pro-projets__media">
            {%- if image != blank -%}
              <img
                src="{{ image | image_url: width: 800 }}"
                srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w"
                sizes="(max-width: 767px) 100vw, 33vw"
                alt="{{ image.alt | default: titre | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {%- else -%}
              <div class="programme-pro-projets__placeholder" role="img" aria-label="Photo à venir">
                <span class="programme-pro-projets__placeholder-text">PHOTO À VENIR</span>
              </div>
            {%- endif -%}
          </div>
          {%- if secteur != blank -%}
            <p class="programme-pro-projets__secteur">{{ secteur | escape }}</p>
          {%- endif -%}
          {%- if titre != blank -%}
            <h3 class="programme-pro-projets__titre">{{ titre | escape }}</h3>
          {%- endif -%}
          {%- if lieu != blank -%}
            <p class="programme-pro-projets__lieu">{{ lieu | escape }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
      <div class="programme-pro-projets__cta-wrap">
        <a href="{{ section.settings.cta_link }}" class="programme-pro-projets__cta">{{ section.settings.cta_text | escape }} →</a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Programme Pro – Projets",
  "settings": [
    { "type": "header", "content": "Eyebrow" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow", "default": "PROJETS ACCOMPAGNÉS" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 24, "step": 1, "unit": "px", "label": "Taille eyebrow", "default": 13 },
    { "type": "range", "id": "eyebrow_tracking", "min": 0, "max": 50, "step": 1, "unit": "%", "label": "Tracking eyebrow", "default": 30 },
    { "type": "range", "id": "eyebrow_margin_bottom", "min": 20, "max": 200, "step": 4, "unit": "px", "label": "Marge sous l'eyebrow", "default": 64 },

    { "type": "header", "content": "Grille" },
    { "type": "range", "id": "content_max_width", "min": 800, "max": 1400, "step": 20, "unit": "px", "label": "Largeur max du contenu", "default": 1200 },
    { "type": "range", "id": "column_gap", "min": 24, "max": 96, "step": 2, "unit": "px", "label": "Gap entre vignettes", "default": 40 },

    { "type": "header", "content": "Vignette 1" },
    { "type": "image_picker", "id": "v1_image", "label": "Image" },
    { "type": "text", "id": "v1_secteur", "label": "Secteur (eyebrow)", "default": "Hôtellerie de luxe" },
    { "type": "text", "id": "v1_titre", "label": "Titre du projet", "default": "Hôtel particulier Côte d'Azur" },
    { "type": "text", "id": "v1_lieu", "label": "Lieu", "default": "Cap d'Antibes, France" },

    { "type": "header", "content": "Vignette 2" },
    { "type": "image_picker", "id": "v2_image", "label": "Image" },
    { "type": "text", "id": "v2_secteur", "label": "Secteur (eyebrow)", "default": "Architecture intérieure" },
    { "type": "text", "id": "v2_titre", "label": "Titre du projet", "default": "Appartement haussmannien" },
    { "type": "text", "id": "v2_lieu", "label": "Lieu", "default": "Paris VIIIe, France" },

    { "type": "header", "content": "Vignette 3" },
    { "type": "image_picker", "id": "v3_image", "label": "Image" },
    { "type": "text", "id": "v3_secteur", "label": "Secteur (eyebrow)", "default": "Restauration gastronomique" },
    { "type": "text", "id": "v3_titre", "label": "Titre du projet", "default": "Table étoilée du Marais" },
    { "type": "text", "id": "v3_lieu", "label": "Lieu", "default": "Paris IIIe, France" },

    { "type": "header", "content": "Lien vers tous les projets" },
    { "type": "text", "id": "cta_text", "label": "Texte du lien", "default": "VOIR TOUS LES PROJETS" },
    { "type": "url", "id": "cta_link", "label": "URL de destination" },
    { "type": "range", "id": "cta_margin_top", "min": 32, "max": 160, "step": 4, "unit": "px", "label": "Marge au-dessus du lien", "default": 64 },

    { "type": "header", "content": "Espacements section" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 300, "step": 4, "unit": "px", "label": "Padding bottom", "default": 60 }
  ],
  "presets": [
    { "name": "Programme Pro – Projets" }
  ]
}
{% endschema %}
