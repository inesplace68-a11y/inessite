{{ 'mc-editorial.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
  assign block_height = section.settings.block_height | default: 75
  assign mobile_height = section.settings.block_height_mobile | default: 60
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop | default: 64
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: 40

  assign heading_size = section.settings.heading_size | default: 52
  assign heading_min = heading_size | times: 60 | divided_by: 100
  if heading_min < 24
    assign heading_min = 24
  endif
  assign heading_mobile = heading_size | times: 70 | divided_by: 100
  if heading_mobile < 24
    assign heading_mobile = 24
  endif

  assign veil_pct = section.settings.veil_opacity_mobile | default: 25
  assign veil_alpha = veil_pct | divided_by: 100.0
  assign veil_alpha_mid = veil_pct | times: 0.5 | divided_by: 100.0
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --mce-overlay-alpha: {{ overlay_alpha }};
    --mce-height: {{ block_height }}vh;
    --mce-height-mobile: {{ mobile_height }}vh;
    --mce-text-color: {{ section.settings.text_color | default: '#FFFFFF' }};
    --mce-button-color: {{ section.settings.button_color | default: '#FFFFFF' }};
    --mce-pb-desktop: {{ padding_bottom_desktop }}px;
    --mce-pb-mobile: {{ padding_bottom_mobile }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: var(--mce-pb-desktop);
    background-color: var(--mc-bg, #F7F5F1);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-bottom: var(--mce-pb-mobile);
    }
  }

  /* Phase 16.59 — font-size titre éditorial customizable.
     Scope strict sur cette section uniquement (id) : aucun effet sur
     le hero ou d'autres titres. */
  #shopify-section-{{ section.id }} .mc-editorial__heading {
    font-size: clamp({{ heading_min }}px, 4.5vw, {{ heading_size }}px);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-editorial__heading {
      font-size: clamp(24px, 7vw, {{ heading_mobile }}px);
    }
  }

  /* Phase 16.9 — corrections MOBILE uniquement (≤749px), scopées à cette section.
     Desktop strictement inchangé. */
  @media (max-width: 749px) {
    /* VOILE : dégradé radial encre (--mc-dark = rgb 26,22,20) derrière le texte,
       concentré au centre et estompé vers les bords. Posé sur le conteneur de
       contenu (centré, avec padding) → détache le texte sans assombrir toute la
       photo. Couleur encre en transparence, aucun nouvel hex. S'ajoute à
       l'overlay plat existant. */
    #shopify-section-{{ section.id }} .mc-editorial__content {
      background-image: radial-gradient(
        ellipse at center,
        rgba(26, 22, 20, {{ veil_alpha }}) 0%,
        rgba(26, 22, 20, {{ veil_alpha_mid }}) 45%,
        rgba(26, 22, 20, 0) 78%
      );
    }

    /* BOUTON : reste un bouton encadré (bordure 1px conservée), plus compact —
       min-width/min-height retirés et padding resserré pour épouser le texte.
       Capitales espacées inchangées. Scopé à ce CTA (jamais le .mc-cta-primary
       global). */
    #shopify-section-{{ section.id }} .mc-editorial__cta {
      min-width: auto;
      min-height: auto;
      padding-block: 8px;
      padding-inline: 16px;
    }
  }

  /* Phase 16.11 — MOBILE uniquement : alignement sur le hero « Reflets du temps »
     (image-banner) pour cohérence visuelle entre les 2 bannières.
     - Taille du titre : même clamp que .banner__heading mobile = clamp(32px, 7vw,
       44px). (44 = hero_title_size 64 × 70%, valeur actuelle de Reflets.)
     - Marges latérales du bloc texte : le conteneur passe pleine largeur avec un
       retrait latéral de 1.5rem de chaque côté, identique au padding horizontal
       de .banner__box mobile (4rem 1.5rem) → marges égales G/D, texte centré.
     - max-width du titre levé (comme .banner__heading qui n'a aucun max-width) :
       le titre remplit la largeur disponible et se centre comme sur Reflets.
     Vertical (padding 40px haut/bas, centrage) inchangé. Desktop intact.
     N'affecte QUE cette bannière. */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mc-editorial__content {
      width: 100%;
      max-width: 100%;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    #shopify-section-{{ section.id }} .mc-editorial__heading {
      font-size: clamp(32px, 7vw, 44px);
      max-width: none;
    }
  }
{%- endstyle -%}

<section
  class="mc-editorial{% if section.settings.image == blank %} mc-editorial--no-image{% endif %}"
  {%- if section.settings.image != blank -%}
    style="background-image: url('{{ section.settings.image | image_url: width: 2400 }}');"
  {%- endif -%}
>
  <div class="mc-editorial__overlay" aria-hidden="true"></div>

  <div class="mc-editorial__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="mc-editorial__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="mc-editorial__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_link | default: '/pages/la-maison' }}"
        class="mc-cta-primary mc-editorial__cta"
        {% if section.settings.cta_link == blank %}aria-disabled="false"{% endif %}
      >
        {{ section.settings.cta_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Brand block — Maison",
  "tag": "section",
  "class": "section section--mc-editorial",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Image de fond" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond",
      "info": "Si vide, fond pierre crème uni en fallback."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Opacité overlay sombre",
      "default": 20
    },
    {
      "type": "range",
      "id": "veil_opacity_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Intensité du voile hero (mobile)",
      "info": "Mobile uniquement (≤749px). Dégradé radial encre derrière le texte, concentré au centre et estompé vers les bords. 0 = aucun. S'ajoute à l'overlay plat ci-dessus.",
      "default": 25
    },

    { "type": "header", "content": "Contenu centré" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MAISON"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Titre éditorial",
      "default": "<p>Une galerie où chaque pièce raconte une histoire.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre éditorial (px)",
      "info": "Police, italique, graisse, interligne et letter-spacing identiques au titre hero (Phase 16.59). Seule la taille reste indépendante — le texte étant plus long que le hero, elle peut être réduite. Le clamp adapte automatiquement mobile/desktop.",
      "default": 52
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Libellé bouton",
      "default": "DÉCOUVRIR LA MAISON"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Cible bouton"
    },

    { "type": "header", "content": "Dimensions" },
    {
      "type": "range",
      "id": "block_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hauteur du bloc (desktop)",
      "default": 75
    },
    {
      "type": "range",
      "id": "block_height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hauteur du bloc (mobile)",
      "default": 60
    },

    { "type": "header", "content": "Couleurs" },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte (eyebrow + titre)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Couleur bouton (bordure + texte)",
      "default": "#FFFFFF"
    },

    { "type": "header", "content": "Espacements (Phase 16.1 V2)" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "Marge haute (image full-bleed)",
      "info": "Image full-bleed inchangée — défaut 0.",
      "default": 0
    },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64, "label": "Marge basse desktop" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40, "label": "Marge basse mobile" }
  ],
  "presets": [
    {
      "name": "Brand block — Maison"
    }
  ]
}
{% endschema %}
