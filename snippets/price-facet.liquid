{%- comment -%}
  Phase 16.7 — Filtre prix en curseur range à 2 poignées (Maison Coeur).

  Markup HTML uniquement : la logique JS (synchronisation poignées,
  display, debounce submit) est centralisée dans le bloc <script>
  de sections/main-collection-product-grid.liquid pour éviter la
  duplication quand le snippet est re-rendu à chaque update facets.

  Les inputs `type="range"` conservent les `name` Shopify natifs
  (filter.v.price.gte / .lte) ; leur événement `change` est attrapé
  par le web component <price-range> et propagé au form parent
  via FacetFiltersForm (assets/facets.js).

  Échelle : on travaille en euros entiers (cents / 100). Shopify
  accepte un entier d'euros pour le param de prix.

  Params :
    filter      : filter object Liquid (results.filters[i])
    id_prefix   : 'Filter-' (desktop/drawer) ou 'Mobile-Filter-'
    filter_type : 'vertical' (drawer) ou 'horizontal'
{%- endcomment -%}

{%- liquid
  assign max_in_cents = filter.range_max
  assign max_eur = max_in_cents | divided_by: 100

  assign min_v_cents = filter.min_value.value | default: 0
  assign max_v_cents = filter.max_value.value | default: max_in_cents
  assign min_v_eur = min_v_cents | divided_by: 100
  assign max_v_eur = max_v_cents | divided_by: 100

  assign currency_symbol = cart.currency.symbol
-%}

<div
  class="mc-price-slider"
  data-mc-price-slider
  data-max="{{ max_eur }}"
  data-currency="{{ currency_symbol }}"
>
  <div class="mc-price-slider__display">
    <span class="mc-price-slider__display-prep">Entre </span><span class="mc-price-slider__display-value" data-mc-min-display>{{ min_v_eur }}</span><span class="mc-price-slider__display-currency"> {{ currency_symbol }}</span><span class="mc-price-slider__display-prep"> et </span><span class="mc-price-slider__display-value" data-mc-max-display>{{ max_v_eur }}</span><span class="mc-price-slider__display-currency"> {{ currency_symbol }}</span>
  </div>
  <div class="mc-price-slider__rail">
    <div class="mc-price-slider__track">
      <div class="mc-price-slider__range" data-mc-range></div>
    </div>
    <input
      class="mc-price-slider__input mc-price-slider__input--min"
      type="range"
      name="{{ filter.min_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-GTE"
      min="0"
      max="{{ max_eur }}"
      step="1"
      value="{{ min_v_eur }}"
      aria-label="Prix minimum"
      data-mc-min
    >
    <input
      class="mc-price-slider__input mc-price-slider__input--max"
      type="range"
      name="{{ filter.max_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-LTE"
      min="0"
      max="{{ max_eur }}"
      step="1"
      value="{{ max_v_eur }}"
      aria-label="Prix maximum"
      data-mc-max
    >
  </div>
</div>
